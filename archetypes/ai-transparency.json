{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "ai-transparency",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "AI Transparency",
  "description": "AI model observability and transparency dashboard for inspecting inference logs, confidence distributions, and neural feedback cycles across deployed models.",
  "tags": [
    "ai",
    "transparency",
    "observability",
    "monitoring",
    "analytics",
    "explainability",
    "2026"
  ],
  "role": "auxiliary",
  "classification": {
    "triggers": {
      "primary": [
        "ai-transparency",
        "model-observability",
        "explainability",
        "inference-monitor"
      ],
      "secondary": [
        "confidence",
        "model-metrics",
        "ai-audit",
        "bias-detection",
        "interpretability"
      ],
      "negative": [
        "chatbot",
        "code-generation"
      ]
    },
    "implies": [
      "monitoring",
      "analytics"
    ],
    "weight": 0.8,
    "tier": "core"
  },
  "pages": [
    {
      "id": "model-overview",
      "default_layout": [
        {
          "pattern": "stats-overview",
          "as": "model-kpis"
        },
        {
          "pattern": "neural-feedback-loop",
          "as": "feedback-summary"
        }
      ],
      "shell": "sidebar-main",
      "notes": "High-level model health: stats-overview shows latency, throughput, error rates; neural-feedback-loop shows aggregate decision cycle patterns"
    },
    {
      "id": "inference-log",
      "default_layout": [
        {
          "pattern": "agent-timeline",
          "as": "inference-trace"
        }
      ],
      "shell": "sidebar-main",
      "notes": "Chronological inference trace: each entry shows input, output, confidence, latency, and token usage with expandable reasoning chains"
    },
    {
      "id": "confidence-explorer",
      "default_layout": [
        {
          "pattern": "intent-radar",
          "as": "confidence-distribution"
        },
        {
          "pattern": "stats-detail",
          "as": "metric-breakdown"
        }
      ],
      "shell": "sidebar-main",
      "notes": "Intent-radar visualizes confidence spread across categories; stats-detail breaks down per-model and per-endpoint metrics"
    }
  ],
  "features": [
    "monitoring",
    "analytics",
    "observability"
  ],
  "shells": {
    "sidebar-main": "Sidebar navigation with main content area for data exploration"
  },
  "suggested_theme": {
    "styles": [
      "carbon",
      "neon-dark"
    ],
    "modes": [
      "dark"
    ]
  },
  "dependencies": {
    "patterns": {
      "stats-overview": ">=1.0.0",
      "neural-feedback-loop": ">=1.0.0",
      "agent-timeline": ">=1.0.0",
      "intent-radar": ">=1.0.0",
      "stats-detail": ">=1.0.0"
    },
    "styles": {}
  }
}
