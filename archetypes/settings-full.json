{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "settings-full",
  "role": "auxiliary",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Settings Full",
  "description": "Complete account settings with profile, security (password, MFA, sessions), preferences (theme, notifications, language), and danger zone.",
  "tags": [
    "settings",
    "account",
    "profile",
    "security",
    "preferences"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "settings",
        "account settings",
        "user settings",
        "preferences"
      ],
      "secondary": [
        "profile",
        "security",
        "password",
        "theme"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1,
    "tier": "core"
  },
  "pages": [
    {
      "id": "profile",
      "patterns": [
        {
          "pattern": "account-settings",
          "preset": "profile",
          "as": "settings"
        }
      ],
      "default_layout": [
        "account-settings"
      ],
      "shell": "inherit"
    },
    {
      "id": "security",
      "patterns": [
        {
          "pattern": "account-settings",
          "preset": "security",
          "as": "security-settings"
        },
        {
          "pattern": "session-manager",
          "preset": "standard",
          "as": "sessions"
        }
      ],
      "default_layout": [
        "account-settings",
        "sessions"
      ],
      "shell": "inherit"
    },
    {
      "id": "preferences",
      "patterns": [
        {
          "pattern": "account-settings",
          "preset": "preferences",
          "as": "settings"
        }
      ],
      "default_layout": [
        "account-settings"
      ],
      "shell": "inherit"
    },
    {
      "id": "danger",
      "patterns": [
        {
          "pattern": "account-settings",
          "preset": "danger-zone",
          "as": "settings"
        }
      ],
      "default_layout": [
        "account-settings"
      ],
      "shell": "inherit"
    }
  ],
  "page_briefs": {
    "profile": "Profile settings form with avatar upload, display name, email, and bio fields. Save button at the bottom of each section. Clean grouped form layout.",
    "security": "Security settings with password change form (current + new password fields), MFA toggle with setup flow, and active sessions table showing device, location, and last-active with revoke buttons.",
    "preferences": "Preferences form with theme selector (light/dark/auto toggle), notification preference checkboxes, language dropdown, and timezone selector.",
    "danger": "Danger zone section with red-bordered cards for destructive actions. Export data button, deactivate account toggle, and delete account button with confirmation dialog warning."
  },
  "features": [
    "profile-edit",
    "password-change",
    "mfa-management",
    "session-management",
    "theme-toggle",
    "account-deletion"
  ],
  "shells": {
    "inherit": "Inherits shell from parent archetype or app context"
  },
  "dependencies": {
    "patterns": {
      "account-settings": "^1.0.0",
      "session-manager": "^1.0.0"
    },
    "styles": {}
  },
  "suggested_theme": {
    "ids": [
      "carbon"
    ],
    "modes": [
      "dark",
      "light"
    ]
  }
}
