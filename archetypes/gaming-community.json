{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "gaming-community",
  "version": "1.0.0",
  "decantr_compat": ">=0.10.0",
  "name": "Gaming Community",
  "description": "Guild hub, news feed, hall of fame, and member profiles for social gaming communities",
  "tags": [
    "gaming",
    "community",
    "guild",
    "leaderboard",
    "social",
    "esports"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "guild",
        "clan",
        "community",
        "leaderboard",
        "social gaming"
      ],
      "secondary": [
        "news feed",
        "member profile",
        "hall of fame",
        "achievements",
        "esports"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "main",
      "patterns": [
        {
          "pattern": "hero",
          "preset": "landing",
          "as": "guild-hero"
        },
        "kpi-grid",
        "activity-feed",
        {
          "pattern": "leaderboard",
          "preset": "spotlight",
          "as": "top-players"
        }
      ],
      "default_layout": [
        {
          "pattern": "hero",
          "preset": "landing",
          "as": "guild-hero"
        },
        "kpi-grid",
        {
          "cols": [
            "activity-feed",
            "top-players"
          ],
          "at": "lg"
        }
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "news",
      "patterns": [
        "filter-bar",
        "post-list"
      ],
      "default_layout": [
        "filter-bar",
        "post-list"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "hall-of-fame",
      "patterns": [
        "stats-bar",
        {
          "pattern": "leaderboard",
          "preset": "ranked",
          "as": "guild-leaderboard"
        },
        "timeline"
      ],
      "default_layout": [
        "stats-bar",
        {
          "pattern": "leaderboard",
          "preset": "ranked",
          "as": "guild-leaderboard"
        },
        "timeline"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "member-profile",
      "patterns": [
        {
          "pattern": "detail-header",
          "preset": "profile",
          "as": "player-header"
        },
        "kpi-grid",
        {
          "pattern": "leaderboard",
          "preset": "grid",
          "as": "achievements"
        },
        "activity-feed",
        "timeline"
      ],
      "default_layout": [
        {
          "pattern": "detail-header",
          "preset": "profile",
          "as": "player-header"
        },
        "kpi-grid",
        {
          "cols": [
            "achievements",
            "activity-feed"
          ],
          "span": {
            "achievements": 2
          },
          "at": "lg"
        },
        "timeline"
      ],
      "shell": "sidebar-main"
    }
  ],
  "features": [
    "guild-state",
    "achievements",
    "realtime-data"
  ],
  "shells": {
    "sidebar-main": "Left sidebar with grouped nav (INFO + SPOTLIGHT sections) + main content area"
  },
  "dependencies": {
    "patterns": {
      "activity-feed": "^1.0.0",
      "detail-header": "^1.0.0",
      "filter-bar": "^1.0.0",
      "hero": "^1.0.0",
      "kpi-grid": "^1.0.0",
      "leaderboard": "^1.0.0",
      "post-list": "^1.0.0",
      "stats-bar": "^1.0.0",
      "timeline": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "gaming-guild"
    ],
    "modes": [
      "dark"
    ]
  }
}
