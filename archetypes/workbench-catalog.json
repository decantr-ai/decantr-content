{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "workbench-catalog",
  "role": "auxiliary",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Workbench Catalog",
  "description": "Component and pattern catalog browser for the design-system workbench. Browsable grid with instant search, detail views with JSON inspection.",
  "tags": [
    "catalog",
    "components",
    "patterns",
    "design-system",
    "browser",
    "2026"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "component catalog",
        "pattern browser",
        "design system catalog",
        "component library",
        "pattern catalog"
      ],
      "secondary": [
        "component browser",
        "storybook",
        "pattern library",
        "ui catalog",
        "component registry"
      ],
      "negative": [
        "ecommerce",
        "social",
        "marketing"
      ]
    },
    "implies": [
      "search",
      "browsing"
    ],
    "weight": 0.8,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "catalog",
      "patterns": [
        {
          "pattern": "card-grid",
          "preset": "icon",
          "as": "component-grid"
        },
        {
          "pattern": "search-filter-bar",
          "preset": "standard",
          "as": "catalog-search"
        }
      ],
      "default_layout": [
        "catalog-search",
        "component-grid"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "catalog-detail",
      "patterns": [
        {
          "pattern": "detail-header",
          "preset": "standard",
          "as": "component-header"
        },
        {
          "pattern": "json-viewer",
          "preset": "standard",
          "as": "component-spec"
        }
      ],
      "default_layout": [
        "component-header",
        "component-spec"
      ],
      "shell": "sidebar-main"
    }
  ],
  "page_briefs": {
    "catalog": "Search-filter bar at top with category filters and instant keyword search. Below, a card grid of component cards with icon, name, description snippet, and tag pills. Cards link to detail view. Dense grid layout maximizing information density.",
    "catalog-detail": "Detail header showing component name, description, version, and tags. Below, a JSON viewer displaying the full component specification with syntax highlighting, collapsible sections, and copy-to-clipboard. Usage examples and variant previews where applicable."
  },
  "features": [
    "search",
    "filtering"
  ],
  "shells": {
    "sidebar-main": "Sidebar with category tree navigation and main content area"
  },
  "suggested_theme": {
    "styles": [
      "carbon",
      "terminal"
    ],
    "modes": [
      "dark"
    ]
  },
  "dependencies": {
    "patterns": {
      "card-grid": ">=1.0.0",
      "search-filter-bar": ">=1.0.0",
      "detail-header": ">=1.0.0",
      "json-viewer": ">=1.0.0"
    },
    "styles": {}
  }
}