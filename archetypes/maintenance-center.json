{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "maintenance-center",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Maintenance Center",
  "description": "Maintenance ticket management with Kanban board view, ticket details, and ticket creation for property repairs.",
  "tags": [
    "property-management",
    "maintenance",
    "tickets",
    "kanban",
    "repairs"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "maintenance management",
        "repair tickets",
        "work orders",
        "maintenance board"
      ],
      "secondary": [
        "property repairs",
        "vendor management",
        "maintenance requests"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "board",
      "patterns": [
        {
          "pattern": "maintenance-board",
          "preset": "board",
          "as": "board"
        }
      ],
      "default_layout": [
        "board"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "ticket",
      "patterns": [
        {
          "pattern": "maintenance-ticket",
          "preset": "view",
          "as": "ticket"
        }
      ],
      "default_layout": [
        "ticket"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "create",
      "patterns": [
        {
          "pattern": "maintenance-ticket",
          "preset": "edit",
          "as": "form"
        }
      ],
      "default_layout": [
        "form"
      ],
      "shell": "sidebar-main"
    }
  ],
  "features": [
    "kanban",
    "drag-drop",
    "file-upload",
    "notifications"
  ],
  "shells": {
    "sidebar-main": "Sidebar navigation for maintenance management"
  },
  "dependencies": {
    "patterns": {
      "maintenance-board": "^1.0.0",
      "maintenance-ticket": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "estate"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
