{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "cloud-infrastructure",
  "version": "1.0.0",
  "decantr_compat": ">=0.10.0",
  "name": "Cloud Infrastructure",
  "description": "Infrastructure management pages: apps, deployments, teams, services, tokens, usage monitoring, status, and compliance",
  "tags": [
    "cloud",
    "infrastructure",
    "deploy",
    "devops",
    "monitoring",
    "compliance"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "cloud",
        "infrastructure",
        "deploy",
        "containers",
        "kubernetes",
        "servers"
      ],
      "secondary": [
        "microservices",
        "devops",
        "monitoring",
        "CI/CD",
        "tokens",
        "compliance"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "apps",
      "patterns": [
        "filter-bar",
        "card-grid",
        "activity-feed"
      ],
      "default_layout": [
        "filter-bar",
        {
          "cols": [
            {
              "pattern": "card-grid",
              "preset": "resource",
              "as": "app-grid"
            },
            "activity-feed"
          ],
          "span": {
            "app-grid": 2
          },
          "at": "lg"
        }
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "app-detail",
      "patterns": [
        "detail-header",
        "kpi-grid",
        "deploy-log",
        "data-table"
      ],
      "default_layout": [
        "detail-header",
        "kpi-grid",
        {
          "cols": [
            {
              "pattern": "deploy-log",
              "preset": "live",
              "as": "deploy-log"
            },
            "data-table"
          ],
          "at": "lg"
        }
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "team",
      "patterns": [
        "filter-bar",
        "card-grid"
      ],
      "default_layout": [
        "filter-bar",
        {
          "pattern": "card-grid",
          "preset": "user",
          "as": "team-grid"
        }
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "activity",
      "patterns": [
        "filter-bar",
        "activity-feed"
      ],
      "default_layout": [
        "filter-bar",
        "activity-feed"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "services",
      "patterns": [
        "service-catalog"
      ],
      "default_layout": [
        {
          "pattern": "service-catalog",
          "preset": "grid",
          "as": "service-grid"
        }
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "tokens",
      "patterns": [
        "filter-bar",
        "data-table"
      ],
      "default_layout": [
        {
          "pattern": "filter-bar",
          "preset": "toolbar",
          "as": "token-toolbar"
        },
        "data-table"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "usage",
      "patterns": [
        "resource-overview",
        "chart-grid"
      ],
      "default_layout": [
        {
          "pattern": "resource-overview",
          "preset": "gauge-grid",
          "as": "resource-gauges"
        },
        "chart-grid"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "status",
      "patterns": [
        "status-board"
      ],
      "default_layout": [
        "status-board"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "compliance",
      "patterns": [
        "checklist-card",
        "data-table"
      ],
      "default_layout": [
        {
          "pattern": "checklist-card",
          "preset": "onboarding",
          "as": "compliance-checklist"
        },
        "data-table"
      ],
      "shell": "sidebar-main"
    }
  ],
  "features": [
    "realtime-data",
    "team-management"
  ],
  "shells": {
    "sidebar-main": "Left sidebar with grouped nav + main content area"
  },
  "dependencies": {
    "patterns": {
      "activity-feed": "^1.0.0",
      "card-grid": "^1.0.0",
      "chart-grid": "^1.0.0",
      "checklist-card": "^1.0.0",
      "data-table": "^1.0.0",
      "deploy-log": "^1.0.0",
      "detail-header": "^1.0.0",
      "filter-bar": "^1.0.0",
      "kpi-grid": "^1.0.0",
      "resource-overview": "^1.0.0",
      "service-catalog": "^1.0.0",
      "status-board": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "launchpad",
      "clean"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
