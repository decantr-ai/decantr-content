{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "document-editor",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Document Editor",
  "description": "Real-time collaborative document editing with presence indicators, remote cursors, inline comments, and version history.",
  "tags": [
    "editor",
    "collaboration",
    "realtime",
    "documents",
    "writing"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "document editor",
        "collaborative editing",
        "real-time editor",
        "notion-like",
        "linear-like"
      ],
      "secondary": [
        "rich text editor",
        "block editor",
        "comments",
        "presence"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "doc",
      "patterns": [
        {
          "pattern": "doc-editor",
          "preset": "standard",
          "as": "editor"
        },
        {
          "pattern": "presence-avatars",
          "preset": "standard",
          "as": "presence"
        },
        {
          "pattern": "remote-cursor",
          "preset": "standard",
          "as": "cursors"
        },
        {
          "pattern": "comment-thread",
          "preset": "sidebar",
          "as": "comments"
        },
        {
          "pattern": "activity-feed",
          "preset": "compact",
          "as": "activity"
        },
        {
          "pattern": "page-tree",
          "preset": "standard",
          "as": "nav"
        },
        {
          "pattern": "share-modal",
          "preset": "invite",
          "as": "share"
        },
        {
          "pattern": "version-history",
          "preset": "sidebar",
          "as": "history"
        }
      ],
      "default_layout": [
        "nav",
        "presence",
        "editor",
        "comments"
      ],
      "shell": "workspace-aside"
    }
  ],
  "features": [
    "realtime",
    "presence",
    "comments",
    "mentions",
    "versioning",
    "sharing",
    "export",
    "markdown",
    "slash-commands"
  ],
  "shells": {
    "workspace-aside": "Three-column layout: page tree, document editor, comment sidebar"
  },
  "dependencies": {
    "patterns": {
      "doc-editor": "^1.0.0",
      "presence-avatars": "^1.0.0",
      "remote-cursor": "^1.0.0",
      "comment-thread": "^1.0.0",
      "page-tree": "^1.0.0",
      "share-modal": "^1.0.0",
      "version-history": "^1.0.0",
      "activity-feed": "^1.0.0",
      "block-toolbar": "^1.0.0",
      "slash-command": "^1.0.0",
      "mention-popup": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "paper"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
