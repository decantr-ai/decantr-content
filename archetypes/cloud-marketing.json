{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "cloud-marketing",
  "version": "1.0.0",
  "decantr_compat": ">=0.10.0",
  "name": "Cloud Marketing",
  "description": "Marketing landing page for cloud and infrastructure platforms",
  "tags": [
    "cloud",
    "marketing",
    "landing",
    "homepage"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "cloud landing",
        "infrastructure marketing",
        "cloud homepage"
      ],
      "secondary": [
        "platform marketing",
        "cloud product page"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 0.6,
    "tier": "optional"
  },
  "pages": [
    {
      "id": "home",
      "patterns": [
        "hero",
        "card-grid",
        "logo-strip",
        "stats-section",
        "cta-section",
        "footer-columns"
      ],
      "default_layout": [
        {
          "pattern": "hero",
          "preset": "brand",
          "as": "brand-hero"
        },
        {
          "pattern": "card-grid",
          "preset": "icon",
          "as": "feature-grid"
        },
        {
          "pattern": "logo-strip",
          "preset": "marquee",
          "as": "tech-logos"
        },
        {
          "pattern": "card-grid",
          "preset": "icon",
          "as": "capability-grid"
        },
        {
          "pattern": "stats-section",
          "preset": "hero",
          "as": "platform-stats"
        },
        {
          "pattern": "cta-section",
          "preset": "brand",
          "as": "enterprise-cta"
        },
        {
          "pattern": "footer-columns",
          "preset": "minimal",
          "as": "footer"
        }
      ],
      "shell": "full-bleed"
    }
  ],
  "features": [],
  "shells": {
    "full-bleed": "Floating nav over scroll-driven marketing sections — hero-first, maximum visual impact"
  },
  "dependencies": {
    "patterns": {
      "hero": "^1.0.0",
      "card-grid": "^1.0.0",
      "logo-strip": "^1.0.0",
      "stats-section": "^1.0.0",
      "cta-section": "^1.0.0",
      "footer-columns": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "launchpad",
      "clean"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
