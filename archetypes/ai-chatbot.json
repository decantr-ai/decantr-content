{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "ai-chatbot",
  "role": "primary",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "AI Chatbot",
  "description": "AI chatbot interface with conversation sidebar, message thread, and anchored input. Core interface for chat-first AI applications.",
  "tags": [
    "ai",
    "chat",
    "conversational",
    "assistant",
    "llm"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "chatbot",
        "ai assistant",
        "conversational ai",
        "chat interface",
        "llm chat"
      ],
      "secondary": [
        "message thread",
        "conversation history",
        "ai chat",
        "claude",
        "gpt"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "chat",
      "patterns": [
        {
          "pattern": "chat-header",
          "preset": "standard",
          "as": "header"
        },
        {
          "pattern": "chat-thread",
          "preset": "standard",
          "as": "messages"
        },
        {
          "pattern": "chat-input",
          "preset": "standard",
          "as": "input"
        }
      ],
      "default_layout": [
        "chat-header",
        "chat-thread",
        "chat-input"
      ],
      "shell": "chat-portal"
    },
    {
      "id": "new",
      "patterns": [
        {
          "pattern": "chat-thread",
          "preset": "standard",
          "as": "empty-thread"
        },
        {
          "pattern": "chat-input",
          "preset": "standard",
          "as": "input"
        }
      ],
      "default_layout": [
        "chat-thread",
        "chat-input"
      ],
      "shell": "chat-portal"
    }
  ],
  "page_briefs": {
    "chat": "Three-region chat interface. Collapsible conversation sidebar on the left lists previous chats. Center area is a scrollable message thread with alternating user and AI bubbles. Anchored input bar at the bottom with text field, send button, and file attachment.",
    "new": "Clean centered view for starting a new conversation. Empty thread area with placeholder prompt suggestions. Anchored input bar at bottom, conversation sidebar still accessible on the left."
  },
  "features": [
    "chat",
    "markdown",
    "code-highlight",
    "file-upload",
    "mentions",
    "reactions",
    "export"
  ],
  "shells": {
    "chat-portal": "Collapsible conversation sidebar with message thread and anchored input"
  },
  "dependencies": {
    "patterns": {
      "chat-header": "^1.0.0",
      "chat-thread": "^1.0.0",
      "chat-input": "^1.0.0",
      "chat-message": "^1.0.0",
      "conversation-list": "^1.0.0"
    },
    "styles": {}
  },
  "suggested_theme": {
    "ids": [
      "carbon"
    ],
    "modes": [
      "dark",
      "light"
    ]
  }
}
