{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "workbench-core",
  "role": "primary",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Workbench Core",
  "description": "Multi-panel IDE workspace with split-pane layout, command palette, and component detail view. The primary workspace for design system power users.",
  "tags": [
    "workbench",
    "ide",
    "workspace",
    "split-pane",
    "developer",
    "2026"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "workbench workspace",
        "ide workspace",
        "split-pane editor",
        "design system workbench",
        "component workspace"
      ],
      "secondary": [
        "multi-panel",
        "resizable panes",
        "command palette",
        "keyboard-driven",
        "developer workspace"
      ],
      "negative": [
        "dashboard",
        "ecommerce",
        "social"
      ]
    },
    "implies": [
      "developer-tools",
      "keyboard-driven"
    ],
    "weight": 1,
    "tier": "core"
  },
  "pages": [
    {
      "id": "workspace",
      "patterns": [
        {
          "pattern": "split-pane",
          "preset": "standard",
          "as": "main-panes"
        },
        {
          "pattern": "command-palette",
          "preset": "standard",
          "as": "command-palette"
        }
      ],
      "default_layout": [
        "main-panes",
        "command-palette"
      ],
      "shell": "sidebar-aside"
    },
    {
      "id": "component-detail",
      "patterns": [
        {
          "pattern": "split-pane",
          "preset": "standard",
          "as": "detail-panes"
        },
        {
          "pattern": "json-viewer",
          "preset": "standard",
          "as": "component-data"
        }
      ],
      "default_layout": [
        "detail-panes",
        "component-data"
      ],
      "shell": "sidebar-aside"
    }
  ],
  "page_briefs": {
    "workspace": "Multi-panel IDE layout with resizable split panes. Component tree on the left, live preview center, property inspector right. Command palette overlay accessible via Cmd+K. Tabs for multiple open items. Status bar at bottom with context info.",
    "component-detail": "Split-pane view focused on a single component. Left pane shows live rendered preview. Right pane shows JSON data viewer with syntax highlighting for component props, state, and configuration. Breadcrumb navigation at top."
  },
  "features": [
    "keyboard-shortcuts",
    "split-pane",
    "command-palette"
  ],
  "shells": {
    "sidebar-aside": "Collapsible activity bar with icon navigation, main content area, and optional right aside panel"
  },
  "suggested_theme": {
    "styles": [
      "carbon",
      "terminal"
    ],
    "modes": [
      "dark"
    ]
  },
  "dependencies": {
    "patterns": {
      "split-pane": ">=1.0.0",
      "command-palette": ">=1.0.0",
      "json-viewer": ">=1.0.0"
    },
    "styles": {}
  }
}