{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "marketing-devtool",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Marketing DevTool",
  "description": "Developer tool landing page with terminal-styled hero, feature highlights, and ASCII art elements. Marketing page that maintains the terminal aesthetic.",
  "tags": [
    "terminal",
    "marketing",
    "landing",
    "developer",
    "cli"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "dev tool landing",
        "cli tool marketing",
        "developer product page",
        "tool homepage"
      ],
      "secondary": [
        "terminal marketing",
        "hacker aesthetic",
        "developer marketing"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 0.8,
    "tier": "optional"
  },
  "pages": [
    {
      "id": "home",
      "patterns": [
        {
          "pattern": "hero",
          "preset": "terminal",
          "as": "hero"
        },
        {
          "pattern": "card-grid",
          "preset": "feature",
          "as": "features"
        },
        {
          "pattern": "ascii-chart",
          "preset": "line",
          "as": "demo-chart"
        },
        {
          "pattern": "terminal-emulator",
          "preset": "readonly",
          "as": "demo-terminal"
        },
        {
          "pattern": "cta-banner",
          "preset": "standard",
          "as": "cta"
        }
      ],
      "default_layout": [
        "hero",
        "features",
        "demo-terminal",
        "demo-chart",
        "cta"
      ],
      "shell": "top-nav-footer"
    },
    {
      "id": "docs",
      "patterns": [
        {
          "pattern": "prose-section",
          "preset": "standard",
          "as": "documentation"
        },
        {
          "pattern": "terminal-emulator",
          "preset": "readonly",
          "as": "code-examples"
        }
      ],
      "default_layout": [
        "documentation",
        "code-examples"
      ],
      "shell": "top-nav-footer"
    }
  ],
  "features": [
    "terminal-hero",
    "ascii-demo",
    "code-examples",
    "installation-guide"
  ],
  "shells": {
    "top-nav-footer": "Standard marketing layout with terminal styling"
  },
  "dependencies": {
    "patterns": {
      "hero": "^1.0.0",
      "card-grid": "^1.0.0",
      "ascii-chart": "^1.0.0",
      "terminal-emulator": "^1.0.0",
      "cta-banner": "^1.0.0",
      "prose-section": "^1.0.0"
    },
    "recipes": {
      "terminal": "^1.0.0"
    },
    "styles": {
      "terminal": "^1.0.0"
    }
  },
  "suggested_theme": {
    "styles": [
      "terminal"
    ],
    "modes": [
      "dark"
    ]
  },
  "hero_customization": {
    "style": "terminal",
    "elements": [
      "ascii-art-logo",
      "typing-effect-tagline",
      "terminal-demo",
      "installation-command"
    ],
    "background": "scanlines-optional"
  }
}
