{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "fan-checkout",
  "role": "auxiliary",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Fan Checkout",
  "description": "Purchase and subscription checkout flow for fans. Complete payment for subscriptions and one-time purchases.",
  "tags": [
    "fan",
    "checkout",
    "payment",
    "subscribe",
    "purchase"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "checkout",
        "payment flow",
        "subscribe checkout"
      ],
      "secondary": [
        "purchase",
        "payment"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "checkout",
      "patterns": [
        {
          "pattern": "checkout-flow",
          "preset": "subscribe",
          "as": "subscribe-checkout"
        }
      ],
      "default_layout": [
        "checkout-flow"
      ],
      "shell": "minimal-header"
    },
    {
      "id": "purchase",
      "patterns": [
        {
          "pattern": "checkout-flow",
          "preset": "purchase",
          "as": "purchase-checkout"
        }
      ],
      "default_layout": [
        "checkout-flow"
      ],
      "shell": "minimal-header"
    },
    {
      "id": "success",
      "patterns": [
        {
          "pattern": "cta-section",
          "preset": "success",
          "as": "success-message"
        }
      ],
      "default_layout": [
        "chat-message"
      ],
      "shell": "minimal-header"
    }
  ],
  "page_briefs": {
    "checkout": "Minimal distraction checkout. Centered subscribe flow with plan summary card, payment method form with card fields, promo code input, and confirm button. Apple Pay and Google Pay buttons above card form.",
    "purchase": "Single-item purchase checkout. Product summary at top with image and price. Payment form below with card fields and confirm purchase button.",
    "success": "Centered success message card with animated checkmark, confirmation text, order/subscription details summary, and a button to continue to the content library."
  },
  "features": [
    "stripe-integration",
    "promo-codes",
    "apple-pay",
    "google-pay"
  ],
  "shells": {
    "minimal-header": "Minimal distraction checkout layout"
  },
  "dependencies": {
    "patterns": {
      "checkout-flow": "^1.0.0",
      "cta-section": "^1.0.0"
    },
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "studio"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
