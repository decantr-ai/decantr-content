{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "portfolio",
  "version": "1.0.0",
  "decantr_compat": ">=0.10.0",
  "name": "Portfolio",
  "description": "Personal portfolio for showcasing projects, skills, and professional background",
  "tags": [
    "portfolio",
    "creative",
    "showcase",
    "personal",
    "projects"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "portfolio",
        "showcase",
        "personal-site",
        "creative"
      ],
      "secondary": [
        "projects",
        "work",
        "resume",
        "freelance",
        "designer"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "home",
      "default_layout": [
        {
          "pattern": "hero",
          "preset": "landing"
        },
        {
          "pattern": "card-grid",
          "preset": "content",
          "as": "featured-projects"
        },
        "cta-section"
      ],
      "shell": "top-nav-main"
    },
    {
      "id": "project-detail",
      "default_layout": [
        {
          "pattern": "detail-header",
          "preset": "standard"
        },
        "cta-section"
      ],
      "shell": "top-nav-main"
    },
    {
      "id": "about",
      "default_layout": [
        {
          "pattern": "hero",
          "preset": "split"
        },
        "activity-feed"
      ],
      "shell": "top-nav-main"
    },
    {
      "id": "contact",
      "default_layout": [
        {
          "pattern": "form-sections",
          "preset": "creation"
        }
      ],
      "shell": "top-nav-main"
    }
  ],
  "features": [
    "analytics",
    "contact-form"
  ],
  "shells": {
    "top-nav-main": "Top navigation bar with main content area"
  },
  "dependencies": {
    "patterns": {
      "hero": "^1.0.0",
      "card-grid": "^1.0.0",
      "cta-section": "^1.0.0",
      "detail-header": "^1.0.0",
      "activity-feed": "^1.0.0",
      "form-sections": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "auradecantism",
      "minimal",
      "elegant"
    ],
    "modes": [
      "light",
      "auto"
    ]
  }
}
