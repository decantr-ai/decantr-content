{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "notifications",
  "role": "auxiliary",
  "version": "1.0.0",
  "decantr_compat": ">=0.10.0",
  "name": "Notifications",
  "description": "Notification inbox and alert management",
  "tags": [
    "notifications",
    "inbox",
    "alerts",
    "messages",
    "updates"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "notifications",
        "inbox",
        "alerts"
      ],
      "secondary": [
        "messages",
        "updates",
        "notification center"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 0.6,
    "tier": "optional"
  },
  "pages": [
    {
      "id": "notifications",
      "default_layout": [
