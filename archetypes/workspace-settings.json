{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "workspace-settings",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Workspace Settings",
  "description": "Team workspace configuration including general settings, member management, permissions, and billing.",
  "tags": [
    "settings",
    "workspace",
    "admin",
    "team",
    "permissions"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "workspace settings",
        "team settings",
        "admin settings",
        "organization settings"
      ],
      "secondary": [
        "member management",
        "permissions",
        "billing",
        "team management"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "general",
      "patterns": [
        {
          "pattern": "form-sections",
          "preset": "standard",
          "as": "workspace-info"
        }
      ],
      "default_layout": [
        "workspace-info"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "members",
      "patterns": [
        {
          "pattern": "data-table",
          "preset": "standard",
          "as": "members-table"
        },
        {
          "pattern": "share-modal",
          "preset": "members",
          "as": "invite"
        }
      ],
      "default_layout": [
        "members-table",
        "invite"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "permissions",
      "patterns": [
        {
          "pattern": "permission-matrix",
          "preset": "granular",
          "as": "permissions"
        }
      ],
      "default_layout": [
        "permissions"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "billing",
      "patterns": [
        {
          "pattern": "pricing-usage",
          "preset": "standard",
          "as": "plan"
        },
        {
          "pattern": "form-sections",
          "preset": "billing",
          "as": "billing-info"
        }
      ],
      "default_layout": [
        "plan",
        "billing-info"
      ],
      "shell": "sidebar-main"
    }
  ],
  "features": [
    "team-management",
    "permissions",
    "billing",
    "admin"
  ],
  "shells": {
    "sidebar-main": "Settings navigation sidebar with main content area"
  },
  "dependencies": {
    "patterns": {
      "form-sections": "^1.0.0",
      "data-table": "^1.0.0",
      "share-modal": "^1.0.0",
      "permission-matrix": "^1.0.0",
      "pricing-usage": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "paper"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
