{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "marketing-marketplace",
  "role": "public",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Marketplace Marketing",
  "description": "Public-facing marketing and landing pages for a two-sided marketplace. Showcases featured listings, categories, testimonials, and conversion CTAs.",
  "tags": [
    "marketplace",
    "marketing",
    "landing",
    "seo",
    "public"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "marketplace landing",
        "marketplace homepage",
        "marketplace marketing"
      ],
      "secondary": [
        "featured listings",
        "marketplace about",
        "marketplace categories"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "home",
      "patterns": [
        {
          "pattern": "hero",
          "preset": "landing",
          "as": "hero"
        },
        {
          "pattern": "card-grid",
          "preset": "content",
          "as": "featured-listings"
        },
        {
          "pattern": "testimonials",
          "preset": "standard",
          "as": "social-proof"
        },
        {
          "pattern": "cta-section",
          "preset": "standard",
          "as": "cta"
        }
      ],
      "default_layout": [
        "hero",
        "featured-listings",
        "social-proof",
        "cta"
      ],
      "shell": "top-nav-footer"
    },
    {
      "id": "about",
      "patterns": [
        {
          "pattern": "hero",
          "preset": "brand",
          "as": "about-hero"
        }
      ],
      "default_layout": [
        "about-hero"
      ],
      "shell": "top-nav-footer"
    }
  ],
  "page_briefs": {
    "home": "Marketplace landing page with a bold hero section featuring a search bar, tagline, and background imagery. Below, a content card grid showcases featured listings organized by category. A testimonials section displays buyer and seller quotes with avatars. The page closes with a prominent CTA section encouraging sign-up or listing creation.",
    "about": "Brand story page with a large hero section featuring the marketplace mission statement, founding story imagery, and team values. Clean typography-focused layout that communicates trust and community."
  },
  "features": [
    "marketing",
    "seo",
    "featured-listings"
  ],
  "shells": {
    "top-nav-footer": "Top navigation with footer layout for public pages"
  },
  "dependencies": {
    "patterns": {
      "hero": "^1.0.0",
      "card-grid": "^1.0.0",
      "testimonials": "^1.0.0",
      "cta-section": "^1.0.0"
    },
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "carbon"
    ],
    "modes": [
      "dark",
      "light"
    ]
  }
}
