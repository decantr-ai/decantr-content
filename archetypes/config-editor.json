{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "config-editor",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Config Editor",
  "description": "Configuration file editor with tree navigation, diff view, and terminal integration. For managing app configuration in a terminal interface.",
  "tags": [
    "terminal",
    "config",
    "editor",
    "settings",
    "developer"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "config editor",
        "settings editor",
        "configuration manager",
        "dotfiles"
      ],
      "secondary": [
        "yaml editor",
        "json editor",
        "env editor",
        "toml editor"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 0.8,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "config",
      "patterns": [
        {
          "pattern": "status-bar",
          "preset": "bottom",
          "as": "status"
        },
        {
          "pattern": "split-pane",
          "preset": "horizontal",
          "as": "main-split"
        },
        {
          "pattern": "tree-view",
          "preset": "standard",
          "as": "file-tree"
        },
        {
          "pattern": "terminal-emulator",
          "preset": "standard",
          "as": "editor"
        },
        {
          "pattern": "hotkey-bar",
          "preset": "standard",
          "as": "hotkeys"
        }
      ],
      "default_layout": [
        "main-split",
        "status",
        "hotkeys"
      ],
      "shell": "terminal-split"
    },
    {
      "id": "diff",
      "patterns": [
        {
          "pattern": "status-bar",
          "preset": "top",
          "as": "status"
        },
        {
          "pattern": "diff-view",
          "preset": "split",
          "as": "diff"
        },
        {
          "pattern": "hotkey-bar",
          "preset": "standard",
          "as": "hotkeys"
        }
      ],
      "default_layout": [
        "status",
        "diff",
        "hotkeys"
      ],
      "shell": "terminal-split"
    }
  ],
  "features": [
    "file-tree",
    "syntax-highlight",
    "diff-view",
    "search-replace",
    "undo-redo",
    "auto-save"
  ],
  "shells": {
    "terminal-split": "Terminal layout with file tree and editor panes"
  },
  "dependencies": {
    "patterns": {
      "status-bar": "^1.0.0",
      "split-pane": "^1.0.0",
      "tree-view": "^1.0.0",
      "terminal-emulator": "^1.0.0",
      "diff-view": "^1.0.0",
      "hotkey-bar": "^1.0.0"
    },
    "recipes": {
      "terminal": "^1.0.0"
    },
    "styles": {
      "terminal": "^1.0.0"
    }
  },
  "suggested_theme": {
    "styles": [
      "terminal"
    ],
    "modes": [
      "dark"
    ]
  }
}
