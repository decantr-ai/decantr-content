{
  "$schema": "https://decantr.ai/schemas/style-metadata.v1.json",
  "id": "luminarum",
  "name": "Luminarum",
  "description": "Dark geometric canvas with vibrant faceted color accents. Breathing gradient orbs, outlined cards with colored strokes, particle network details. Tech-forward meets visual candy.",
  "tags": [
    "dark",
    "vibrant",
    "geometric",
    "technical",
    "premium",
    "colorful"
  ],
  "personality": "sharp + bold elevation + breathing motion + colored strokes + geometric gradients",
  "seed": {
    "primary": "#FE4474",
    "secondary": "#0AF3EB",
    "accent": "#FDA303",
    "background": "#0D0D1A"
  },
  "palette": {
    "coral": "#F58882",
    "pink": "#FE4474",
    "crimson": "#D80F4A",
    "cyan": "#0AF3EB",
    "green": "#00E0AB",
    "amber": "#FDA303",
    "yellow": "#FCD021",
    "orange": "#FC8D0D",
    "purple": "#6500C6"
  },
  "modes": [
    "dark"
  ],
  "shapes": [
    "rounded",
    "pill"
  ],
  "cvd_support": ["deuteranopia", "protanopia"],
  "tokens": {
    "base": {
      "danger": "#EF4444",
      "success": "#22C55E",
      "warning": "#F59E0B"
    },
    "cvd": {
      "deuteranopia": {
        "danger": "#FF8F00",
        "success": "#2196F3"
      },
      "protanopia": {
        "danger": "#FFC107",
        "success": "#03A9F4"
      }
    }
  },
  "decantr_compat": ">=1.0.0",
  "source": "core"
}
