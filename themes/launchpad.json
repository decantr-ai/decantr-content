{
  "$schema": "https://decantr.ai/schemas/style-metadata.v1.json",
  "id": "launchpad",
  "name": "Launchpad",
  "description": "Clean, professional aesthetic inspired by fly.io. Navy-violet palette, semi-transparent surfaces, violet-tinted shadows. Gradient accent buttons, transparent nav with violet active states.",
  "tags": [
    "professional",
    "violet",
    "navy",
    "saas",
    "gradient-buttons"
  ],
  "personality": "rounded + shadow elevation + smooth motion + thin borders + no gradients",
  "seed": {
    "primary": "#7C3AED",
    "secondary": "#4F46E5",
    "accent": "#06B6D4",
    "background": "#F9F9FD"
  },
  "modes": [
    "light",
    "dark"
  ],
  "shapes": [
    "sharp",
    "rounded",
    "pill"
  ],
  "decantr_compat": ">=0.9.0",
  "source": "community",
  "palette": {
    "background": { "light": "#F9F9FD", "dark": "#0C0A14" },
    "surface": { "light": "#FFFFFF", "dark": "#141020" },
    "surface-raised": { "light": "#F4F2FA", "dark": "#1C1830" },
    "border": { "light": "#E4E0F0", "dark": "#2E2848" },
    "text": { "light": "#1A1530", "dark": "#F0EEF8" },
    "text-muted": { "light": "#706A88", "dark": "#9890B0" },
    "primary": { "light": "#7C3AED", "dark": "#9F6EFF" },
    "primary-hover": { "light": "#6D28D9", "dark": "#B08AFF" }
  },
  "decorators": {
    "lp-surface": "Base surface with subtle texture. Light mode: #FAFAFA, Dark mode: #111111.",
    "lp-nav": "Sticky navigation with blur backdrop. Minimal branding.",
    "lp-header": "Large hero with gradient mesh background.",
    "lp-card-elevated": "Card with elevation shadow, hover lift effect.",
    "lp-gradient-mesh": "Subtle gradient mesh in primary/accent colors at 5% opacity.",
    "lp-button-primary": "Solid primary color button with hover scale.",
    "lp-fade-in": "Simple fade-in on scroll, 0.4s duration."
  },
  "spatial": {
    "density_bias": 0,
    "content_gap_shift": 0,
    "section_padding": "96px",
    "card_wrapping": "standard",
    "surface_override": null
  },
  "motion": {
    "preference": "subtle",
    "reduce_motion": true,
    "entrance": "lp-fade-in",
    "micro": "snappy",
    "timing": "ease-out",
    "durations": {
      "hover": "150ms",
      "entrance": "400ms"
    }
  },
  "effects": {
    "enabled": true,
    "intensity": "subtle",
    "type_mapping": {
      "hero_section": [
        "lp-gradient-mesh"
      ],
      "feature_card": [
        "lp-card-elevated"
      ],
      "cta_button": [
        "lp-button-primary"
      ]
    }
  },
  "radius": {
    "philosophy": "rounded",
    "base": 8
  },
  "shell": {
    "preferred": [
      "top-nav-main",
      "minimal-header"
    ],
    "avoid": [
      "sidebar-main"
    ],
    "nav_style": "minimal",
    "default_nav_state": "expanded",
    "root": "lp-surface",
    "nav": "lp-nav",
    "header": "lp-header",
    "brand": "lp-brand"
  },
  "card_styles": {
    "elevated": {
      "description": "Clean card with subtle shadow and rounded corners",
      "properties": {
        "background": "var(--lp-surface)",
        "border-radius": "12px",
        "box-shadow": "0 4px 24px rgba(0,0,0,0.08)"
      }
    },
    "outlined": {
      "description": "Card with thin border, no shadow",
      "properties": {
        "background": "transparent",
        "border": "1px solid var(--lp-border)",
        "border-radius": "12px"
      }
    }
  },
  "typography": {
    "scale": "modular",
    "heading_weight": 600,
    "body_weight": 400
  }
}
