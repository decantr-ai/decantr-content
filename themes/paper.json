{
  "$schema": "https://decantr.ai/schemas/style-metadata.v1.json",
  "id": "paper",
  "name": "Paper",
  "description": "Clean, minimal, content-focused theme with warm whites and soft grays. Inspired by high-end writing apps like iA Writer, Bear, and Notion.",
  "tags": [
    "warm",
    "light",
    "minimal",
    "writing",
    "clean",
    "professional",
    "collaboration"
  ],
  "personality": "warm + clean + minimal + content-focused",
  "seed": {
    "primary": "#2E8B8B",
    "secondary": "#78756F",
    "accent": "#E07B4C",
    "background": "#FDFCFA"
  },
  "palette": {
    "background": {
      "light": "#FDFCFA",
      "dark": "#1C1B1A"
    },
    "surface": {
      "light": "#FFFFFF",
      "dark": "#252422"
    },
    "surface-raised": {
      "light": "#F9F8F6",
      "dark": "#2D2B29"
    },
    "border": {
      "light": "#E8E6E3",
      "dark": "#3D3A36"
    },
    "text": {
      "light": "#1A1918",
      "dark": "#FAF9F7"
    },
    "text-muted": {
      "light": "#78756F",
      "dark": "#A8A49E"
    },
    "primary": {
      "light": "#2E8B8B",
      "dark": "#3DA5A5"
    },
    "primary-hover": {
      "light": "#257575",
      "dark": "#4DBFBF"
    },
    "accent": {
      "light": "#E07B4C",
      "dark": "#F09B6C"
    }
  },
  "presence": {
    "colors": [
      {
        "name": "Blue",
        "light": "#3B82F6",
        "dark": "#60A5FA"
      },
      {
        "name": "Purple",
        "light": "#8B5CF6",
        "dark": "#A78BFA"
      },
      {
        "name": "Pink",
        "light": "#EC4899",
        "dark": "#F472B6"
      },
      {
        "name": "Orange",
        "light": "#F97316",
        "dark": "#FB923C"
      },
      {
        "name": "Teal",
        "light": "#14B8A6",
        "dark": "#2DD4BF"
      },
      {
        "name": "Yellow",
        "light": "#EAB308",
        "dark": "#FACC15"
      },
      {
        "name": "Red",
        "light": "#EF4444",
        "dark": "#F87171"
      },
      {
        "name": "Green",
        "light": "#22C55E",
        "dark": "#4ADE80"
      }
    ]
  },
  "modes": [
    "light",
    "dark",
    "auto"
  ],
  "shapes": [
    "rounded",
    "sharp"
  ],
  "cvd_support": [
    "deuteranopia",
    "protanopia"
  ],
  "tokens": {
    "base": {
      "success": "#22C55E",
      "danger": "#EF4444",
      "warning": "#EAB308",
      "info": "#3B82F6"
    },
    "cvd": {
      "deuteranopia": {
        "success": "#3B82F6",
        "danger": "#F97316"
      },
      "protanopia": {
        "success": "#0EA5E9",
        "danger": "#FACC15"
      }
    }
  },
  "decantr_compat": ">=1.0.0",
  "source": "core",
  "decorators": {
    "paper-canvas": "Warm cream background in light mode, soft charcoal in dark. Clean foundation for content.",
    "paper-surface": "Clean panel surface with subtle warmth. Used for sidebars and elevated areas.",
    "paper-card": "Minimal card styling with 1px warm border, 6px radius, no shadow. Content over decoration.",
    "paper-input": "Warm gray border with teal focus ring. Clean input styling for forms and editors.",
    "paper-divider": "Hairline separator using warm gray. Subtle content division.",
    "paper-prose": "Optimized typography for reading. 16px base, 1.75 line-height, Inter font stack, max-width 680px.",
    "paper-comment": "Comment bubble with subtle shadow and presence color accent. Used in comment threads.",
    "paper-cursor": "Remote cursor SVG with name label. Colored by collaborator presence color.",
    "paper-presence": "Avatar ring indicating collaborator presence. Ring color matches assigned presence color.",
    "paper-selection": "Highlighted text selection for remote collaborators. Tinted with presence color at 20% opacity.",
    "paper-fade": "Entrance animation: opacity 0 to 1, 180ms natural easing. No translation."
  },
  "spatial": {
    "density_bias": 0,
    "content_gap_shift": 0,
    "section_padding": "64px",
    "card_wrapping": "none",
    "surface_override": null
  },
  "motion": {
    "preference": "subtle",
    "reduce_motion": true,
    "entrance": "paper-fade",
    "micro": "smooth",
    "timing": "cubic-bezier(0.25, 0.1, 0.25, 1)",
    "durations": {
      "hover": "120ms",
      "entrance": "180ms",
      "modal": "200ms",
      "page": "250ms",
      "cursor": "50ms"
    }
  },
  "effects": {
    "enabled": true,
    "intensity": "minimal",
    "type_mapping": {
      "card": [
        "paper-card"
      ],
      "input": [
        "paper-input"
      ],
      "editor": [
        "paper-prose"
      ],
      "comment": [
        "paper-comment"
      ]
    },
    "component_fallback": {
      "pre": "editor",
      "code": "editor",
      "Card": "card",
      "Input": "input"
    }
  },
  "compositions": {
    "editor": {
      "description": "Document editor with real-time collaboration. Page tree, editor, and comment sidebar.",
      "shell": "workspace-aside",
      "effects": [
        "paper-prose",
        "paper-cursor"
      ]
    },
    "workspace": {
      "description": "Workspace dashboard with activity and recent documents.",
      "shell": "sidebar-main",
      "card_style": "paper-card"
    },
    "auth": {
      "description": "Centered auth forms with clean card styling.",
      "shell": "centered",
      "card_style": "paper-card"
    },
    "marketing": {
      "description": "Marketing pages with top nav and footer. Clean sections with generous whitespace.",
      "shell": "top-nav-footer"
    }
  },
  "radius": {
    "philosophy": "rounded",
    "base": 8
  },
  "pattern_preferences": {
    "prefer": [
      "doc-editor",
      "page-tree",
      "comment-thread",
      "presence-avatars",
      "activity-feed"
    ],
    "avoid": [],
    "default_presets": {}
  },
  "shell": {
    "preferred": [
      "workspace-aside",
      "sidebar-main",
      "top-nav-footer"
    ],
    "avoid": [
      "full-bleed"
    ],
    "nav_style": "minimal",
    "default_nav_state": "expanded",
    "root": "paper-canvas",
    "nav": "paper-surface",
    "header": "",
    "navLabel": "",
    "brand": "",
    "dimensions": null
  },
  "typography": {
    "scale": "modular",
    "heading_weight": 600,
    "body_weight": 400
  }
}
