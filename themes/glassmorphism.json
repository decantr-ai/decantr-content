{
  "$schema": "https://decantr.ai/schemas/style-metadata.v1.json",
  "id": "glassmorphism",
  "name": "Glassmorphism",
  "description": "Stormy blue frosted glass aesthetic. Dark glass surfaces with blue-tinted borders, sky-blue primary, cyan accents, and atmospheric gradient backgrounds.",
  "tags": [
    "glass",
    "frosted",
    "stormy",
    "atmospheric",
    "blur"
  ],
  "personality": "rounded + glass elevation + smooth motion + thin borders + vivid gradients",
  "seed": {
    "primary": "#38bdf8",
    "secondary": "#22d3ee",
    "accent": "#4ade80",
    "background": "#f0f4f9"
  },
  "modes": [
    "light",
    "dark"
  ],
  "shapes": [
    "sharp",
    "rounded",
    "pill"
  ],
  "decantr_compat": ">=0.9.0",
  "source": "community",
  "decorators": {
    "glass-backdrop": "Dark gradient background with subtle noise texture.",
    "glass-panel": "Frosted panel with blur(20px), 5% white background, subtle border.",
    "glass-card": "Individual glass card element.",
    "glass-header": "Glass hero section with layered blur panels.",
    "glass-overlay": "Modal overlay with heavy blur.",
    "glass-fade-up": "Entrance animation: fade + translateY(20px) over 0.5s."
  },
  "spatial": {
    "density_bias": 0,
    "content_gap_shift": 0,
    "section_padding": "80px",
    "card_wrapping": "glass",
    "surface_override": null
  },
  "motion": {
    "preference": "subtle",
    "reduce_motion": true,
    "entrance": "glass-fade-up",
    "micro": "smooth"
  },
  "effects": {
    "enabled": true,
    "intensity": "medium",
    "type_mapping": {
      "card": [
        "glass-card"
      ],
      "nav": [
        "glass-panel"
      ],
      "modal": [
        "glass-overlay"
      ]
    }
  },
  "radius": {
    "philosophy": "rounded",
    "base": 8
  },
  "shell": {
    "preferred": [
      "sidebar-main",
      "top-nav-main"
    ],
    "avoid": [],
    "nav_style": "glass",
    "default_nav_state": "expanded",
    "root": "glass-backdrop",
    "nav": "glass-panel",
    "header": "glass-header"
  },
  "card_styles": {
    "glass": {
      "description": "Frosted glass card with blur and subtle border",
      "properties": {
        "background": "rgba(255,255,255,0.05)",
        "backdrop-filter": "blur(20px)",
        "border": "1px solid rgba(255,255,255,0.1)",
        "border-radius": "16px"
      }
    }
  },
  "typography": {
    "scale": "modular",
    "heading_weight": 600,
    "body_weight": 400
  }
}
