{
  "$schema": "https://decantr.ai/schemas/style-metadata.v1.json",
  "id": "clean",
  "name": "Clean",
  "description": "Professional, understated, universally appropriate. Subtle shadows, smooth motion, rounded corners. The safe default.",
  "tags": [
    "professional",
    "minimal",
    "universal",
    "subtle"
  ],
  "personality": "rounded + subtle elevation + smooth motion + thin borders + no gradients",
  "seed": {
    "primary": "#1366D9",
    "secondary": "#7c3aed",
    "accent": "#0891b2",
    "background": "#ffffff"
  },
  "modes": [
    "light",
    "dark"
  ],
  "shapes": [
    "sharp",
    "rounded",
    "pill"
  ],
  "decantr_compat": ">=0.9.0",
  "source": "community",
  "palette": {
    "background": { "light": "#FFFFFF", "dark": "#111111" },
    "surface": { "light": "#FFFFFF", "dark": "#1A1A1A" },
    "surface-raised": { "light": "#F8F8F8", "dark": "#222222" },
    "border": { "light": "#E5E5E5", "dark": "#333333" },
    "text": { "light": "#111111", "dark": "#F5F5F5" },
    "text-muted": { "light": "#6B7280", "dark": "#9CA3AF" },
    "primary": { "light": "#1366D9", "dark": "#3B82F6" },
    "primary-hover": { "light": "#0D4EA6", "dark": "#60A5FA" }
  },
  "decorators": {
    "clean-surface": "Pure white (#FFFFFF) or near-black (#111111) depending on mode.",
    "clean-nav": "Minimal navigation with text links, no backgrounds.",
    "clean-surface-raised": "Slightly elevated surface for cards (2% darker/lighter).",
    "clean-card": "Bordered card with 1px border, 8px radius, no shadow at rest, subtle shadow on hover transition.",
    "clean-input": "Standard input with thin border, rounded corners, and blue focus ring using primary color."
  },
  "spatial": {
    "density_bias": 0,
    "content_gap_shift": 0,
    "section_padding": "64px",
    "card_wrapping": "standard",
    "surface_override": null
  },
  "motion": {
    "preference": "subtle",
    "reduce_motion": true,
    "entrance": "none",
    "micro": "instant",
    "timing": "ease-out",
    "durations": {
      "hover": "150ms",
      "entrance": "200ms"
    }
  },
  "effects": {
    "enabled": false,
    "intensity": "none"
  },
  "radius": {
    "philosophy": "rounded",
    "base": 8
  },
  "shell": {
    "preferred": [
      "top-nav-main",
      "sidebar-main"
    ],
    "avoid": [],
    "nav_style": "minimal",
    "default_nav_state": "collapsed",
    "root": "clean-surface",
    "nav": "clean-nav",
    "header": ""
  },
  "card_styles": {
    "flat": {
      "description": "Borderless card with subtle background difference",
      "properties": {
        "background": "var(--clean-surface-raised)",
        "border-radius": "8px"
      }
    },
    "bordered": {
      "description": "Card with thin border, no shadow",
      "properties": {
        "background": "var(--clean-surface)",
        "border": "1px solid var(--clean-border)",
        "border-radius": "8px"
      }
    }
  },
  "typography": {
    "scale": "modular",
    "heading_weight": 600,
    "body_weight": 400
  }
}
