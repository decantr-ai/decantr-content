{
  "$schema": "https://decantr.ai/schemas/style-metadata.v1.json",
  "id": "bioluminescent",
  "name": "Bioluminescent",
  "description": "Deep ocean aesthetic. Organic glow. Luminescent edges on dark backgrounds, living and breathing UI. Glowing borders, pulsing animations, deep abyss backgrounds.",
  "tags": [
    "ocean",
    "glow",
    "organic",
    "luminescent",
    "deep-sea"
  ],
  "personality": "pill + glow elevation + smooth motion + no borders + vivid gradients",
  "seed": {
    "primary": "#00ffd5",
    "secondary": "#7b61ff",
    "accent": "#ff6b9d",
    "background": "#f0fdf4"
  },
  "modes": [
    "light",
    "dark"
  ],
  "shapes": [
    "sharp",
    "rounded",
    "pill"
  ],
  "decantr_compat": ">=0.9.0",
  "source": "community",
  "typography_hints": {
    "scale": "modular",
    "heading_weight": 600,
    "body_weight": 400
  },
  "motion_hints": {
    "preference": "subtle",
    "reduce_motion_default": true
  }
}
