{
  "$schema": "https://decantr.ai/schemas/style-metadata.v1.json",
  "id": "terminal",
  "name": "Terminal",
  "description": "Pure terminal aesthetic with CRT-inspired phosphor green/amber on black. Monospace only, ASCII borders, optional scanline effects. Dark mode only.",
  "tags": [
    "dark",
    "terminal",
    "retro",
    "developer",
    "monospace",
    "cli"
  ],
  "personality": "retro + technical + focused + immersive",
  "seed": {
    "primary": "#00FF00",
    "secondary": "#FFB000",
    "accent": "#00FFFF",
    "background": "#000000"
  },
  "palette": {
    "background": {
      "dark": "#000000"
    },
    "surface": {
      "dark": "#0A0A0A"
    },
    "surface-raised": {
      "dark": "#111111"
    },
    "border": {
      "dark": "#333333"
    },
    "text": {
      "dark": "#00FF00"
    },
    "text-muted": {
      "dark": "#00AA00"
    },
    "primary": {
      "dark": "#00FF00"
    },
    "primary-hover": {
      "dark": "#00CC00"
    },
    "secondary": {
      "dark": "#FFB000"
    },
    "secondary-hover": {
      "dark": "#CC8C00"
    },
    "accent": {
      "dark": "#00FFFF"
    },
    "accent-hover": {
      "dark": "#00CCCC"
    }
  },
  "modes": [
    "dark"
  ],
  "shapes": [
    "sharp"
  ],
  "cvd_support": [],
  "tokens": {
    "base": {
      "success": "#00FF00",
      "danger": "#FF0000",
      "warning": "#FFB000",
      "info": "#00FFFF"
    }
  },
  "typography": {
    "font_family": "'JetBrains Mono', 'Fira Code', 'Source Code Pro', 'Consolas', monospace",
    "font_family_heading": "'JetBrains Mono', 'Fira Code', 'Source Code Pro', 'Consolas', monospace",
    "base_size": "14px",
    "scale": 1.2,
    "weights": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "decantr_compat": ">=1.0.0",
  "source": "core"
}
