{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "expense-tracker",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Expense Tracker",
  "description": "Property expense management with category breakdown, receipt upload, recurring expenses, and budget tracking.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select"
      ],
      "charts": [
        "PieChart"
      ]
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Input",
    "Select"
  ],
  "default_preset": "list",
  "presets": {
    "list": {
      "description": "Expense list view",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title, add expense, export",
          "filters": "Property, category, date range, vendor",
          "summary": "Category totals chart",
          "table": "Expense records"
        }
      }
    },
    "create": {
      "description": "Add expense form",
      "components": [
        "Button",
        "icon",
        "Input",
        "Select",
        "Textarea"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4 _p6",
        "slots": {
          "form": "Expense form fields",
          "receipt": "Receipt upload",
          "actions": "Save/cancel"
        }
      }
    },
    "summary": {
      "description": "Category summary with chart",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4 _p4",
        "slots": {
          "chart": "Category pie chart",
          "legend": "Category breakdown"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "header": "Title and controls",
      "filters": "Filters",
      "summary": "Category totals",
      "table": "Expense records"
    }
  }
}
