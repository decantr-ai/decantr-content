{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "page-tree",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Page Tree",
  "description": "Hierarchical page navigation with drag-and-drop reordering, inline rename, and nested page support. Used in workspace sidebars.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Input",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Input",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full tree with icons, expand/collapse, and context menus",
      "components": [
        "Button",
        "Input",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap0.5",
        "slots": {
          "search": "Filter pages by name",
          "favorites": "Pinned pages section",
          "tree": "Nested page items",
          "new-button": "Create new page button"
        }
      }
    },
    "compact": {
      "description": "Dense tree with smaller text",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap0",
        "slots": {
          "tree": "Dense nested page items"
        }
      }
    },
    "flat": {
      "description": "Single-level page list without hierarchy",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap1",
        "slots": {
          "search": "Filter input",
          "pages": "Flat page list"
        }
      }
    }
  },
  "default_layout": {
    "layout": "column",
    "atoms": "_flex _col _gap0.5",
    "slots": {
      "search": "Filter pages by name",
      "favorites": "Pinned/favorite pages section",
      "tree": "Nested page items with expand/collapse",
      "item-actions": "Per-item context menu (rename, delete, duplicate)",
      "new-button": "Create new page button"
    }
  },
  "io": {
    "consumes": [
      "pages",
      "currentPageId",
      "favorites"
    ],
    "produces": [
      "page-select",
      "page-reorder"
    ],
    "actions": [
      "new-page",
      "rename-page",
      "delete-page",
      "duplicate-page",
      "reorder",
      "toggle-favorite"
    ]
  }
}
