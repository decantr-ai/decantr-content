{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "ascii-chart",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "ASCII Chart",
  "description": "ASCII and braille character-based charts for terminal-style data visualization.",
  "dependencies": {
    "patterns": {},
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [],
      "charts": []
    }
  },
  "components": [],
  "default_preset": "line",
  "presets": {
    "line": {
      "description": "ASCII line chart with axes",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen",
        "slots": {
          "title": "Chart title",
          "chart": "ASCII line visualization",
          "legend": "Series legend",
          "axes": "X/Y axis labels"
        }
      }
    },
    "bar": {
      "description": "Horizontal ASCII bar chart",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen",
        "slots": {
          "title": "Chart title",
          "bars": "Horizontal bar entries",
          "legend": "Color/pattern legend"
        }
      }
    },
    "sparkline": {
      "description": "Inline sparkline using braille characters",
      "components": [],
      "layout": {
        "layout": "inline",
        "atoms": "_inline _mono _fggreen",
        "slots": {
          "sparkline": "Braille character visualization"
        }
      }
    },
    "braille": {
      "description": "High-resolution braille dot matrix chart",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen",
        "slots": {
          "title": "Chart title",
          "chart": "Braille dot visualization",
          "axes": "Axis labels"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _mono _fggreen",
    "slots": {
      "title": "Chart title",
      "chart": "ASCII visualization",
      "legend": "Color/symbol legend",
      "axes": "X/Y axis labels"
    }
  },
  "features": [
    "realtime-updates",
    "multiple-series",
    "configurable-dimensions",
    "time-based-axis",
    "value-labels"
  ],
  "character_sets": {
    "blocks": [
      "█",
      "▓",
      "▒",
      "░",
      " "
    ],
    "braille": "U+2800 to U+28FF",
    "lines": [
      "_",
      ".",
      "-",
      "~",
      "^",
      "*",
      "|"
    ]
  },
  "visual_brief": "Monospace terminal-style chart rendered entirely with ASCII and braille characters on a dark or transparent background. Green-on-dark color scheme by default. Line preset draws axes with pipe and dash characters, data points with dots and asterisks connected by line-drawing characters. Bar preset renders horizontal bars using block characters (full, three-quarter, half, quarter fills). Sparkline preset is a single inline row of braille dots. All presets include a chart title at top and axis labels along edges.",
  "responsive": {
    "mobile": "Chart width scales to container. Character count per row reduces. Sparkline preset preferred for inline metrics. Legend moves below chart.",
    "tablet": "Standard chart dimensions. Side legend if space allows.",
    "desktop": "Full-width charts with generous character grids. Legend renders beside the chart area."
  }
}
