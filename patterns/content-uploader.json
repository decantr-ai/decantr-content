{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "content-uploader",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Content Uploader",
  "description": "Drag-drop media upload component with file preview, progress tracking, and multi-file support. Handles images, videos, audio, and documents.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Progress",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Progress",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Multi-file upload with preview grid and progress tracking",
      "components": [
        "Button",
        "Card",
        "Progress",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "dropzone": "Drag-drop target area with visual feedback",
          "file-list": "Uploaded files with progress bars",
          "preview": "Media preview thumbnails grid",
          "actions": "Upload, cancel, clear buttons"
        }
      }
    },
    "single": {
      "description": "Single file upload with large preview area",
      "components": [
        "Button",
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "dropzone": "Large drag-drop target",
          "preview": "Full-size media preview",
          "actions": "Replace, remove buttons"
        }
      }
    },
    "audio": {
      "description": "Audio upload with waveform preview",
      "components": [
        "Button",
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "dropzone": "Audio file drop area",
          "waveform": "Audio waveform visualization",
          "player": "Audio player controls",
          "actions": "Upload actions"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "dropzone": "Drag-drop target area",
      "file-list": "Uploaded files list",
      "preview": "Media preview",
      "actions": "Action buttons"
    }
  },
  "io": {
    "produces": [
      "uploaded-files",
      "upload-progress"
    ],
    "consumes": []
  }
}
