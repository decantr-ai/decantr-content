{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "chat-input",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Chat Input",
  "description": "Message composition area with auto-growing textarea, file attachments, mentions autocomplete, and keyboard shortcuts.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Auto-expanding textarea with attach and send buttons",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap2 _p4 _borderT _bgbg",
        "slots": {
          "attachments-preview": "Staged file thumbnails with remove buttons",
          "textarea": "Auto-growing input with placeholder",
          "actions": "Attach and send buttons"
        }
      }
    },
    "rich": {
      "description": "Full-featured input with formatting toolbar",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap2 _p4 _borderT _bgbg",
        "slots": {
          "toolbar": "Formatting buttons (bold, italic, code, link)",
          "attachments-preview": "Staged file thumbnails",
          "mentions-popup": "@mention autocomplete dropdown",
          "textarea": "Rich text input area",
          "actions": "Attach and send buttons",
          "counter": "Character/token count display"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap2 _p4 _borderT _bgbg",
    "slots": {
      "attachments-preview": "Staged file thumbnails with remove buttons",
      "mentions-popup": "@mention autocomplete dropdown",
      "textarea": "Auto-growing input with placeholder",
      "actions": "Attach and send buttons"
    }
  }
}
