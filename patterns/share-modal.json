{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "share-modal",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Share Modal",
  "description": "Invite collaborators and manage document sharing. Includes email invite, shareable link, and current collaborators management.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Input",
        "Select",
        "Avatar",
        "Tabs",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Input",
    "Select",
    "Avatar",
    "Tabs",
    "icon"
  ],
  "default_preset": "invite",
  "presets": {
    "invite": {
      "description": "Email invite form with role selector",
      "components": [
        "Button",
        "Input",
        "Select",
        "icon"
      ],
      "layout": {
        "layout": "modal",
        "atoms": "_flex _col _gap4 _p6 _w[480px]",
        "slots": {
          "header": "Modal title and close button",
          "invite-form": "Email input with role selector",
          "send-button": "Send invitation button"
        }
      }
    },
    "link": {
      "description": "Shareable link management",
      "components": [
        "Button",
        "Input",
        "Select",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap4",
        "slots": {
          "link-display": "Shareable URL with copy button",
          "link-settings": "Permission level for link access",
          "toggle": "Enable/disable link sharing"
        }
      }
    },
    "members": {
      "description": "Current collaborators list with role management",
      "components": [
        "Avatar",
        "Button",
        "Select",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap2",
        "slots": {
          "members-list": "List of current collaborators with roles",
          "pending": "Pending invitations"
        }
      }
    }
  },
  "default_layout": {
    "layout": "modal",
    "atoms": "_flex _col _gap4 _p6 _w[480px]",
    "slots": {
      "tabs": "Invite / Link / Members navigation",
      "invite-form": "Email input with role selector and autocomplete",
      "link-settings": "Shareable link toggle and permissions",
      "members-list": "Current collaborators with role management",
      "pending": "Pending invitations list"
    }
  },
  "io": {
    "consumes": [
      "document",
      "members",
      "pending",
      "suggestions"
    ],
    "produces": [
      "invite",
      "role-change",
      "remove-member"
    ],
    "actions": [
      "send-invite",
      "cancel-invite",
      "change-role",
      "remove-member",
      "toggle-link",
      "copy-link"
    ]
  }
}
