{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "mention-popup",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Mention Popup",
  "description": "@mention autocomplete for collaborators. Triggered by @ character with type-ahead filtering and keyboard navigation.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Avatar",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Avatar",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "List with avatars, names, and online status",
      "components": [
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "dropdown",
        "atoms": "_absolute _bg[var(--surface)] _shadow _r2 _border _w[280px] _max-h[300px] _overflow[auto] _z[100]",
        "slots": {
          "search": "Type-ahead filter (inline in editor)",
          "recent": "Recently mentioned users section",
          "results": "Filtered collaborator list"
        }
      }
    },
    "compact": {
      "description": "Names only without status indicators",
      "components": [
        "Avatar"
      ],
      "layout": {
        "layout": "dropdown",
        "atoms": "_absolute _bg[var(--surface)] _shadow _r1 _border _w[200px] _z[100]",
        "slots": {
          "results": "Simple user list"
        }
      }
    }
  },
  "default_layout": {
    "layout": "dropdown",
    "atoms": "_absolute _bg[var(--surface)] _shadow _r2 _border _w[280px] _z[100]",
    "slots": {
      "search": "Type-ahead filter input",
      "recent": "Recently mentioned users for quick access",
      "results": "Filtered list of matching collaborators"
    }
  },
  "io": {
    "consumes": [
      "collaborators",
      "query",
      "position",
      "recentMentions"
    ],
    "produces": [
      "select"
    ],
    "actions": [
      "select-user",
      "close"
    ]
  }
}
