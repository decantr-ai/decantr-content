{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "property-grid",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Property Grid",
  "description": "Dashboard grid of all properties with filtering, search, view toggles, and portfolio summary.",
  "dependencies": {
    "patterns": {
      "property-card": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Input",
        "Select",
        "Tabs"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Input",
    "Select",
    "Tabs"
  ],
  "default_preset": "cards",
  "presets": {
    "cards": {
      "description": "Card grid layout with property cards",
      "components": [
        "Button",
        "icon",
        "Input",
        "Select"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "header": "Title, add property button, view toggle",
          "summary": "Portfolio summary metrics",
          "filters": "Property type, status, location filters",
          "search": "Property search input",
          "grid": "Property cards grid",
          "pagination": "Page controls"
        }
      }
    },
    "table": {
      "description": "Table layout with sortable columns",
      "components": [
        "Button",
        "icon",
        "Input"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title and controls",
          "filters": "Filter controls",
          "table": "Property table with columns",
          "pagination": "Table pagination"
        }
      }
    },
    "map": {
      "description": "Map view with property pins",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "split",
        "atoms": "_flex _h[calc(100vh-200px)]",
        "slots": {
          "sidebar": "Property list sidebar",
          "map": "Interactive map with pins"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "header": "Page header with controls",
      "summary": "Portfolio metrics",
      "filters": "Search and filters",
      "items": "Property cards or rows",
      "pagination": "Page controls"
    }
  }
}
