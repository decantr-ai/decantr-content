{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "content-feed",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Content Feed",
  "description": "Exclusive content feed with posts, media players, comments, and tier-gated content. Infinite scroll support.",
  "dependencies": {
    "patterns": {
      "unlock-gate": "^1.0.0"
    },
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Badge",
        "Avatar",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Badge",
    "Avatar",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Chronological feed with media",
      "components": [
        "Button",
        "Card",
        "Badge",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _maxw[720px] _mx[auto]",
        "slots": {
          "filters": "Type, tier filter buttons",
          "items": "Content posts",
          "load-more": "Infinite scroll trigger"
        }
      }
    },
    "grid": {
      "description": "Grid layout for visual content",
      "components": [
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc2 _md:gc3 _gap4",
        "slots": {
          "items": "Content cards in grid"
        }
      }
    },
    "compact": {
      "description": "Dense list view",
      "components": [
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap2",
        "slots": {
          "items": "Compact post rows"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "filters": "Content filters",
      "items": "Post feed",
      "load-more": "Pagination"
    }
  },
  "io": {
    "produces": [
      "post-click",
      "unlock-click",
      "like-click"
    ],
    "consumes": [
      "post-data",
      "creator-data",
      "user-tier"
    ]
  }
}
