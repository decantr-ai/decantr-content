{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "rent-reminder",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Rent Reminder",
  "description": "Payment reminder notification with contextual styling for upcoming, due today, and overdue states. Includes one-click payment action.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge"
  ],
  "default_preset": "upcoming",
  "presets": {
    "upcoming": {
      "description": "Upcoming payment reminder",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap4 _p4 _r2 _bgPrimary/10",
        "slots": {
          "icon": "Calendar icon",
          "title": "Reminder headline",
          "amount": "Amount due",
          "due-date": "Due date",
          "action": "Pay now button"
        }
      }
    },
    "due-today": {
      "description": "Due today alert",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap4 _p4 _r2 _bgWarning/10",
        "slots": {
          "icon": "Alert icon",
          "title": "Due today message",
          "amount": "Amount due",
          "action": "Pay now button"
        }
      }
    },
    "overdue": {
      "description": "Overdue payment warning",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap4 _p4 _r2 _bgDanger/10",
        "slots": {
          "icon": "Warning icon",
          "title": "Overdue message",
          "amount": "Amount with late fee",
          "days-overdue": "Days overdue",
          "action": "Pay now button"
        }
      }
    },
    "paid": {
      "description": "Payment confirmed",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap4 _p4 _r2 _bgSuccess/10",
        "slots": {
          "icon": "Check icon",
          "title": "Paid confirmation",
          "amount": "Amount paid",
          "date": "Payment date"
        }
      }
    }
  },
  "default_layout": {
    "layout": "row",
    "atoms": "_flex _aic _gap4 _p4 _r2",
    "slots": {
      "icon": "Status icon",
      "content": "Message and details",
      "amount": "Amount",
      "action": "Action button"
    }
  }
}
