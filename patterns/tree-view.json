{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "tree-view",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Tree View",
  "description": "File/data tree with ASCII connectors for hierarchical navigation.",
  "dependencies": {
    "patterns": {},
    "recipes": {
      "terminal": "^1.0.0"
    },
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Expandable tree with ASCII connectors",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen _overflow[auto]",
        "slots": {
          "root": "Tree root node",
          "nodes": "Child tree nodes"
        }
      }
    },
    "flat": {
      "description": "Indented list without connectors",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen",
        "slots": {
          "items": "Indented list items"
        }
      }
    },
    "checkbox": {
      "description": "Tree with selection checkboxes",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen",
        "slots": {
          "nodes": "Tree nodes with checkboxes"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _mono _fggreen",
    "slots": {
      "root": "Tree root",
      "nodes": "Tree nodes"
    }
  },
  "features": [
    "expand-collapse",
    "multi-select",
    "drag-drop",
    "context-menu",
    "search-filter",
    "keyboard-navigation"
  ],
  "keyboard_shortcuts": {
    "ArrowUp": "Previous node",
    "ArrowDown": "Next node",
    "ArrowLeft": "Collapse or go to parent",
    "ArrowRight": "Expand or go to first child",
    "Enter": "Select node",
    "Space": "Toggle checkbox"
  },
  "ascii_connectors": {
    "branch": "├── ",
    "last": "└── ",
    "vertical": "│   ",
    "empty": "    "
  }
}
