{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "rent-roll",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Rent Roll",
  "description": "Monthly rent summary with all units showing expected rent, collected, outstanding, and vacancy loss. Calculates totals.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Select"
      ],
      "charts": [
        "AreaChart"
      ]
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Select"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full rent roll with summary and table",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Select"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "header": "Month selector, export button",
          "summary": "Expected rent, collected, outstanding, vacancy loss cards",
          "table": "All units with rent status",
          "totals": "Grand totals row",
          "trends": "Collection rate trend chart"
        }
      }
    },
    "summary": {
      "description": "Compact rent roll summary for dashboard",
      "components": [
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap3 _p4",
        "slots": {
          "header": "Title",
          "metrics": "Collected, outstanding",
          "progress": "Collection progress bar"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "header": "Title and controls",
      "summary": "Summary metrics",
      "table": "Rent roll table",
      "totals": "Totals row"
    }
  }
}
