{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "version-history",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Version History",
  "description": "Document revision timeline with version preview, diff view, and restore functionality. Shows auto-saves and named checkpoints.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Avatar",
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Avatar",
    "Button",
    "icon"
  ],
  "default_preset": "sidebar",
  "presets": {
    "sidebar": {
      "description": "Vertical timeline in aside panel",
      "components": [
        "Avatar",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _hfull",
        "slots": {
          "header": "Panel header with close button",
          "timeline": "Chronological version list",
          "actions": "Restore and compare buttons"
        }
      }
    },
    "modal": {
      "description": "Full-screen history viewer with preview pane",
      "components": [
        "Avatar",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "split",
        "atoms": "_grid _grid-cols[300px_1fr] _h[80vh]",
        "slots": {
          "timeline": "Left pane with version list",
          "preview": "Right pane with version content",
          "diff-toggle": "Switch between content and diff view",
          "actions": "Restore and download buttons"
        }
      }
    },
    "compact": {
      "description": "Dropdown version selector",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "dropdown",
        "atoms": "_relative",
        "slots": {
          "trigger": "Current version display with dropdown arrow",
          "menu": "Version list dropdown"
        }
      }
    }
  },
  "default_layout": {
    "layout": "column",
    "atoms": "_flex _col",
    "slots": {
      "timeline": "Chronological version list grouped by date",
      "preview": "Selected version content view",
      "compare": "Diff view toggle between versions",
      "restore": "Restore to selected version button"
    }
  },
  "io": {
    "consumes": [
      "versions",
      "currentVersionId"
    ],
    "produces": [
      "version-select",
      "restore"
    ],
    "actions": [
      "select-version",
      "restore-version",
      "create-checkpoint",
      "download-version",
      "compare-versions"
    ]
  }
}
