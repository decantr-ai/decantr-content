{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "creator-profile",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Creator Profile",
  "description": "Public creator page layout with hero, tiers, content feed, and about section. Tab-based navigation.",
  "dependencies": {
    "patterns": {
      "storefront-hero": "^1.0.0",
      "tier-card": "^1.0.0",
      "content-feed": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Tabs",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Tabs",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full profile page with tabs",
      "components": [
        "Button",
        "Card",
        "Tabs",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col",
        "slots": {
          "hero": "Storefront hero pattern",
          "tabs": "Posts, About, Tiers navigation",
          "content": "Tab content area",
          "tiers-sidebar": "Optional tier cards sidebar"
        }
      }
    },
    "embed": {
      "description": "Embeddable widget version",
      "components": [
        "Button",
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "card",
        "atoms": "studio-card _p4 _flex _gap4",
        "slots": {
          "avatar": "Small avatar",
          "info": "Name, subscribers",
          "cta": "Subscribe button"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col",
    "slots": {
      "hero": "Profile hero",
      "tabs": "Navigation tabs",
      "content": "Tab content"
    }
  },
  "io": {
    "produces": [
      "subscribe-click",
      "tab-changed"
    ],
    "consumes": [
      "creator-data",
      "tier-data",
      "post-data"
    ]
  }
}
