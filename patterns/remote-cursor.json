{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "remote-cursor",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Remote Cursor",
  "description": "Real-time cursor indicator for collaborators with name label and smooth interpolation. Shows where other users are editing.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [],
      "charts": []
    }
  },
  "components": [],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Cursor with name label positioned below",
      "components": [],
      "layout": {
        "layout": "absolute",
        "atoms": "_absolute _pointer[none] _z[100]",
        "slots": {
          "cursor": "SVG cursor icon in user's presence color",
          "label": "Name tag with colored background"
        }
      }
    },
    "minimal": {
      "description": "Cursor only without name label",
      "components": [],
      "layout": {
        "layout": "absolute",
        "atoms": "_absolute _pointer[none] _z[100]",
        "slots": {
          "cursor": "SVG cursor icon only"
        }
      }
    },
    "extended": {
      "description": "Cursor with avatar thumbnail",
      "components": [
        "Avatar"
      ],
      "layout": {
        "layout": "absolute",
        "atoms": "_absolute _pointer[none] _z[100]",
        "slots": {
          "cursor": "SVG cursor icon",
          "avatar": "Small avatar image",
          "label": "Name on hover"
        }
      }
    }
  },
  "default_layout": {
    "layout": "absolute",
    "atoms": "_absolute _pointer[none] _z[100]",
    "slots": {
      "cursor": "SVG cursor icon in user's presence color",
      "label": "Name tag with colored background",
      "caret": "Optional text caret for typing position"
    }
  },
  "io": {
    "consumes": [
      "user",
      "position"
    ],
    "produces": [],
    "actions": []
  }
}
