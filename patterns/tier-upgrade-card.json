{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "tier-upgrade-card",
  "version": "1.0.0",
  "decantr_compat": ">=0.9.0",
  "name": "Tier Upgrade Card",
  "description": "Pricing tier card with plan name, price, feature list, and upgrade CTA button. Used in billing portal and landing page pricing sections.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Card",
        "Badge",
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "contained": false,
  "components": [
    "Card",
    "CardHeader",
    "CardBody",
    "CardFooter",
    "Badge",
    "Button",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Pricing card with plan name, monthly price, feature checklist, and upgrade button. Vertical stack layout.",
      "components": [
        "Card",
        "CardHeader",
        "CardBody",
        "CardFooter",
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap0 _border _bordermuted/20 _r4 _overflow[hidden]",
        "slots": {
          "header": "Plan name with _heading4 and optional 'Popular' Badge",
          "price": "Monthly price with large _heading2 number and /mo suffix",
          "description": "One-line plan description with _bodysm _fgmuted",
          "features": "Checklist of included features, each with check icon",
          "cta": "Upgrade/downgrade Button, full-width in CardFooter"
        }
      }
    },
    "highlighted": {
      "description": "Featured/recommended tier card with primary border, gradient background accent, and prominent CTA.",
      "components": [
        "Card",
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap0 _border2 _borderprimary _r4 _overflow[hidden] _relative",
        "slots": {
          "highlight-bar": "Top gradient accent bar",
          "badge": "Recommended/Popular Badge at top",
          "header": "Plan name and price",
          "features": "Feature checklist with check icons",
          "cta": "Primary CTA with aura-glow effect"
        }
      }
    },
    "horizontal": {
      "description": "Horizontal tier comparison row for compact billing views. Plan info on left, features in middle, CTA on right.",
      "components": [
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap6 _px6 _py4 _borderb _bordermuted/10",
        "slots": {
          "plan-info": "Plan name, price, and description stacked on left",
          "features": "Key features as horizontal Badge list",
          "cta": "Upgrade Button on right"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap0 _border _bordermuted/20 _r4",
    "slots": {
      "header": "Plan name and badge",
      "price": "Monthly price",
      "description": "Plan description",
      "features": "Feature checklist",
      "cta": "Upgrade button"
    }
  }
}
