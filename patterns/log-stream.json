{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "log-stream",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Log Stream",
  "description": "Real-time log streaming display with filtering, search, and auto-scroll behavior.",
  "dependencies": {
    "patterns": {},
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Continuous log stream with auto-scroll",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _mono _bgblack _fggreen",
        "slots": {
          "header": "Pause/play controls and stats",
          "stream": "Scrolling log entries",
          "stats": "Error/warn/info counts"
        }
      }
    },
    "filtered": {
      "description": "Log stream with level filter controls",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _mono _bgblack _fggreen",
        "slots": {
          "header": "Filter controls by log level",
          "search": "Search/filter input",
          "stream": "Filtered log entries",
          "stats": "Count per level"
        }
      }
    },
    "grouped": {
      "description": "Logs grouped by source or timestamp",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _mono _bgblack _fggreen",
        "slots": {
          "groups": "Collapsible log groups",
          "group-header": "Group label with count",
          "group-entries": "Log entries within group"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _hfull _mono _bgblack _fggreen",
    "slots": {
      "header": "Controls and stats",
      "stream": "Log entries",
      "search": "Search input"
    }
  },
  "features": [
    "auto-scroll",
    "pause-on-hover",
    "level-filtering",
    "search-highlight",
    "timestamp-format",
    "source-labels",
    "copy-entry",
    "export-logs"
  ],
  "log_levels": {
    "DEBUG": {
      "color": "#666666",
      "priority": 0
    },
    "INFO": {
      "color": "#00FF00",
      "priority": 1
    },
    "WARN": {
      "color": "#FFB000",
      "priority": 2
    },
    "ERROR": {
      "color": "#FF0000",
      "priority": 3
    }
  }
}
