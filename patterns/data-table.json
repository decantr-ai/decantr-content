{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "data-table",
  "version": "1.0.0",
  "decantr_compat": ">=0.9.0",
  "name": "Data Table",
  "description": "Sortable, filterable, paginated data table with row selection",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Table",
        "Checkbox",
        "Button",
        "Input",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Table",
    "Checkbox",
    "Button",
    "Input",
    "Badge",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full-featured table with column headers, sortable columns, row selection checkboxes, pagination footer",
      "components": [
        "Table",
        "Checkbox",
        "Button",
        "Input",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap4 _w[100%] _overflow[auto]",
        "slots": {
          "toolbar": "Top row with optional search Input and action Buttons",
          "table-header": "Column headers with sort controls",
          "table-body": "Data rows with optional row selection Checkbox",
          "pagination": "Footer with page info and prev/next Buttons"
        }
      }
    },
    "compact": {
      "description": "Denser rows, no selection, simpler pagination (prev/next only)",
      "components": [
        "Table",
        "Button",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap2 _w[100%] _overflow[auto]",
        "slots": {
          "table-header": "Column headers without sort controls",
          "table-body": "Dense data rows without selection",
          "pagination": "Simple prev/next footer"
        }
      }
    }
  },
  "default_layout": {
    "layout": "column",
    "atoms": "_flex _col _gap4 _w[100%] _overflow[auto]",
    "slots": {
      "toolbar": "Top row with optional search Input and action Buttons",
      "table-header": "Column headers with sort controls",
      "table-body": "Data rows with optional row selection Checkbox",
      "pagination": "Footer with page info and prev/next Buttons"
    }
  },
  "io": {
    "consumes": [
      "search",
      "filters",
      "data"
    ],
    "produces": [
      "selection",
      "sort"
    ],
    "actions": [
      "export",
      "delete",
      "edit"
    ]
  }
}
