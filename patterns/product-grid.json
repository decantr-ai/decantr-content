{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "product-grid",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Product Grid",
  "description": "Purchasable items/posts grid with filtering, sorting, and multiple view modes. Used for creator content libraries.",
  "dependencies": {
    "patterns": {
      "product-card": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Select",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Select",
    "Badge",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Card grid with filters and sorting",
      "components": [
        "Button",
        "Card",
        "Select",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "filters": "Category, price, type filters",
          "sort": "Sort controls",
          "view-toggle": "Grid/list view toggle",
          "items": "Product cards grid",
          "load-more": "Pagination/infinite scroll"
        }
      }
    },
    "list": {
      "description": "Horizontal list view",
      "components": [
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap3",
        "slots": {
          "items": "Product list items"
        }
      }
    },
    "masonry": {
      "description": "Pinterest-style masonry layout",
      "components": [
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "masonry",
        "atoms": "_columns2 _md:columns3 _gap4",
        "slots": {
          "items": "Variable-height product cards"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "filters": "Filter controls",
      "items": "Product grid",
      "pagination": "Load more"
    }
  },
  "io": {
    "produces": [
      "product-click",
      "filter-changed"
    ],
    "consumes": [
      "product-data",
      "category-data"
    ]
  }
}
