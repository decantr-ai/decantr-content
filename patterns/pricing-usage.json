{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "pricing-usage",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Pricing Usage",
  "description": "Usage-based pricing section with volume tiers, calculator, feature comparison table, and FAQ accordion.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Badge",
        "Card",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Badge",
    "Card",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full pricing section with tiers, calculator, and comparison",
      "components": [
        "Button",
        "Badge",
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap12 _py16 _px6",
        "slots": {
          "toggle": "Monthly/annual billing toggle",
          "tiers": "Volume tier pricing cards",
          "calculator": "Usage estimator slider/input",
          "comparison": "Feature comparison table",
          "faq": "Frequently asked questions accordion"
        }
      }
    },
    "compact": {
      "description": "Simplified pricing cards without calculator",
      "components": [
        "Button",
        "Badge",
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap8 _py12 _px6",
        "slots": {
          "toggle": "Monthly/annual toggle",
          "tiers": "Pricing tier cards"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap12 _py16 _px6",
    "slots": {
      "toggle": "Monthly/annual billing toggle",
      "tiers": "Volume tier pricing cards",
      "calculator": "Usage estimator",
      "comparison": "Feature comparison table",
      "faq": "FAQ accordion"
    }
  }
}
