{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "terminal-emulator",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Terminal Emulator",
  "description": "Interactive terminal input/output area with command history, tab completion, and ANSI color support.",
  "dependencies": {
    "patterns": {},
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Scrollable output with input line and command prompt",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _mono _bgblack _fggreen",
        "slots": {
          "output": "Scrollable command output with ANSI color support",
          "input": "Command input with $ prompt and blinking cursor",
          "history": "Command history accessible via up/down arrows"
        }
      }
    },
    "readonly": {
      "description": "Output only display, no input capability",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _mono _bgblack _fggreen",
        "slots": {
          "output": "Scrollable read-only output display"
        }
      }
    },
    "split": {
      "description": "Input and output in separate panes",
      "components": [],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _hfull _mono _bgblack _fggreen",
        "slots": {
          "output": "Top pane for command output",
          "input": "Bottom pane for command input"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _hfull _mono _bgblack _fggreen",
    "slots": {
      "output": "Scrollable command output with ANSI color support",
      "input": "Command input with prompt and cursor",
      "history": "Command history navigation"
    }
  },
  "features": [
    "command-history",
    "tab-completion",
    "ansi-colors",
    "copy-paste",
    "clear-screen",
    "search-history"
  ],
  "keyboard_shortcuts": {
    "Enter": "Execute command",
    "ArrowUp": "Previous command in history",
    "ArrowDown": "Next command in history",
    "Ctrl+L": "Clear screen",
    "Ctrl+R": "Search history",
    "Tab": "Autocomplete"
  }
}
