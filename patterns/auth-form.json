{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "auth-form",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Auth Form",
  "description": "Unified authentication form with multiple modes: login, register, forgot-password, reset-password, verify-email, mfa-setup, mfa-verify, phone-verify.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon"
  ],
  "default_preset": "login",
  "presets": {
    "login": {
      "description": "Email/password login with OAuth options",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _p8 _maxw[400px] _wfull",
        "slots": {
          "header": "Logo and welcome title",
          "form": "Email and password inputs",
          "oauth": "Social login buttons (Google, GitHub, etc.)",
          "divider": "'or continue with' separator",
          "footer": "Register and forgot password links",
          "error": "Inline error message area"
        }
      }
    },
    "register": {
      "description": "Registration form with password strength indicator",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _p8 _maxw[400px] _wfull",
        "slots": {
          "header": "Logo and create account title",
          "form": "Name, email, password inputs with strength indicator",
          "oauth": "Social signup buttons",
          "divider": "Separator",
          "footer": "Login link",
          "error": "Inline error message"
        }
      }
    },
    "forgot-password": {
      "description": "Password reset request form",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _p8 _maxw[400px] _wfull",
        "slots": {
          "header": "Title and instructions",
          "form": "Email input",
          "footer": "Back to login link",
          "success": "Success message after submission"
        }
      }
    },
    "reset-password": {
      "description": "Set new password form with confirmation",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _p8 _maxw[400px] _wfull",
        "slots": {
          "header": "Title",
          "form": "New password and confirm password inputs",
          "error": "Validation errors"
        }
      }
    },
    "verify-email": {
      "description": "Email verification pending screen",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _aic _gap6 _p8 _tc",
        "slots": {
          "icon": "Mail icon",
          "message": "Verification instructions",
          "resend": "Resend verification button"
        }
      }
    },
    "mfa-setup": {
      "description": "Multi-factor authentication setup with QR code",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _p8 _maxw[400px] _wfull",
        "slots": {
          "header": "Setup instructions",
          "qr": "QR code image for authenticator app",
          "secret": "Manual entry secret key",
          "verify": "Verification code input"
        }
      }
    },
    "mfa-verify": {
      "description": "MFA code entry during login",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _p8 _maxw[400px] _wfull",
        "slots": {
          "header": "Enter code prompt",
          "form": "6-digit code input",
          "backup": "Use backup code link"
        }
      }
    },
    "phone-verify": {
      "description": "Phone number verification with SMS code",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _p8 _maxw[400px] _wfull",
        "slots": {
          "header": "Verification prompt",
          "form": "SMS code input",
          "resend": "Resend code button"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6 _p8 _maxw[400px] _wfull",
    "slots": {
      "header": "Logo, title, subtitle",
      "form": "Form inputs",
      "oauth": "OAuth provider buttons",
      "divider": "'or continue with' separator",
      "footer": "Navigation links",
      "error": "Inline error messages"
    }
  }
}
