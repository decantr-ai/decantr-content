{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "legal-prose",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Legal Prose",
  "description": "Styled legal documents with auto-generated TOC, smooth scroll navigation, collapsible sections, and print-friendly layout.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon"
  ],
  "default_preset": "privacy",
  "presets": {
    "privacy": {
      "description": "Privacy policy document layout",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_grid _gc1 _lg:gc[1fr_280px] _gap8 _py12 _px6 _maxw[1200px] _mx[auto]",
        "slots": {
          "header": "Title and last updated date",
          "toc": "Sticky table of contents sidebar",
          "content": "Markdown prose content",
          "footer": "Contact info and version history"
        }
      }
    },
    "terms": {
      "description": "Terms of service document layout",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_grid _gc1 _lg:gc[1fr_280px] _gap8 _py12 _px6 _maxw[1200px] _mx[auto]",
        "slots": {
          "header": "Title, effective date, version",
          "toc": "Sticky table of contents",
          "content": "Legal prose with numbered sections",
          "footer": "Acceptance statement, contact"
        }
      }
    },
    "cookies": {
      "description": "Cookie policy with collapsible category sections",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap8 _py12 _px6 _maxw[800px] _mx[auto]",
        "slots": {
          "header": "Title and last updated",
          "intro": "Policy introduction",
          "categories": "Collapsible cookie category accordions",
          "footer": "Manage preferences link"
        }
      }
    }
  },
  "default_layout": {
    "layout": "row",
    "atoms": "_grid _gc1 _lg:gc[1fr_280px] _gap8 _py12 _px6 _maxw[1200px] _mx[auto]",
    "slots": {
      "header": "Title and last updated date",
      "toc": "Auto-generated sticky table of contents",
      "content": "Markdown prose content",
      "footer": "Contact, version history"
    }
  }
}
