{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "lease-manager",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Lease Manager",
  "description": "Lease document and term management including summary, editing, documents, amendments, and renewal workflow.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Input",
    "Select"
  ],
  "default_preset": "overview",
  "presets": {
    "overview": {
      "description": "Lease summary view with key terms",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Lease ID, status badge",
          "parties": "Tenant(s) and property owner",
          "terms": "Start/end dates, rent, deposit",
          "documents": "Uploaded lease documents",
          "actions": "Renew, terminate, amend buttons"
        }
      }
    },
    "edit": {
      "description": "Lease term editing form",
      "components": [
        "Button",
        "icon",
        "Input",
        "Select"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "form": "Lease term form fields",
          "documents": "Document upload",
          "actions": "Save/cancel"
        }
      }
    },
    "summary": {
      "description": "Compact lease summary for tenant portal",
      "components": [
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap2 _p4",
        "slots": {
          "dates": "Start and end dates",
          "rent": "Monthly rent amount",
          "status": "Lease status"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "header": "Lease header",
      "terms": "Lease terms",
      "documents": "Documents",
      "actions": "Actions"
    }
  }
}
