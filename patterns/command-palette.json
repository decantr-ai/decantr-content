{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "command-palette",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Command Palette",
  "description": "Cmd+K style command search overlay with fuzzy search, categories, and keyboard navigation.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full command palette with categories and recent commands",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_fixed _inset0 _flex _center _z[100] _bg[rgba(0,0,0,0.8)]",
        "slots": {
          "search": "Fuzzy search input",
          "results": "Command list with categories",
          "preview": "Optional command preview/help",
          "recent": "Recent commands section"
        }
      }
    },
    "minimal": {
      "description": "Simple search-only command palette",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_fixed _inset0 _flex _center _z[100] _bg[rgba(0,0,0,0.8)]",
        "slots": {
          "search": "Search input",
          "results": "Flat command list"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_fixed _inset0 _flex _center _z[100]",
    "slots": {
      "search": "Fuzzy search input",
      "results": "Command list",
      "preview": "Command preview"
    }
  },
  "features": [
    "fuzzy-search",
    "keyboard-navigation",
    "command-categories",
    "shortcut-hints",
    "recent-commands"
  ],
  "keyboard_shortcuts": {
    "Ctrl+K": "Open palette",
    "Cmd+K": "Open palette (Mac)",
    "Escape": "Close palette",
    "ArrowUp": "Previous command",
    "ArrowDown": "Next command",
    "Enter": "Execute command"
  }
}
