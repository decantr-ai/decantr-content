{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "subscriber-list",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Subscriber List",
  "description": "Fan/subscriber management table with filtering, search, sorting, and bulk actions. Export and messaging capabilities.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Input",
        "Badge",
        "Avatar",
        "Checkbox",
        "Select",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Input",
    "Badge",
    "Avatar",
    "Checkbox",
    "Select",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full data table with all subscriber info",
      "components": [
        "Button",
        "Card",
        "Input",
        "Badge",
        "Avatar",
        "Checkbox",
        "Select",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "filters": "Tier, date, status filters",
          "search": "Subscriber search input",
          "table": "Subscriber data rows",
          "pagination": "Page navigation controls",
          "bulk-actions": "Mass action buttons"
        }
      }
    },
    "compact": {
      "description": "Card grid view for mobile",
      "components": [
        "Card",
        "Avatar",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc1 _md:gc2 _gap4",
        "slots": {
          "cards": "Subscriber info cards"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "filters": "Filter controls",
      "table": "Subscriber table",
      "pagination": "Page controls"
    }
  },
  "io": {
    "produces": [
      "subscriber-selected",
      "export-triggered"
    ],
    "consumes": [
      "subscriber-data",
      "tier-data"
    ]
  }
}
