{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "earnings-dashboard",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Earnings Dashboard",
  "description": "Revenue analytics dashboard with KPIs, charts, tier breakdown, and recent transactions. Date range filtering and export capabilities.",
  "dependencies": {
    "patterns": {
      "kpi-grid": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Badge",
        "Select",
        "icon"
      ],
      "charts": [
        "LineChart",
        "BarChart",
        "PieChart"
      ]
    }
  },
  "components": [
    "Button",
    "Card",
    "Badge",
    "Select",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full analytics view with all charts and data",
      "components": [
        "Button",
        "Card",
        "Badge",
        "Select",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "kpis": "Revenue, MRR, subscribers, churn metrics",
          "revenue-chart": "Line/bar chart of revenue over time",
          "tier-breakdown": "Revenue by tier pie chart",
          "recent-transactions": "Latest payments table",
          "payout-status": "Next payout info card"
        }
      }
    },
    "summary": {
      "description": "Condensed KPI view for dashboard home",
      "components": [
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc2 _lg:gc4 _gap4",
        "slots": {
          "kpis": "Key metrics cards"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "kpis": "Key metrics",
      "charts": "Revenue charts",
      "transactions": "Recent payments"
    }
  },
  "io": {
    "produces": [
      "date-range-changed",
      "export-triggered"
    ],
    "consumes": [
      "earnings-data",
      "transaction-data"
    ]
  }
}
