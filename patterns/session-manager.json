{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "session-manager",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Session Manager",
  "description": "Active sessions panel showing current device, other sessions with device info, location, last active, and revoke controls.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Badge",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full session list with current device highlighted",
      "components": [
        "Button",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "current-session": "This device session card with 'Current' badge",
          "sessions-list": "Other active sessions list",
          "revoke-all": "Logout from all devices button"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "current-session": "This device with 'Current' badge",
      "sessions-list": "Other sessions with device, browser, location, last active",
      "revoke-all": "Sign out everywhere button"
    }
  }
}
