{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "diff-view",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Diff View",
  "description": "Side-by-side or unified diff display for code and text comparison.",
  "dependencies": {
    "patterns": {},
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon"
  ],
  "default_preset": "split",
  "presets": {
    "split": {
      "description": "Side-by-side diff view",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _hfull _mono _bgblack _fggreen",
        "slots": {
          "header": "File names, stats",
          "left": "Original content",
          "right": "Modified content",
          "gutter": "Line numbers, change markers"
        }
      }
    },
    "unified": {
      "description": "Unified diff format view",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _bgblack _fggreen",
        "slots": {
          "header": "Diff header with stats",
          "hunks": "Diff hunks with context"
        }
      }
    },
    "inline": {
      "description": "Inline word-level diff",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _bgblack _fggreen",
        "slots": {
          "content": "Mixed inline additions and deletions"
        }
      }
    }
  },
  "default_layout": {
    "layout": "grid",
    "atoms": "_grid _hfull _mono _bgblack _fggreen",
    "slots": {
      "header": "File names and stats",
      "left": "Original",
      "right": "Modified"
    }
  },
  "features": [
    "syntax-highlighting",
    "line-navigation",
    "copy-hunks",
    "expand-collapse",
    "jump-to-change"
  ],
  "keyboard_shortcuts": {
    "n": "Next change",
    "p": "Previous change",
    "e": "Expand all",
    "c": "Collapse all"
  }
}
