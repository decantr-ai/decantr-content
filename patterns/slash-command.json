{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "slash-command",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Slash Command",
  "description": "Block-type command palette triggered by / character. Provides quick access to insert different block types with keyboard navigation.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full command list with icons organized by category",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "dropdown",
        "atoms": "_absolute _bg[var(--surface)] _shadow _r2 _border _w[320px] _max-h[400px] _overflow[auto] _z[100]",
        "slots": {
          "search": "Command filter input",
          "categories": "Grouped command sections",
          "commands": "Individual command items"
        }
      }
    },
    "filtered": {
      "description": "Show only commands matching current filter",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "dropdown",
        "atoms": "_absolute _bg[var(--surface)] _shadow _r1 _border _w[280px] _z[100]",
        "slots": {
          "results": "Filtered command list only"
        }
      }
    }
  },
  "default_layout": {
    "layout": "dropdown",
    "atoms": "_absolute _bg[var(--surface)] _shadow _r2 _border _w[320px] _z[100]",
    "slots": {
      "search": "Command filter input (typically inline)",
      "categories": "Grouped command sections (Text, Lists, Media, Advanced)",
      "commands": "Individual command items with icon, name, description, shortcut"
    }
  },
  "io": {
    "consumes": [
      "position",
      "query"
    ],
    "produces": [
      "select"
    ],
    "actions": [
      "select-command",
      "close"
    ]
  }
}
