{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "unit-detail",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Unit Detail",
  "description": "Single unit details including specs, current tenant, lease info, rent history, maintenance, and documents.",
  "dependencies": {
    "patterns": {
      "tenant-card": "^1.0.0",
      "payment-history": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Tabs"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Tabs"
  ],
  "default_preset": "view",
  "presets": {
    "view": {
      "description": "Full unit detail view",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Tabs"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "header": "Unit number, property name, status badge, edit",
          "specs": "Beds, baths, sqft, floor, amenities",
          "tenant": "Current tenant info (embedded tenant-card)",
          "lease": "Current lease summary",
          "tabs": "Rent history, maintenance, documents tabs",
          "rent-history": "Payment history for this unit",
          "maintenance": "Maintenance history",
          "documents": "Unit-specific documents"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "header": "Unit header",
      "specs": "Unit specifications",
      "tenant": "Tenant information",
      "tabs": "History tabs"
    }
  }
}
