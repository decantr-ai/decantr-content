{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "product-card",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Product Card",
  "description": "Single product/post display card with thumbnail, price, type indicator, and actions. Used within product grids.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Badge",
    "icon"
  ],
  "default_preset": "grid",
  "presets": {
    "grid": {
      "description": "Square thumbnail card for grids",
      "components": [
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "card",
        "atoms": "studio-card _overflow[hidden]",
        "slots": {
          "thumbnail": "Preview image/video",
          "title": "Product name",
          "price": "Price or tier indicator",
          "meta": "Date, type, likes",
          "lock-indicator": "Locked badge for gated content"
        }
      }
    },
    "list": {
      "description": "Horizontal list item",
      "components": [
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "inline",
        "atoms": "studio-card _p4 _flex _gap4",
        "slots": {
          "thumbnail": "Small thumbnail",
          "content": "Title, description",
          "meta": "Price, actions"
        }
      }
    },
    "featured": {
      "description": "Large featured card with more details",
      "components": [
        "Button",
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "card",
        "atoms": "studio-card _overflow[hidden] _lg:flex _lg:row",
        "slots": {
          "media": "Large preview area",
          "content": "Full title, description, meta",
          "actions": "Buy, like, share buttons"
        }
      }
    }
  },
  "default_layout": {
    "layout": "card",
    "atoms": "studio-card _overflow[hidden]",
    "slots": {
      "thumbnail": "Preview image",
      "title": "Product name",
      "price": "Price display",
      "actions": "Card actions"
    }
  },
  "io": {
    "produces": [
      "product-click",
      "buy-click"
    ],
    "consumes": [
      "product-data"
    ]
  }
}
