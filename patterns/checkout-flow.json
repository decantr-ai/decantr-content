{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "checkout-flow",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Checkout Flow",
  "description": "Complete purchase/subscribe checkout process with payment form, promo codes, order summary, and success confirmation.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Input",
        "Badge",
        "Radio",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Input",
    "Badge",
    "Radio",
    "icon"
  ],
  "default_preset": "subscribe",
  "presets": {
    "subscribe": {
      "description": "Tier subscription checkout",
      "components": [
        "Button",
        "Card",
        "Input",
        "Badge",
        "Radio",
        "icon"
      ],
      "layout": {
        "layout": "split",
        "atoms": "_grid _gc1 _lg:gc2 _gap8 _maxw[960px] _mx[auto]",
        "slots": {
          "summary": "Tier/order summary card",
          "payment-form": "Card/payment method inputs",
          "promo-code": "Discount code input",
          "terms": "Terms acceptance checkbox",
          "submit": "Subscribe/pay button"
        }
      }
    },
    "purchase": {
      "description": "One-time product purchase",
      "components": [
        "Button",
        "Card",
        "Input",
        "icon"
      ],
      "layout": {
        "layout": "split",
        "atoms": "_grid _gc1 _lg:gc2 _gap8 _maxw[960px] _mx[auto]",
        "slots": {
          "summary": "Product summary",
          "payment-form": "Payment inputs",
          "submit": "Purchase button"
        }
      }
    },
    "upgrade": {
      "description": "Tier upgrade flow",
      "components": [
        "Button",
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "center",
        "atoms": "_flex _col _gap6 _maxw[480px] _mx[auto]",
        "slots": {
          "comparison": "Current vs new tier",
          "pricing": "Prorated price",
          "submit": "Upgrade button"
        }
      }
    }
  },
  "default_layout": {
    "layout": "split",
    "atoms": "_grid _gc1 _lg:gc2 _gap8",
    "slots": {
      "summary": "Order summary",
      "payment": "Payment form",
      "submit": "Submit button"
    }
  },
  "io": {
    "produces": [
      "checkout-complete",
      "payment-error"
    ],
    "consumes": [
      "tier-data",
      "product-data"
    ]
  }
}
