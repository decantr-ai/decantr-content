{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "chat-thread",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Chat Thread",
  "description": "Full message thread container with scrollable messages, typing indicator, pagination, and auto-scroll behavior.",
  "dependencies": {
    "patterns": {
      "chat-message": "^1.0.0",
      "chat-input": "^1.0.0"
    },
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Avatar",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Avatar",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Standard chat thread with messages and anchored input",
      "components": [
        "Button",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _overflow[hidden]",
        "slots": {
          "messages": "Scrollable message list",
          "typing-indicator": "AI is thinking... indicator",
          "load-more": "History pagination button",
          "scroll-to-bottom": "Floating button when scrolled up"
        }
      }
    },
    "branched": {
      "description": "Thread with branch indicator for conversation forks",
      "components": [
        "Button",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _overflow[hidden]",
        "slots": {
          "branch-indicator": "Visual marker showing conversation branch point",
          "messages": "Scrollable message list",
          "typing-indicator": "AI is thinking... indicator"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _hfull _overflow[hidden]",
    "slots": {
      "messages": "Scrollable message list with ChatMessage components",
      "typing-indicator": "AI is thinking... animated indicator",
      "load-more": "History pagination trigger",
      "branch-indicator": "Branched conversation marker",
      "scroll-to-bottom": "Floating FAB when scrolled up"
    }
  }
}
