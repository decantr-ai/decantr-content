{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "unit-list",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Unit List",
  "description": "Units within a property displayed as cards or table. Shows unit number, specs, tenant, rent, and status.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge"
  ],
  "default_preset": "grid",
  "presets": {
    "grid": {
      "description": "Card grid of units",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title, add unit button",
          "summary": "Total units, occupied, vacant, revenue",
          "filters": "Status filter",
          "items": "Unit cards"
        }
      }
    },
    "table": {
      "description": "Table view of units",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title and controls",
          "table": "Units table"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "header": "Title and add button",
      "summary": "Unit counts",
      "items": "Unit cards or rows"
    }
  }
}
