{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "vacancy-tracker",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Vacancy Tracker",
  "description": "Empty units tracker with vacancy rate, days vacant, lost revenue, listing status, and applicant pipeline.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full vacancy tracker view",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "header": "Title, total vacant count",
          "summary": "Vacancy rate, days vacant avg, lost revenue",
          "units": "Vacant unit list",
          "pipeline": "Applicants in pipeline",
          "marketing": "Listing status per unit"
        }
      }
    },
    "mini": {
      "description": "Compact vacancy widget for dashboard",
      "components": [
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap3 _p4",
        "slots": {
          "header": "Title",
          "rate": "Vacancy rate",
          "lost": "Lost revenue"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "header": "Title",
      "summary": "Vacancy metrics",
      "units": "Vacant unit list",
      "pipeline": "Applicants"
    }
  }
}
