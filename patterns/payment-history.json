{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "payment-history",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Payment History",
  "description": "Payment records table with date range filtering, export, and receipt generation. Supports tenant, property, and portfolio views.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Input",
    "Select"
  ],
  "default_preset": "portfolio",
  "presets": {
    "portfolio": {
      "description": "All payments across portfolio",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title, date range picker, export",
          "filters": "Payment type, status, property filters",
          "summary": "Total for period",
          "table": "Payment records"
        }
      }
    },
    "tenant": {
      "description": "Single tenant payment history",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title",
          "table": "Tenant's payment records"
        }
      }
    },
    "property": {
      "description": "Property-wide payment history",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Select"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title and filters",
          "table": "Property payment records"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "header": "Title and controls",
      "filters": "Date and type filters",
      "table": "Payment records",
      "summary": "Totals"
    }
  }
}
