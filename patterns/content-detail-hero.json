{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "content-detail-hero",
  "version": "1.0.0",
  "decantr_compat": ">=0.9.0",
  "name": "Content Detail Hero",
  "description": "Header section for content detail pages showing name, namespace, type, description, version history, and action buttons (copy JSON, use in project).",
  "dependencies": {
    "patterns": {
      "namespace-badge": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Badge",
        "Button",
        "Chip",
        "icon"
      ],
      "charts": []
    }
  },
  "contained": false,
  "components": [
    "Badge",
    "Button",
    "Chip",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full-width hero with content name, namespace badge, type chip, description, version, and action buttons.",
      "components": [
        "Badge",
        "Button",
        "Chip",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4 _py8 _px6 _borderb _bordermuted/20",
        "slots": {
          "breadcrumb": "Breadcrumb navigation: Registry > Type > Namespace > Slug",
          "badges": "Horizontal row of type Chip and namespace Badge",
          "title": "Content name with _heading2 styling",
          "description": "Full description with _body _fgmuted",
          "meta-row": "Version, author, updated date, download count",
          "action-group": "Copy JSON Button, Use in Project Button, share icon"
        }
      }
    },
    "compact": {
      "description": "Compact hero for inline/modal views with minimal spacing.",
      "components": [
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap3 _py4 _px4",
        "slots": {
          "badges": "Type and namespace badges, inline",
          "title": "Content name with _heading3",
          "description": "Short description with _bodysm _fgmuted",
          "actions": "Copy and use buttons, compact"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4 _py8 _px6 _borderb _bordermuted/20",
    "slots": {
      "breadcrumb": "Breadcrumb navigation",
      "badges": "Type and namespace badges",
      "title": "Content name heading",
      "description": "Content description",
      "meta-row": "Version, author, date",
      "action-group": "Copy, use, share buttons"
    }
  }
}
