{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "conversation-list",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Conversation List",
  "description": "Sidebar conversation history with search, new chat button, and conversation items showing unread indicators and actions.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Avatar",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Avatar",
    "Badge",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full conversation list with search and details",
      "components": [
        "Button",
        "Avatar",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull",
        "slots": {
          "search": "Filter/search conversations input",
          "new-button": "Create new conversation button",
          "items": "List of conversation rows"
        }
      }
    },
    "compact": {
      "description": "Icon-only list for collapsed sidebar rail",
      "components": [
        "Button",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _aic _gap2 _py2",
        "slots": {
          "new-button": "Icon-only new chat button",
          "items": "Avatar/icon-only conversation items"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _hfull",
    "slots": {
      "search": "Filter conversations input",
      "new-button": "Create new conversation",
      "items": "Conversation rows with icon, title, date, unread-indicator, actions"
    }
  }
}
