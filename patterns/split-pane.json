{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "split-pane",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Split Pane",
  "description": "Resizable terminal panes with keyboard and mouse controls for multi-panel layouts.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [],
      "charts": []
    }
  },
  "components": [],
  "default_preset": "horizontal",
  "presets": {
    "horizontal": {
      "description": "Side by side panes with vertical divider",
      "components": [],
      "layout": {
        "layout": "flex",
        "atoms": "_flex _hfull _mono _bgblack",
        "slots": {
          "pane-left": "Left content pane",
          "divider": "Resizable vertical divider",
          "pane-right": "Right content pane"
        }
      }
    },
    "vertical": {
      "description": "Stacked panes with horizontal divider",
      "components": [],
      "layout": {
        "layout": "flex",
        "atoms": "_flex _col _hfull _mono _bgblack",
        "slots": {
          "pane-top": "Top content pane",
          "divider": "Resizable horizontal divider",
          "pane-bottom": "Bottom content pane"
        }
      }
    },
    "quad": {
      "description": "2x2 grid of four panes",
      "components": [],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _hfull _mono _bgblack",
        "slots": {
          "pane-tl": "Top-left pane",
          "pane-tr": "Top-right pane",
          "pane-bl": "Bottom-left pane",
          "pane-br": "Bottom-right pane"
        }
      }
    }
  },
  "default_layout": {
    "layout": "flex",
    "atoms": "_flex _hfull _mono",
    "slots": {
      "panes": "Content panes",
      "handles": "Resize handles"
    }
  },
  "features": [
    "drag-resize",
    "double-click-reset",
    "keyboard-resize",
    "min-max-constraints",
    "collapse-rail",
    "focus-indicator"
  ],
  "keyboard_shortcuts": {
    "Ctrl+Shift+Left": "Shrink left pane",
    "Ctrl+Shift+Right": "Expand left pane",
    "Ctrl+Shift+Up": "Shrink top pane",
    "Ctrl+Shift+Down": "Expand top pane",
    "Ctrl+\\": "Toggle pane focus"
  }
}
