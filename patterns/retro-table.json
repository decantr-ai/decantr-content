{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "retro-table",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Retro Table",
  "description": "ASCII-bordered data tables with box-drawing characters for terminal-style displays.",
  "dependencies": {
    "patterns": {},
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full ASCII borders with box-drawing characters",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen _overflow[auto]",
        "slots": {
          "header": "Column headers",
          "body": "Data rows",
          "footer": "Summary row",
          "pagination": "Page controls"
        }
      }
    },
    "simple": {
      "description": "Simple pipe separators without full borders",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen",
        "slots": {
          "header": "Column headers with pipes",
          "body": "Data rows with pipes"
        }
      }
    },
    "compact": {
      "description": "Compact table without vertical lines",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen",
        "slots": {
          "header": "Underlined headers",
          "body": "Space-separated data"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _mono _fggreen",
    "slots": {
      "header": "Column headers",
      "body": "Data rows",
      "footer": "Summary",
      "pagination": "Page controls"
    }
  },
  "features": [
    "sortable-columns",
    "resizable-columns",
    "horizontal-scroll",
    "row-selection",
    "copy-cell",
    "export-csv"
  ],
  "border_characters": {
    "top_left": "┌",
    "top_right": "┐",
    "bottom_left": "└",
    "bottom_right": "┘",
    "horizontal": "─",
    "vertical": "│",
    "t_left": "├",
    "t_right": "┤",
    "t_top": "┬",
    "t_bottom": "┴",
    "cross": "┼"
  }
}
