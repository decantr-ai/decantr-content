{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "pnl-dashboard",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "P&L Dashboard",
  "description": "Profit & loss analytics dashboard with gross income, expenses, NOI, cash flow, breakdowns by category, property comparison, and projections.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Select"
      ],
      "charts": [
        "AreaChart",
        "BarChart",
        "PieChart"
      ]
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Select"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full P&L dashboard",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Select"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "header": "Date range, property filter, export",
          "summary-cards": "Gross income, expenses, NOI, cash flow",
          "income-breakdown": "Rental income, other income by category",
          "expense-breakdown": "Expenses by category",
          "chart": "Income vs expenses trend",
          "property-comparison": "P&L by property table",
          "projections": "Forecasted cash flow"
        }
      }
    },
    "summary": {
      "description": "Compact P&L summary for dashboard",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap3 _p4",
        "slots": {
          "metrics": "Key financial metrics"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "header": "Title and filters",
      "summary": "Key metrics",
      "breakdowns": "Income and expense breakdowns",
      "comparison": "Property comparison"
    }
  }
}
