{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "tier-builder",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Tier Builder",
  "description": "Subscription tier configuration interface with drag-reorder, benefit editor, pricing inputs, and live preview.",
  "dependencies": {
    "patterns": {
      "tier-card": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Input",
        "Badge",
        "Switch",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Input",
    "Badge",
    "Switch",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full tier editor with drag-reorder, benefits, and live preview",
      "components": [
        "Button",
        "Card",
        "Input",
        "Badge",
        "Switch",
        "icon"
      ],
      "layout": {
        "layout": "split",
        "atoms": "_grid _gc1 _lg:gc2 _gap6",
        "slots": {
          "tier-list": "Existing tiers with drag handles for reordering",
          "tier-form": "Create/edit tier form with all fields",
          "benefits-editor": "Add/remove/reorder tier benefits",
          "price-input": "Monthly and yearly pricing inputs",
          "preview": "Live tier card preview"
        }
      }
    },
    "compact": {
      "description": "Simplified tier list view for mobile",
      "components": [
        "Button",
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "tier-list": "Compact tier cards",
          "add-button": "Add tier button"
        }
      }
    }
  },
  "default_layout": {
    "layout": "split",
    "atoms": "_grid _gc1 _lg:gc2 _gap6",
    "slots": {
      "tier-list": "Existing tiers",
      "tier-form": "Tier editor form",
      "benefits-editor": "Benefits management",
      "preview": "Live preview"
    }
  },
  "io": {
    "produces": [
      "tier-data",
      "tier-saved"
    ],
    "consumes": [
      "existing-tiers"
    ]
  }
}
