{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "metric-gauge",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Metric Gauge",
  "description": "CLI-style metric displays with value, trend indicators, and optional sparklines.",
  "dependencies": {
    "patterns": {
      "ascii-chart": "^1.0.0"
    },
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "icon"
  ],
  "default_preset": "single",
  "presets": {
    "single": {
      "description": "Single large metric value display",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _aic _mono _fggreen",
        "slots": {
          "label": "Metric name",
          "value": "Current value",
          "unit": "Unit suffix",
          "trend": "Up/down trend arrow"
        }
      }
    },
    "inline": {
      "description": "Inline key: value metric display",
      "components": [],
      "layout": {
        "layout": "flex",
        "atoms": "_flex _aic _gap2 _mono _fggreen",
        "slots": {
          "label": "Metric name",
          "value": "Current value"
        }
      }
    },
    "block": {
      "description": "Boxed metric with border and sparkline",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _mono _fggreen",
        "slots": {
          "label": "Metric name",
          "value": "Current value",
          "sparkline": "Mini trend chart"
        }
      }
    },
    "grid": {
      "description": "Grid of multiple metrics",
      "components": [],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gap2 _mono _fggreen",
        "slots": {
          "metrics": "Array of metric displays"
        }
      }
    }
  },
  "default_layout": {
    "layout": "flex",
    "atoms": "_flex _aic _gap2 _mono _fggreen",
    "slots": {
      "label": "Metric name",
      "value": "Current value",
      "unit": "Unit suffix",
      "trend": "Trend indicator"
    }
  },
  "features": [
    "color-thresholds",
    "trend-indicators",
    "historical-sparkline",
    "click-detail"
  ],
  "thresholds": {
    "success": {
      "color": "#00FF00",
      "description": "Normal/good state"
    },
    "warning": {
      "color": "#FFB000",
      "description": "Warning threshold"
    },
    "critical": {
      "color": "#FF0000",
      "description": "Critical threshold"
    }
  }
}
