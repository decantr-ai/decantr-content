{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "moderation-queue-item",
  "version": "1.0.0",
  "decantr_compat": ">=0.9.0",
  "name": "Moderation Queue Item",
  "description": "Submission card for the admin moderation queue showing content preview, submitter info, reputation score, and approve/reject action buttons.",
  "dependencies": {
    "patterns": {
      "namespace-badge": "^1.0.0",
      "reputation-badge": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Card",
        "Badge",
        "Button",
        "Avatar",
        "icon"
      ],
      "charts": []
    }
  },
  "contained": false,
  "components": [
    "Card",
    "CardHeader",
    "CardBody",
    "CardFooter",
    "Badge",
    "Button",
    "Avatar",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full moderation card with content preview, submitter avatar, reputation score, submission date, and approve/reject buttons.",
      "components": [
        "Card",
        "CardHeader",
        "CardBody",
        "CardFooter",
        "Badge",
        "Button",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap0 _border _bordermuted/20 _r3 _overflow[hidden]",
        "slots": {
          "header": "Type badge, content name, and submission timestamp",
          "submitter": "Avatar, username, reputation score badge, and trust indicator",
          "preview": "Content description and truncated JSON preview",
          "notes": "Optional admin notes textarea",
          "actions": "Approve Button (success), Reject Button (destructive), View Detail link"
        }
      }
    },
    "compact": {
      "description": "Compact single-row moderation item for dense queue views. Inline approve/reject icons.",
      "components": [
        "Badge",
        "Button",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap4 _px4 _py3 _borderb _bordermuted/10",
        "slots": {
          "avatar": "Submitter Avatar, small",
          "content-info": "Type badge, name, and short description inline",
          "reputation": "Reputation score, compact",
          "actions": "Approve/reject icon Buttons"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap0 _border _bordermuted/20 _r3",
    "slots": {
      "header": "Type, name, timestamp",
      "submitter": "Avatar, name, reputation",
      "preview": "Description and content preview",
      "actions": "Approve and reject buttons"
    }
  }
}
