{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "comment-thread",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Comment Thread",
  "description": "Inline or sidebar comment discussions with reply threading, @mentions, reactions, and resolve functionality.",
  "dependencies": {
    "patterns": {
      "mention-popup": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Avatar",
        "Button",
        "Textarea",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Avatar",
    "Button",
    "Textarea",
    "icon"
  ],
  "default_preset": "sidebar",
  "presets": {
    "sidebar": {
      "description": "Full thread display in aside panel",
      "components": [
        "Avatar",
        "Button",
        "Textarea",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap3 _p4",
        "slots": {
          "comments": "List of comment messages",
          "reply-input": "New reply composer",
          "actions": "Thread-level actions (resolve, delete)"
        }
      }
    },
    "inline": {
      "description": "Compact thread attached to text selection",
      "components": [
        "Avatar",
        "Button",
        "Textarea",
        "icon"
      ],
      "layout": {
        "layout": "popover",
        "atoms": "_absolute _w[320px] _bg[var(--surface)] _shadow _r2 _border",
        "slots": {
          "anchor": "Connection line to commented text",
          "comments": "Compact comment list",
          "reply-input": "Inline reply field"
        }
      }
    },
    "resolved": {
      "description": "Collapsed resolved thread indicator",
      "components": [
        "Avatar",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap2 _p2 _bg[var(--surface-raised)] _r1",
        "slots": {
          "indicator": "Resolved checkmark",
          "summary": "Brief thread summary",
          "expand": "Expand to view"
        }
      }
    }
  },
  "default_layout": {
    "layout": "column",
    "atoms": "_flex _col _gap3",
    "slots": {
      "anchor": "Connection to commented content",
      "comments": "List of comment messages with avatar, author, timestamp",
      "reply-input": "Textarea for new replies",
      "actions": "Resolve, delete, react actions",
      "resolved-indicator": "Checkmark when thread is resolved"
    }
  },
  "io": {
    "consumes": [
      "thread",
      "currentUser"
    ],
    "produces": [
      "reply",
      "resolve",
      "react"
    ],
    "actions": [
      "add-reply",
      "resolve-thread",
      "reopen-thread",
      "add-reaction",
      "delete-comment",
      "edit-comment"
    ]
  }
}
