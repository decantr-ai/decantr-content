{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "contact-form",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Contact Form",
  "description": "Working contact form with validation, honeypot spam protection, file attachment, and department dropdown.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full contact form with all fields",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _maxw[600px] _mx[auto]",
        "slots": {
          "header": "Title and description",
          "fields": "Form inputs (name, email, department, message)",
          "attachments": "File attachment area",
          "submit": "Submit button",
          "success": "Success message after submission",
          "info": "Contact info sidebar (optional)"
        }
      }
    },
    "compact": {
      "description": "Simplified contact form with minimal fields",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "fields": "Email and message only",
          "submit": "Submit button"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6 _maxw[600px] _mx[auto]",
    "slots": {
      "header": "Title and description",
      "fields": "Form inputs",
      "submit": "Submit button",
      "success": "Success confirmation",
      "info": "Contact info (optional)"
    }
  }
}
