{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "presence-avatars",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Presence Avatars",
  "description": "Horizontal stack of collaborator avatars showing who is currently viewing or editing. Each avatar has a unique presence color ring.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Avatar",
        "Button",
        "Tooltip",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Avatar",
    "Button",
    "Tooltip"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Avatar stack with overflow count and hover tooltips",
      "components": [
        "Avatar",
        "Tooltip"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _-space-x-2",
        "slots": {
          "avatars": "Stacked avatar images with presence color ring",
          "overflow": "+N more indicator",
          "tooltip": "Hover shows full name and status"
        }
      }
    },
    "compact": {
      "description": "Smaller avatars with tighter spacing",
      "components": [
        "Avatar",
        "Tooltip"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _-space-x-1",
        "slots": {
          "avatars": "Small stacked avatars",
          "overflow": "Overflow count"
        }
      }
    },
    "detailed": {
      "description": "Avatars with online/away status dots",
      "components": [
        "Avatar",
        "Tooltip"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap1",
        "slots": {
          "avatars": "Avatars with status indicator",
          "status-dot": "Online/away/idle indicator"
        }
      }
    }
  },
  "default_layout": {
    "layout": "row",
    "atoms": "_flex _aic _-space-x-2",
    "slots": {
      "avatars": "Stacked avatar images with presence color ring",
      "overflow": "+N more indicator with click to expand",
      "tooltip": "Hover tooltip showing collaborator name and status"
    }
  },
  "io": {
    "consumes": [
      "collaborators",
      "maxVisible"
    ],
    "produces": [],
    "actions": [
      "expand-list",
      "view-profile"
    ]
  }
}
