{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "property-detail",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Property Detail",
  "description": "Full property view with details, gallery, metrics, units, financials, documents, and maintenance history.",
  "dependencies": {
    "patterns": {
      "unit-list": "^1.0.0"
    },
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Tabs"
      ],
      "charts": [
        "AreaChart"
      ]
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Tabs"
  ],
  "default_preset": "view",
  "presets": {
    "view": {
      "description": "Full property detail view with tabs",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Tabs"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "header": "Property name, address, edit button, back link",
          "gallery": "Property photo gallery",
          "metrics": "Key metrics row (occupancy, revenue, expenses, NOI)",
          "tabs": "Overview, Units, Financials, Documents, Maintenance tabs",
          "overview": "Property details (type, year, sqft, beds/baths)",
          "units": "Unit list (embedded)",
          "financials": "Property P&L summary",
          "documents": "Property documents",
          "maintenance": "Recent maintenance tickets",
          "timeline": "Property activity history"
        }
      }
    },
    "create": {
      "description": "Create/edit property form",
      "components": [
        "Button",
        "icon",
        "Input",
        "Select",
        "Textarea"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6 _maxw[800px]",
        "slots": {
          "header": "Form title",
          "form": "Property form fields",
          "images": "Image upload area",
          "actions": "Save/cancel buttons"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "header": "Property header",
      "gallery": "Photo gallery",
      "metrics": "Key metrics",
      "content": "Tabbed content area"
    }
  }
}
