{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "card-grid",
  "version": "1.0.0",
  "decantr_compat": ">=0.9.0",
  "name": "Card Grid",
  "description": "Responsive grid of cards with preset-specific content layouts",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Card",
        "Button",
        "Badge",
        "Image",
        "icon"
      ],
      "charts": []
    }
  },
  "contained": false,
  "components": [
    "Card",
    "CardHeader",
    "CardBody",
    "CardFooter",
    "Image",
    "Button",
    "Badge"
  ],
  "default_preset": "product",
  "presets": {
    "product": {
      "description": "Product cards with image, title, price, rating, add-to-cart button. Grid: 1/2/3/4 cols at sm/md/lg/xl.",
      "components": [
        "Card",
        "CardHeader",
        "CardBody",
        "CardFooter",
        "Image",
        "Button",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc1 _sm:gc2 _lg:gc3 _xl:gc4 _gap4",
        "slots": {
          "card-image": "Product image with aspect-ratio container",
          "card-title": "Product name with _textsm _fontmedium",
          "card-price": "Price with _heading4 styling",
          "card-rating": "Star rating row with icon stars and count Badge",
          "card-action": "Add-to-cart Button in CardFooter"
        }
      }
    },
    "content": {
      "description": "Content/blog cards with thumbnail, title, excerpt, author, date. Grid: 1/2/3 cols.",
      "components": [
        "Card",
        "CardHeader",
        "CardBody",
        "Image",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc1 _md:gc2 _lg:gc3 _gap6",
        "slots": {
          "card-thumbnail": "Blog post thumbnail image",
          "card-category": "Category Badge above title",
          "card-title": "Article title with _heading4 styling",
          "card-excerpt": "Short excerpt with _bodysm _fgmuted",
          "card-meta": "Author avatar, name, and date row"
        }
      }
    },
    "collection": {
      "description": "Collection/category cards with background image, overlay title, item count. Grid: 2/3 cols.",
      "components": [
        "Card",
        "Image",
        "Badge"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc2 _lg:gc3 _gap4",
        "slots": {
          "card-background": "Full-bleed background image with gradient overlay",
          "card-overlay-title": "Collection name overlaid at bottom with _heading3",
          "card-count": "Item count Badge overlaid on image"
        }
      }
    },
    "icon": {
      "description": "Small icon cards with icon, title, short description. Grid: 2/3/4 cols. Compact.",
      "components": [
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc2 _md:gc3 _lg:gc4 _gap3",
        "slots": {
          "card-icon": "Icon in a rounded muted background circle",
          "card-title": "Feature title with _textsm _fontmedium",
          "card-description": "Short description with _textxs _fgmuted"
        }
      }
    }
  },
  "default_layout": {
    "layout": "grid",
    "atoms": "_grid _gc1 _sm:gc2 _lg:gc3 _xl:gc4 _gap4",
    "slots": {
      "card-image": "Product image with aspect-ratio container",
      "card-title": "Product name with _textsm _fontmedium",
      "card-price": "Price with _heading4 styling",
      "card-rating": "Star rating row with icon stars and count Badge",
      "card-action": "Add-to-cart Button in CardFooter"
    }
  },
  "io": {
    "consumes": [
      "search",
      "filters",
      "data"
    ],
    "produces": [
      "selection"
    ],
    "actions": [
      "load-more"
    ]
  }
}
