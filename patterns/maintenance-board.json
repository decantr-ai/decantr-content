{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "maintenance-board",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Maintenance Board",
  "description": "Kanban-style maintenance ticket board with drag-and-drop between columns: new, assigned, in-progress, pending-parts, completed, closed.",
  "dependencies": {
    "patterns": {
      "maintenance-ticket": "^1.0.0"
    },
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Select"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Select"
  ],
  "default_preset": "board",
  "presets": {
    "board": {
      "description": "Full Kanban board view",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Select"
      ],
      "layout": {
        "layout": "horizontal",
        "atoms": "_flex _gap4 _overflow[auto] _pb4",
        "slots": {
          "header": "Title, filters, view toggle",
          "filters": "Property, priority, category, date range",
          "columns": "Kanban columns with ticket cards",
          "summary": "Open count, avg resolution time"
        }
      }
    },
    "list": {
      "description": "List view of tickets",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap2",
        "slots": {
          "header": "Title and controls",
          "table": "Ticket table"
        }
      }
    },
    "mini": {
      "description": "Compact board for dashboard",
      "components": [
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap3 _p4",
        "slots": {
          "header": "Title",
          "counts": "Column counts",
          "recent": "Recent tickets"
        }
      }
    }
  },
  "default_layout": {
    "layout": "horizontal",
    "atoms": "_flex _gap4 _overflow[auto]",
    "slots": {
      "header": "Title and controls",
      "columns": "Kanban columns"
    }
  }
}
