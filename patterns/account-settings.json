{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "account-settings",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Account Settings",
  "description": "Account management forms with presets for profile, security, preferences, and danger zone (account deletion).",
  "dependencies": {
    "patterns": {
      "session-manager": "^1.0.0"
    },
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Avatar",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Avatar",
    "Badge",
    "icon"
  ],
  "default_preset": "profile",
  "presets": {
    "profile": {
      "description": "Profile editing with avatar upload, name, email, bio",
      "components": [
        "Button",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap8",
        "slots": {
          "avatar": "Avatar with upload/change button",
          "form": "Name, email, bio inputs with inline edit",
          "save": "Save changes button"
        }
      }
    },
    "security": {
      "description": "Security settings with password change and MFA controls",
      "components": [
        "Button",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap8",
        "slots": {
          "password": "Change password form",
          "mfa": "MFA enable/disable toggle with status",
          "sessions": "Session manager component"
        }
      }
    },
    "preferences": {
      "description": "User preferences for theme, notifications, language",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap8",
        "slots": {
          "theme": "Theme selector (light/dark/auto)",
          "notifications": "Notification toggles",
          "language": "Language/locale selector"
        }
      }
    },
    "danger-zone": {
      "description": "Account deletion with typed confirmation",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "warning": "Deletion warning message",
          "confirm": "Typed confirmation input",
          "delete": "Delete account button"
        }
      }
    }
  },
  "layout_hints": {
    "active_state": "Active nav/tab item should have a visible indicator: accent-colored left border (for vertical nav) or bottom border (for horizontal tabs), plus accent text color.",
    "nav_position": "For settings pages, vertical tab nav on the left. Content area scrolls independently.",
    "spacing": "Nav items have consistent padding. Active item stands out but doesn't shift layout."
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap8",
    "slots": {
      "form": "Settings form fields",
      "save": "Save button"
    }
  },
  "composition": {
    "AccountSettings": "Container(d-section, flex-col) > [SettingsNav(vertical-tabs, d-interactive) + SettingsContent]",
    "SettingsNav": "TabList(d-control) > Tab(active?: accent-border)[]",
    "SettingsContent": "Panel(d-surface, flex-col, gap-8) > [AvatarUpload? + FormFields + SaveButton(d-interactive, variant: primary)]"
  }
}
