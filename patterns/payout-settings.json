{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "payout-settings",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Payout Settings",
  "description": "Bank/payment configuration form with payout method selection, bank details, schedule settings, and payout history.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Input",
        "Select",
        "Badge",
        "Radio",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Input",
    "Select",
    "Badge",
    "Radio",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full payout setup with all options",
      "components": [
        "Button",
        "Card",
        "Input",
        "Select",
        "Badge",
        "Radio",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "method-select": "Bank, PayPal, Stripe selection",
          "bank-form": "Bank account details form",
          "payout-schedule": "Weekly/monthly selection",
          "threshold": "Minimum payout amount",
          "history": "Past payouts table"
        }
      }
    },
    "readonly": {
      "description": "Display current payout settings",
      "components": [
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "method": "Current payout method",
          "schedule": "Payout schedule",
          "next-payout": "Next payout info"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "method": "Payout method selection",
      "details": "Account details",
      "schedule": "Schedule settings",
      "history": "Payout history"
    }
  },
  "io": {
    "produces": [
      "settings-saved"
    ],
    "consumes": [
      "payout-settings",
      "payout-history"
    ]
  }
}
