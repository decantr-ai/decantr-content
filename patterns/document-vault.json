{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "document-vault",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Document Vault",
  "description": "Document storage and organization with folder navigation, preview, version history, expiration tracking, and sharing.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Input"
  ],
  "default_preset": "list",
  "presets": {
    "list": {
      "description": "File list view",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input"
      ],
      "layout": {
        "layout": "split",
        "atoms": "_flex _gap6",
        "slots": {
          "header": "Title, upload button, view toggle",
          "navigation": "Folder tree sidebar",
          "search": "Document search",
          "items": "Document list/grid",
          "preview": "Document preview pane"
        }
      }
    },
    "grid": {
      "description": "Thumbnail grid view",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _cols4 _gap4",
        "slots": {
          "items": "Document thumbnail cards"
        }
      }
    },
    "tenant": {
      "description": "Tenant document view (limited)",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title",
          "documents": "Tenant's accessible documents"
        }
      }
    }
  },
  "default_layout": {
    "layout": "split",
    "atoms": "_flex _gap6",
    "slots": {
      "navigation": "Folder sidebar",
      "content": "Document list/grid",
      "preview": "Preview pane"
    }
  }
}
