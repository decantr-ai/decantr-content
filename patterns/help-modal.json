{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "help-modal",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Help Modal",
  "description": "Keyboard shortcuts help overlay with categorized shortcuts and search.",
  "dependencies": {
    "patterns": {},
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full categorized keyboard shortcuts modal",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_fixed _inset0 _flex _center _z[100] _bg[rgba(0,0,0,0.9)]",
        "slots": {
          "header": "Title and close button",
          "search": "Filter shortcuts",
          "categories": "Shortcut categories",
          "shortcuts": "Key + description pairs"
        }
      }
    },
    "minimal": {
      "description": "Compact quick reference card",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_fixed _inset0 _flex _center _z[100] _bg[rgba(0,0,0,0.8)]",
        "slots": {
          "shortcuts": "Compact shortcut list"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_fixed _inset0 _flex _center _z[100]",
    "slots": {
      "header": "Title",
      "categories": "Shortcut categories",
      "shortcuts": "Key bindings"
    }
  },
  "features": [
    "keyboard-searchable",
    "categorized",
    "toggle-shortcut"
  ],
  "default_shortcuts": [
    {
      "name": "Navigation",
      "items": [
        {
          "key": "?",
          "description": "Toggle help"
        },
        {
          "key": "Ctrl+K",
          "description": "Command palette"
        },
        {
          "key": "F1",
          "description": "Help"
        },
        {
          "key": "F4",
          "description": "Quit"
        }
      ]
    },
    {
      "name": "Panes",
      "items": [
        {
          "key": "Ctrl+\\",
          "description": "Toggle pane focus"
        },
        {
          "key": "Ctrl+Shift+Left",
          "description": "Resize pane left"
        },
        {
          "key": "Ctrl+Shift+Right",
          "description": "Resize pane right"
        }
      ]
    },
    {
      "name": "Terminal",
      "items": [
        {
          "key": "Ctrl+L",
          "description": "Clear screen"
        },
        {
          "key": "Ctrl+R",
          "description": "Search history"
        },
        {
          "key": "Up/Down",
          "description": "History navigation"
        }
      ]
    }
  ],
  "visual_brief": "Centered modal overlay with a title ('Keyboard Shortcuts') and an optional search input. The body is organized into categorized sections (General, Navigation, Editing, etc.) with muted category headers. Each shortcut row shows the action description on the left and the key combination on the right rendered as styled key cap badges (bordered rounded boxes with monospace text, e.g., [Cmd] + [K]). Sections are separated by subtle dividers. Minimal preset removes categories and shows a flat list.",
  "responsive": {
    "mobile": "Modal takes near-full screen. Shortcuts list scrolls vertically. Key badges remain readable. Search input at top for quick filtering.",
    "tablet": "Centered modal at 520px width. Standard layout with categories.",
    "desktop": "Centered modal at 600px width. Optional two-column layout for dense shortcut lists."
  }
}
