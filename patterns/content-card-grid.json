{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "content-card-grid",
  "version": "1.0.0",
  "decantr_compat": ">=0.9.0",
  "name": "Content Card Grid",
  "description": "Responsive grid of registry content cards with type badges, namespace indicators, version info, and quick-action buttons. Used for browsing patterns, themes, blueprints, and other registry items.",
  "dependencies": {
    "patterns": {
      "namespace-badge": "^1.0.0"
    },
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Card",
        "Badge",
        "Button",
        "icon"
      ],
      "charts": []
    }
  },
  "contained": false,
  "components": [
    "Card",
    "CardHeader",
    "CardBody",
    "CardFooter",
    "Badge",
    "Button",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Registry content cards with type badge, namespace indicator, name, description, and version. Grid: 1/2/3 cols at sm/md/lg.",
      "components": [
        "Card",
        "CardHeader",
        "CardBody",
        "CardFooter",
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc1 _md:gc2 _lg:gc3 _gap4",
        "slots": {
          "card-type-badge": "Type badge (pattern/theme/blueprint) with color-coded variant in CardHeader",
          "card-namespace": "Namespace badge (@official/@community/@org) inline with type",
          "card-title": "Content name with _heading4 styling, clickable link to detail",
          "card-description": "Short description with _bodysm _fgmuted, max 2 lines",
          "card-meta": "Version number, download count, and updated-at in CardFooter"
        }
      }
    },
    "compact": {
      "description": "Compact list-style content cards with minimal info. Grid: 1/2/4 cols. Useful for dense browsing views.",
      "components": [
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc1 _sm:gc2 _xl:gc4 _gap3",
        "slots": {
          "card-icon": "Content type icon on the left",
          "card-title": "Content name with _textsm _fontmedium",
          "card-namespace": "Namespace badge, small variant",
          "card-version": "Version text with _textxs _fgmuted"
        }
      }
    },
    "editable": {
      "description": "Content cards with edit/delete actions for the user dashboard. Includes status indicator and publish date.",
      "components": [
        "Card",
        "CardHeader",
        "CardBody",
        "CardFooter",
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "grid",
        "atoms": "_grid _gc1 _md:gc2 _lg:gc3 _gap4",
        "slots": {
          "card-status": "Status badge (published/pending/rejected) with color coding",
          "card-type-badge": "Content type badge",
          "card-title": "Content name, clickable to edit",
          "card-description": "Short description, max 2 lines",
          "card-actions": "Edit and delete Button group in CardFooter"
        }
      }
    }
  },
  "default_layout": {
    "layout": "grid",
    "atoms": "_grid _gc1 _md:gc2 _lg:gc3 _gap4",
    "slots": {
      "card-type-badge": "Type badge (pattern/theme/blueprint) with color-coded variant",
      "card-namespace": "Namespace badge (@official/@community/@org)",
      "card-title": "Content name, clickable link",
      "card-description": "Short description, max 2 lines",
      "card-meta": "Version, download count, updated-at"
    }
  }
}
