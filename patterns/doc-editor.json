{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "doc-editor",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Document Editor",
  "description": "Rich text block editor with real-time collaboration support. CRDT-based synchronization, floating toolbar, slash commands, and remote cursor overlay.",
  "dependencies": {
    "patterns": {
      "block-toolbar": "^1.0.0",
      "slash-command": "^1.0.0",
      "mention-popup": "^1.0.0",
      "remote-cursor": "^1.0.0"
    },
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Avatar",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Avatar",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full-featured block editor with toolbar, slash commands, and collaboration features",
      "components": [
        "Button",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _relative",
        "slots": {
          "cursors-layer": "Overlay for remote collaborator cursors",
          "selections-layer": "Overlay for remote text selections",
          "toolbar": "Floating formatting toolbar on selection",
          "content": "Contenteditable block container",
          "slash-menu": "Block type command palette",
          "mention-popup": "@mention autocomplete dropdown"
        }
      }
    },
    "minimal": {
      "description": "Focused writing mode with minimal UI",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull _relative",
        "slots": {
          "content": "Contenteditable with minimal distractions",
          "word-count": "Optional word/character count"
        }
      }
    },
    "presentation": {
      "description": "Read-only view mode for sharing",
      "components": [],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _hfull",
        "slots": {
          "content": "Rendered document (non-editable)"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _hfull _relative",
    "slots": {
      "cursors-layer": "Overlay for remote collaborator cursors",
      "selections-layer": "Overlay for remote text selections",
      "toolbar": "Floating formatting toolbar on selection",
      "content": "Contenteditable block container",
      "slash-menu": "Block type command palette",
      "mention-popup": "@mention autocomplete dropdown"
    }
  },
  "io": {
    "consumes": [
      "doc",
      "collaborators",
      "permissions"
    ],
    "produces": [
      "content-update",
      "selection-change",
      "cursor-move"
    ],
    "actions": [
      "format-text",
      "insert-block",
      "delete-block",
      "add-comment"
    ]
  }
}
