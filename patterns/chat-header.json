{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "chat-header",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Chat Header",
  "description": "Contextual header for active conversation with editable title, status indicator, and action buttons.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Badge",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Standard chat header with title and actions",
      "components": [
        "Button",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _jcsb _px6 _py3 _borderB _bgbg",
        "slots": {
          "title": "Editable conversation subject/title",
          "status": "Online/offline indicator or model name badge",
          "actions": "Search, export, branch, settings buttons"
        }
      }
    },
    "compact": {
      "description": "Minimal header for mobile or constrained layouts",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _jcsb _px4 _py2 _borderB _bgbg",
        "slots": {
          "back": "Back navigation button",
          "title": "Conversation title (truncated)",
          "menu": "Overflow menu button"
        }
      }
    }
  },
  "default_layout": {
    "layout": "row",
    "atoms": "_flex _aic _jcsb _px6 _py3 _borderB _bgbg",
    "slots": {
      "title": "Editable conversation subject",
      "status": "Online/offline or model name",
      "actions": "Search, export, branch, settings"
    }
  }
}
