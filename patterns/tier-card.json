{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "tier-card",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Tier Card",
  "description": "Single subscription tier display card with pricing, benefits, and subscribe CTA. Used on storefronts and upgrade flows.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Badge",
    "icon"
  ],
  "default_preset": "storefront",
  "presets": {
    "storefront": {
      "description": "Public-facing tier card with subscribe CTA",
      "components": [
        "Button",
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "card",
        "atoms": "studio-card _flex _col _p6 _r3",
        "slots": {
          "header": "Tier name, price, badge",
          "benefits": "List of included perks",
          "cta": "Subscribe/upgrade button",
          "subscribers": "Optional subscriber count"
        }
      }
    },
    "compact": {
      "description": "Small inline tier display",
      "components": [
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "inline",
        "atoms": "_flex _aic _gap3 _p3 _r2 _bgmuted/5",
        "slots": {
          "color": "Tier color indicator",
          "name": "Tier name",
          "price": "Price display"
        }
      }
    },
    "featured": {
      "description": "Large highlighted tier with glow effect",
      "components": [
        "Button",
        "Card",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "card",
        "atoms": "studio-card-premium _flex _col _p8 _r4 _scale[1.05]",
        "slots": {
          "header": "Tier name with featured badge",
          "benefits": "Extended benefits list",
          "cta": "Prominent subscribe button",
          "guarantee": "Money-back guarantee text"
        }
      }
    }
  },
  "default_layout": {
    "layout": "card",
    "atoms": "studio-card _flex _col _p6 _r3",
    "slots": {
      "header": "Tier name and price",
      "benefits": "Benefits list",
      "cta": "Subscribe button"
    }
  },
  "io": {
    "produces": [
      "subscribe-click"
    ],
    "consumes": [
      "tier-data",
      "billing-cycle"
    ]
  }
}
