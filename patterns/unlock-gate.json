{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "unlock-gate",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Unlock Gate",
  "description": "Paywall/tier gate component that blurs or hides content and prompts subscription. Shows required tier and quick subscribe flow.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Card",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Card",
    "Badge",
    "icon"
  ],
  "default_preset": "blur",
  "presets": {
    "blur": {
      "description": "Blurred preview with unlock overlay",
      "components": [
        "Button",
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "overlay",
        "atoms": "_relative _overflow[hidden]",
        "slots": {
          "preview": "Blurred content preview",
          "overlay": "Unlock prompt overlay",
          "tier-info": "Required tier badge",
          "cta": "Subscribe button"
        }
      }
    },
    "solid": {
      "description": "Solid overlay without preview",
      "components": [
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "center",
        "atoms": "_aspect[16/9] _bgmuted/5 _flex _col _center _r3",
        "slots": {
          "message": "Unlock prompt text",
          "tier-info": "Required tier",
          "cta": "Subscribe button"
        }
      }
    },
    "teaser": {
      "description": "Partial content visible with fade to gate",
      "components": [
        "Button",
        "Card",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_relative",
        "slots": {
          "teaser-content": "Visible portion of content",
          "fade": "Gradient fade to gate",
          "gate": "Subscribe prompt"
        }
      }
    }
  },
  "default_layout": {
    "layout": "overlay",
    "atoms": "_relative",
    "slots": {
      "preview": "Content preview",
      "overlay": "Gate overlay",
      "cta": "Unlock action"
    }
  },
  "io": {
    "produces": [
      "unlock-click",
      "subscribe-click"
    ],
    "consumes": [
      "tier-data",
      "preview-content"
    ]
  }
}
