{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "status-bar",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Status Bar",
  "description": "Terminal-style status line with real-time indicators, mode display, and clickable sections.",
  "dependencies": {
    "patterns": {},
    "recipes": {
      "terminal": "^1.0.0"
    },
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "icon"
  ],
  "default_preset": "bottom",
  "presets": {
    "top": {
      "description": "Status bar at top of screen (title bar style)",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "flex",
        "atoms": "_flex _aic _jcsb _px2 _mono _textsm _h[24px]",
        "slots": {
          "left": "App name, version, mode",
          "center": "Current file/context",
          "right": "Time, status indicators"
        }
      }
    },
    "bottom": {
      "description": "Status bar at bottom of screen (vim style)",
      "components": [
        "icon"
      ],
      "layout": {
        "layout": "flex",
        "atoms": "_flex _aic _jcsb _px2 _mono _textsm _h[24px] _bgmuted",
        "slots": {
          "left": "Mode, file info",
          "center": "Optional center content",
          "right": "Position, encoding, status"
        }
      }
    }
  },
  "default_layout": {
    "layout": "flex",
    "atoms": "_flex _aic _jcsb _px2 _mono _textsm _h[24px]",
    "slots": {
      "left": "Left-aligned items",
      "center": "Center-aligned items",
      "right": "Right-aligned items"
    }
  },
  "features": [
    "realtime-updates",
    "color-coded-status",
    "click-actions",
    "tooltip-hover"
  ]
}
