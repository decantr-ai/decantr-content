{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "activity-feed",
  "version": "1.0.0",
  "decantr_compat": ">=0.9.0",
  "name": "Activity Feed",
  "description": "Chronological list of activity events with avatars, timestamps, and action descriptions",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Avatar",
        "Badge",
        "Button",
        "Separator",
        "ScrollArea",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Avatar",
    "Badge",
    "Button"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Vertical timeline with avatar, user name, action text, timestamp. Grouped by date.",
      "components": [
        "Avatar",
        "Badge",
        "Button",
        "Separator",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap2 _w[100%]",
        "slots": {
          "date-header": "Date group separator with _textsm _fgmuted _fontmedium",
          "feed-item": "Single activity row: _flex _row _gap3 _items[start]",
          "avatar": "User Avatar with fallback initials",
          "content": "Action text with user name (_fontmedium) and description",
          "timestamp": "Relative time label with _textsm _fgmuted",
          "load-more": "Button at bottom to load older activities"
        }
      }
    },
    "compact": {
      "description": "Dense list without avatars, just icon + text + relative time",
      "components": [
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap1 _w[100%]",
        "slots": {
          "feed-item": "Compact row: _flex _row _gap2 _aic",
          "icon": "Small type icon indicator",
          "content": "Action text in single line, truncated",
          "timestamp": "Relative time, right-aligned"
        }
      }
    },
    "detailed": {
      "description": "Each activity is a mini-card with full context, attachments, and reply option",
      "components": [
        "Avatar",
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "column",
        "atoms": "_flex _col _gap4 _w[100%]",
        "slots": {
          "feed-card": "Activity card: _flex _col _gap2 _p4 _r3 _border _border[var(--border)]",
          "card-header": "Avatar + user + timestamp row",
          "card-body": "Full action description and optional attachment preview",
          "card-actions": "Reply, Like, Share action Buttons"
        }
      }
    }
  },
  "default_layout": {
    "layout": "column",
    "atoms": "_flex _col _gap2 _w[100%]",
    "slots": {
      "date-header": "Date group separator with _textsm _fgmuted _fontmedium",
      "feed-item": "Single activity row: _flex _row _gap3 _items[start]",
      "avatar": "User Avatar with fallback initials",
      "content": "Action text with user name and description",
      "timestamp": "Relative time label",
      "load-more": "Button at bottom to load older activities"
    }
  },
  "io": {
    "consumes": [
      "search",
      "view",
      "filters"
    ],
    "produces": [],
    "actions": [
      "load-more",
      "mark-read"
    ]
  }
}
