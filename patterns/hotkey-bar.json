{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "hotkey-bar",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Hotkey Bar",
  "description": "Function key shortcut bar inspired by DOS/Norton Commander style interfaces.",
  "dependencies": {
    "patterns": {},
    "styles": {
      "terminal": "^1.0.0"
    },
    "requires_core": {
      "components": [],
      "charts": []
    }
  },
  "components": [],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "F1-F10 function key bar",
      "components": [],
      "layout": {
        "layout": "flex",
        "atoms": "_flex _aic _jcsb _px1 _mono _textsm _h[28px] _bgmuted",
        "slots": {
          "keys": "Array of F1-F10 hotkey bindings"
        }
      }
    },
    "extended": {
      "description": "F1-F12 extended function key bar",
      "components": [],
      "layout": {
        "layout": "flex",
        "atoms": "_flex _aic _jcsb _px1 _mono _textsm _h[28px] _bgmuted",
        "slots": {
          "keys": "Array of F1-F12 hotkey bindings"
        }
      }
    },
    "custom": {
      "description": "Custom key bindings with modifiers",
      "components": [],
      "layout": {
        "layout": "flex",
        "atoms": "_flex _aic _gap4 _px2 _mono _textsm _h[28px] _bgmuted",
        "slots": {
          "keys": "Custom key bindings with labels"
        }
      }
    }
  },
  "default_layout": {
    "layout": "flex",
    "atoms": "_flex _aic _jcsb _px1 _mono _textsm _h[28px]",
    "slots": {
      "keys": "Hotkey bindings"
    }
  },
  "features": [
    "click-activate",
    "keyboard-trigger",
    "disabled-state",
    "active-pressed-state"
  ]
}
