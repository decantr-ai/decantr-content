{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "tenant-directory",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Tenant Directory",
  "description": "All tenants list with search, filters, bulk actions, and summary stats. Supports card and table views.",
  "dependencies": {
    "patterns": {
      "tenant-card": "^1.0.0"
    },
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Input",
        "Select",
        "Badge"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Input",
    "Select",
    "Badge"
  ],
  "default_preset": "table",
  "presets": {
    "table": {
      "description": "Detailed table view of tenants",
      "components": [
        "Button",
        "icon",
        "Input",
        "Select",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title, add tenant button",
          "summary": "Total tenants, active, past due counts",
          "filters": "Search, status filter, property filter, lease expiring filter",
          "table": "Tenant table with sortable columns",
          "pagination": "Page controls"
        }
      }
    },
    "cards": {
      "description": "Card grid of tenants",
      "components": [
        "Button",
        "icon",
        "Input"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title and controls",
          "filters": "Search and filters",
          "grid": "Tenant cards"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "header": "Title and add button",
      "summary": "Stats",
      "filters": "Search and filters",
      "items": "Tenant cards or rows",
      "pagination": "Page controls"
    }
  }
}
