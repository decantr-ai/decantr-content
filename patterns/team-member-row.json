{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "team-member-row",
  "version": "1.0.0",
  "decantr_compat": ">=0.9.0",
  "name": "Team Member Row",
  "description": "Team member display row with avatar, name, email, role badge, join date, and management actions (change role, remove).",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Avatar",
        "Badge",
        "Button",
        "Select",
        "icon"
      ],
      "charts": []
    }
  },
  "contained": false,
  "components": [
    "Avatar",
    "Badge",
    "Button",
    "Select",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full team member row with avatar, name, email, role badge, joined date, and role-change/remove actions.",
      "components": [
        "Avatar",
        "Badge",
        "Button",
        "Select",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap4 _px4 _py4 _borderb _bordermuted/10",
        "slots": {
          "avatar": "Team member Avatar, medium size",
          "identity": "Name (_textsm _fontmedium) and email (_textxs _fgmuted) stacked",
          "role": "Role Badge (owner=primary, admin=secondary, member=outline)",
          "joined": "Join date with _textxs _fgmuted",
          "actions": "Role Select dropdown and Remove Button"
        }
      }
    },
    "card": {
      "description": "Card-style team member for grid layouts. Avatar centered, name below, role badge, and actions.",
      "components": [
        "Avatar",
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _aic _gap3 _p4 _border _bordermuted/20 _r3 _tc",
        "slots": {
          "avatar": "Large centered Avatar",
          "name": "Member name with _textsm _fontmedium",
          "email": "Email with _textxs _fgmuted",
          "role": "Role Badge centered",
          "actions": "Action buttons row"
        }
      }
    },
    "invite": {
      "description": "Pending invitation row showing email, invited-by, expiry, and resend/cancel actions.",
      "components": [
        "Badge",
        "Button",
        "icon"
      ],
      "layout": {
        "layout": "row",
        "atoms": "_flex _aic _gap4 _px4 _py3 _borderb _bordermuted/10 _bgmuted/5",
        "slots": {
          "icon": "Mail icon for pending invite",
          "email": "Invitee email with _textsm",
          "status": "Pending Badge with expiry date",
          "actions": "Resend and cancel Buttons"
        }
      }
    }
  },
  "default_layout": {
    "layout": "row",
    "atoms": "_flex _aic _gap4 _px4 _py4 _borderb _bordermuted/10",
    "slots": {
      "avatar": "Member Avatar",
      "identity": "Name and email",
      "role": "Role badge",
      "joined": "Join date",
      "actions": "Management actions"
    }
  }
}
