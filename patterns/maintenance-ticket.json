{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "maintenance-ticket",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Maintenance Ticket",
  "description": "Repair request form and display. Supports create (tenant-facing), view, and edit modes with photo upload and status tracking.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select",
        "Textarea"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Input",
    "Select",
    "Textarea"
  ],
  "default_preset": "view",
  "presets": {
    "create": {
      "description": "New ticket form (tenant-facing)",
      "components": [
        "Button",
        "icon",
        "Select",
        "Textarea"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title",
          "property-unit": "Auto-filled for tenant",
          "category": "Issue category dropdown",
          "priority": "Priority level",
          "description": "Issue description textarea",
          "photos": "Photo upload",
          "availability": "Preferred access times",
          "submit": "Submit button"
        }
      }
    },
    "view": {
      "description": "Ticket details view",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Ticket ID, status badge",
          "details": "Category, priority, description",
          "photos": "Attached images",
          "timeline": "Status updates, comments",
          "assignment": "Assigned vendor/staff",
          "resolution": "Resolution notes, completion date",
          "actions": "Update status, assign, close"
        }
      }
    },
    "edit": {
      "description": "Edit ticket (owner-facing)",
      "components": [
        "Button",
        "icon",
        "Select",
        "Textarea"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "form": "Edit fields",
          "assignment": "Assign to vendor",
          "notes": "Internal notes",
          "actions": "Save/cancel"
        }
      }
    },
    "recent": {
      "description": "Recent tickets list for dashboard",
      "components": [
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap2",
        "slots": {
          "items": "Recent ticket rows"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "header": "Ticket header",
      "details": "Ticket details",
      "timeline": "Status timeline",
      "actions": "Actions"
    }
  }
}
