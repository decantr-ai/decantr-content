{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "maintenance-ticket",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Maintenance Ticket",
  "description": "Repair request form and display. Supports create (tenant-facing), view, and edit modes with photo upload and status tracking.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select",
        "Textarea"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Input",
    "Select",
    "Textarea"
  ],
  "default_preset": "view",
  "presets": {
    "create": {
      "description": "New ticket form (tenant-facing)",
      "components": [
        "Button",
        "icon",
        "Select",
        "Textarea"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Title",
          "property-unit": "Auto-filled for tenant",
          "category": "Issue category dropdown",
          "priority": "Priority level",
          "description": "Issue description textarea",
          "photos": "Photo upload",
          "availability": "Preferred access times",
          "submit": "Submit button"
        }
      }
    },
    "view": {
      "description": "Ticket details view",
      "components": [
        "Button",
        "icon",
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "header": "Ticket ID, status badge",
          "details": "Category, priority, description",
          "photos": "Attached images",
          "timeline": "Status updates, comments",
          "assignment": "Assigned vendor/staff",
          "resolution": "Resolution notes, completion date",
          "actions": "Update status, assign, close"
        }
      }
    },
    "edit": {
      "description": "Edit ticket (owner-facing)",
      "components": [
        "Button",
        "icon",
        "Select",
        "Textarea"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap4",
        "slots": {
          "form": "Edit fields",
          "assignment": "Assign to vendor",
          "notes": "Internal notes",
          "actions": "Save/cancel"
        }
      }
    },
    "recent": {
      "description": "Recent tickets list for dashboard",
      "components": [
        "Badge"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap2",
        "slots": {
          "items": "Recent ticket rows"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap4",
    "slots": {
      "header": "Ticket header",
      "details": "Ticket details",
      "timeline": "Status timeline",
      "actions": "Actions"
    }
  },
  "visual_brief": "Ticket detail view with a header showing ticket ID, title, status badge (color-coded), and priority badge. The details section displays property, unit, category (plumbing, electrical, etc.), reporter name, and description text. A photo section shows uploaded images in a small gallery grid. A status timeline tracks the ticket lifecycle with timestamped entries (submitted, assigned, in-progress, completed). The create preset shows a form with title, category select, priority select, description textarea, and photo upload area. Action buttons include Assign, Update Status, and Close.",
  "responsive": {
    "mobile": "Single-column stacked layout. Photo gallery uses horizontal scroll. Timeline is vertical. Action buttons are full-width at the bottom.",
    "tablet": "Standard layout with comfortable spacing. Photo gallery shows 2-3 thumbnails per row.",
    "desktop": "Full layout with details and timeline side by side. Photo gallery in a grid. All actions visible in a toolbar."
  }
}
