{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "storefront-hero",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Storefront Hero",
  "description": "Creator landing page banner with cover image, avatar, bio, social links, and subscribe CTA. The first impression for fans.",
  "dependencies": {
    "patterns": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "Avatar",
        "Badge",
        "icon"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "Avatar",
    "Badge",
    "icon"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full hero with cover image and all details",
      "components": [
        "Button",
        "Avatar",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col",
        "slots": {
          "cover": "Banner/cover image area",
          "avatar": "Creator profile photo",
          "name": "Creator display name with verification badge",
          "tagline": "Short bio/description",
          "social": "Social media links",
          "stats": "Subscriber count, post count",
          "cta": "Primary subscribe button"
        }
      }
    },
    "minimal": {
      "description": "Compact header-style hero",
      "components": [
        "Button",
        "Avatar",
        "icon"
      ],
      "layout": {
        "layout": "inline",
        "atoms": "_flex _aic _gap4 _p4 _borderB",
        "slots": {
          "avatar": "Small avatar",
          "name": "Creator name",
          "cta": "Subscribe button"
        }
      }
    },
    "video": {
      "description": "Video background hero",
      "components": [
        "Button",
        "Avatar",
        "Badge",
        "icon"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _relative",
        "slots": {
          "video": "Background video",
          "overlay": "Content overlay",
          "avatar": "Creator avatar",
          "content": "Name, bio, CTA"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col",
    "slots": {
      "cover": "Cover image",
      "avatar": "Creator avatar",
      "content": "Name, bio, stats",
      "cta": "Subscribe action"
    }
  },
  "io": {
    "produces": [
      "subscribe-click",
      "share-click"
    ],
    "consumes": [
      "creator-data"
    ]
  }
}
