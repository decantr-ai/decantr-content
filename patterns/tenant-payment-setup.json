{
  "$schema": "https://decantr.ai/schemas/pattern.v2.json",
  "id": "tenant-payment-setup",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Tenant Payment Setup",
  "description": "Tenant autopay configuration with payment method management, ACH/card setup, autopay toggle, and upcoming payment preview.",
  "dependencies": {
    "patterns": {},
    "recipes": {},
    "styles": {},
    "requires_core": {
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select"
      ],
      "charts": []
    }
  },
  "components": [
    "Button",
    "icon",
    "Badge",
    "Input",
    "Select"
  ],
  "default_preset": "standard",
  "presets": {
    "standard": {
      "description": "Full payment setup view",
      "components": [
        "Button",
        "icon",
        "Badge",
        "Input",
        "Select"
      ],
      "layout": {
        "layout": "stack",
        "atoms": "_flex _col _gap6",
        "slots": {
          "header": "Title, autopay status indicator",
          "current-method": "Current payment method summary",
          "methods": "Saved payment methods list",
          "add-method": "Add bank account or card form",
          "autopay-settings": "Autopay toggle, day of month",
          "schedule": "Upcoming payments preview"
        }
      }
    }
  },
  "default_layout": {
    "layout": "stack",
    "atoms": "_flex _col _gap6",
    "slots": {
      "autopay": "Autopay settings",
      "methods": "Payment methods",
      "upcoming": "Upcoming payments"
    }
  }
}
