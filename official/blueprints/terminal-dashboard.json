{
  "$schema": "decantr-vignette-v1.0",
  "id": "terminal-dashboard",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Terminal Dashboard",
  "description": "CLI-style terminal dashboard for developer tools. Retro-modern terminal aesthetic with phosphor green/amber, ASCII borders, split panes, and optional CRT effects. Dark mode only.",
  "tags": [
    "terminal",
    "cli",
    "developer",
    "dashboard",
    "monitoring",
    "retro"
  ],
  "compose": [
    "terminal-home",
    "log-viewer",
    "metrics-monitor",
    "config-editor",
    "marketing-devtool",
    "auth-full",
    "legal"
  ],
  "theme": {
    "style": "terminal",
    "mode": "dark",
    "recipe": "terminal",
    "shape": "sharp"
  },
  "personality": [
    "technical",
    "retro",
    "focused",
    "immersive"
  ],
  "overrides": {
    "pages": {},
    "pages_remove": [],
    "features_add": [
      "keyboard-shortcuts",
      "command-palette"
    ],
    "features_remove": [
      "theme-toggle"
    ]
  },
  "dependencies": {
    "archetypes": {
      "terminal-home": "^1.0.0",
      "log-viewer": "^1.0.0",
      "metrics-monitor": "^1.0.0",
      "config-editor": "^1.0.0",
      "marketing-devtool": "^1.0.0",
      "auth-full": "^1.0.0",
      "legal": "^1.0.0"
    },
    "recipes": {
      "terminal": "^1.0.0"
    },
    "styles": {
      "terminal": "^1.0.0"
    }
  },
  "features": [
    "auth",
    "logging",
    "metrics",
    "config",
    "keyboard-shortcuts",
    "split-panes",
    "command-palette",
    "hotkeys"
  ],
  "routes": {
    "/": {
      "shell": "top-nav-footer",
      "archetype": "marketing-devtool",
      "page": "home"
    },
    "/docs": {
      "shell": "top-nav-footer",
      "archetype": "marketing-devtool",
      "page": "docs"
    },
    "/privacy": {
      "shell": "top-nav-footer",
      "archetype": "legal",
      "page": "privacy"
    },
    "/terms": {
      "shell": "top-nav-footer",
      "archetype": "legal",
      "page": "terms"
    },
    "/login": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "login"
    },
    "/register": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "register"
    },
    "/app": {
      "shell": "terminal-split",
      "archetype": "terminal-home",
      "page": "home"
    },
    "/app/logs": {
      "shell": "terminal-split",
      "archetype": "log-viewer",
      "page": "logs"
    },
    "/app/logs/grouped": {
      "shell": "terminal-split",
      "archetype": "log-viewer",
      "page": "grouped"
    },
    "/app/metrics": {
      "shell": "terminal-split",
      "archetype": "metrics-monitor",
      "page": "metrics"
    },
    "/app/metrics/:id": {
      "shell": "terminal-split",
      "archetype": "metrics-monitor",
      "page": "detail"
    },
    "/app/config": {
      "shell": "terminal-split",
      "archetype": "config-editor",
      "page": "config"
    },
    "/app/config/diff": {
      "shell": "terminal-split",
      "archetype": "config-editor",
      "page": "diff"
    }
  },
  "navigation": {
    "hotkeys": [
      { "key": "F1", "route": "/app", "label": "Home" },
      { "key": "F2", "route": "/app/config", "label": "Config" },
      { "key": "F3", "route": "/app/logs", "label": "Logs" },
      { "key": "F4", "route": "/app/metrics", "label": "Metrics" },
      { "key": "F10", "action": "logout", "label": "Quit" }
    ],
    "command_palette": true
  },
  "seo_hints": {
    "schema_org": ["Organization", "WebApplication", "SoftwareApplication"],
    "meta_priorities": ["description", "og:image", "twitter:card"]
  },
  "design_constraints": {
    "mode": "dark_only",
    "typography": "monospace_only",
    "borders": "ascii_box_drawing",
    "corners": "sharp_only",
    "shadows": "none",
    "effects": {
      "glow": "optional",
      "scanlines": "optional",
      "flicker": "disabled"
    }
  }
}
