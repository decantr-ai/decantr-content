{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "marketing-saas",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Marketing SaaS",
  "description": "SaaS marketing landing page with hero, features, how-it-works timeline, pricing, testimonials, and CTA sections.",
  "tags": [
    "marketing",
    "saas",
    "landing",
    "pricing",
    "features"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "saas landing",
        "marketing page",
        "product landing",
        "pricing page"
      ],
      "secondary": [
        "features",
        "testimonials",
        "how it works",
        "call to action"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "home",
      "patterns": [
        {
          "pattern": "hero",
          "preset": "brand",
          "as": "hero"
        },
        {
          "pattern": "card-grid",
          "preset": "feature",
          "as": "features"
        },
        {
          "pattern": "timeline",
          "preset": "steps",
          "as": "how-it-works"
        },
        {
          "pattern": "pricing-usage",
          "preset": "standard",
          "as": "pricing"
        },
        {
          "pattern": "card-grid",
          "preset": "testimonial",
          "as": "testimonials"
        },
        {
          "pattern": "cta-banner",
          "preset": "standard",
          "as": "cta"
        }
      ],
      "default_layout": [
        "hero",
        "features",
        "how-it-works",
        "pricing",
        "testimonials",
        "cta"
      ],
      "shell": "top-nav-footer"
    }
  ],
  "features": [
    "pricing-toggle",
    "testimonials",
    "feature-grid"
  ],
  "shells": {
    "top-nav-footer": "Top navigation with hero and footer for marketing pages"
  },
  "dependencies": {
    "patterns": {
      "hero": "^1.0.0",
      "card-grid": "^1.0.0",
      "timeline": "^1.0.0",
      "pricing-usage": "^1.0.0",
      "cta-banner": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "carbon"
    ],
    "modes": [
      "dark",
      "light"
    ]
  }
}
