{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "terminal-home",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Terminal Home",
  "description": "Main terminal dashboard view with split panes, log streaming, metrics, and command input. Core interface for CLI-style developer tools.",
  "tags": [
    "terminal",
    "dashboard",
    "developer",
    "cli",
    "monitoring"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "terminal dashboard",
        "cli interface",
        "dev tool",
        "command line",
        "terminal ui"
      ],
      "secondary": [
        "log viewer",
        "system monitor",
        "devops dashboard",
        "tui"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "home",
      "patterns": [
        {
          "pattern": "status-bar",
          "preset": "top",
          "as": "status"
        },
        {
          "pattern": "split-pane",
          "preset": "horizontal",
          "as": "main-split"
        },
        {
          "pattern": "log-stream",
          "preset": "standard",
          "as": "logs"
        },
        {
          "pattern": "metric-gauge",
          "preset": "grid",
          "as": "metrics"
        },
        {
          "pattern": "terminal-emulator",
          "preset": "standard",
          "as": "terminal"
        },
        {
          "pattern": "hotkey-bar",
          "preset": "standard",
          "as": "hotkeys"
        },
        {
          "pattern": "command-palette",
          "preset": "standard",
          "as": "palette"
        },
        {
          "pattern": "help-modal",
          "preset": "standard",
          "as": "help"
        }
      ],
      "default_layout": [
        "status",
        "main-split",
        "hotkeys"
      ],
      "shell": "terminal-split"
    }
  ],
  "features": [
    "split-panes",
    "log-streaming",
    "metrics",
    "command-input",
    "keyboard-shortcuts",
    "command-palette"
  ],
  "shells": {
    "terminal-split": "Terminal layout with status bar, resizable split panes, and hotkey bar"
  },
  "dependencies": {
    "patterns": {
      "status-bar": "^1.0.0",
      "split-pane": "^1.0.0",
      "log-stream": "^1.0.0",
      "metric-gauge": "^1.0.0",
      "terminal-emulator": "^1.0.0",
      "hotkey-bar": "^1.0.0",
      "command-palette": "^1.0.0",
      "help-modal": "^1.0.0"
    },
    "recipes": {
      "terminal": "^1.0.0"
    },
    "styles": {
      "terminal": "^1.0.0"
    }
  },
  "suggested_theme": {
    "styles": [
      "terminal"
    ],
    "modes": [
      "dark"
    ]
  }
}
