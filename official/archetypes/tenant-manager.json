{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "tenant-manager",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Tenant Manager",
  "description": "Tenant management screens including directory, detail view with lease and payment history, and tenant onboarding.",
  "tags": [
    "property-management",
    "tenants",
    "real-estate",
    "leases",
    "crm"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "tenant management",
        "tenant list",
        "tenant directory",
        "lease management"
      ],
      "secondary": [
        "add tenant",
        "tenant profile",
        "tenant crm"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "list",
      "patterns": [
        {
          "pattern": "tenant-directory",
          "preset": "table",
          "as": "directory"
        }
      ],
      "default_layout": [
        "directory"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "detail",
      "patterns": [
        {
          "pattern": "tenant-card",
          "preset": "standard",
          "as": "profile"
        },
        {
          "pattern": "lease-manager",
          "preset": "overview",
          "as": "lease"
        },
        {
          "pattern": "payment-history",
          "preset": "tenant",
          "as": "payments"
        }
      ],
      "default_layout": [
        "profile",
        "lease",
        "payments"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "create",
      "patterns": [
        {
          "pattern": "tenant-card",
          "preset": "standard",
          "as": "form"
        },
        {
          "pattern": "lease-manager",
          "preset": "edit",
          "as": "lease-form"
        }
      ],
      "default_layout": [
        "form",
        "lease-form"
      ],
      "shell": "sidebar-main"
    }
  ],
  "features": [
    "crud",
    "search",
    "filters",
    "communication"
  ],
  "shells": {
    "sidebar-main": "Sidebar navigation for tenant management"
  },
  "dependencies": {
    "patterns": {
      "tenant-directory": "^1.0.0",
      "tenant-card": "^1.0.0",
      "lease-manager": "^1.0.0",
      "payment-history": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "estate"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
