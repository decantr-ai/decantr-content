{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "legal",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Legal",
  "description": "Legal pages including privacy policy, terms of service, and cookie policy with sticky TOC and print-friendly layout.",
  "tags": [
    "legal",
    "privacy",
    "terms",
    "cookies",
    "policy"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "legal pages",
        "privacy policy",
        "terms of service",
        "cookie policy"
      ],
      "secondary": [
        "tos",
        "legal",
        "compliance"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "privacy",
      "patterns": [
        {
          "pattern": "legal-prose",
          "preset": "privacy",
          "as": "content"
        }
      ],
      "default_layout": [
        "content"
      ],
      "shell": "top-nav-footer"
    },
    {
      "id": "terms",
      "patterns": [
        {
          "pattern": "legal-prose",
          "preset": "terms",
          "as": "content"
        }
      ],
      "default_layout": [
        "content"
      ],
      "shell": "top-nav-footer"
    },
    {
      "id": "cookies",
      "patterns": [
        {
          "pattern": "legal-prose",
          "preset": "cookies",
          "as": "content"
        }
      ],
      "default_layout": [
        "content"
      ],
      "shell": "top-nav-footer"
    }
  ],
  "features": [
    "toc-navigation",
    "print-friendly",
    "smooth-scroll"
  ],
  "shells": {
    "top-nav-footer": "Standard page layout with navigation and footer"
  },
  "dependencies": {
    "patterns": {
      "legal-prose": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "carbon"
    ],
    "modes": [
      "dark",
      "light"
    ]
  }
}
