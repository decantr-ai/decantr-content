{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "tenant-portal",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Tenant Portal",
  "description": "Tenant self-service portal home with lease summary, rent reminders, recent maintenance tickets, and quick actions.",
  "tags": [
    "property-management",
    "tenant",
    "self-service",
    "portal",
    "real-estate"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "tenant portal",
        "tenant self-service",
        "renter portal",
        "tenant home"
      ],
      "secondary": [
        "tenant dashboard",
        "renter dashboard"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "home",
      "patterns": [
        {
          "pattern": "tenant-card",
          "preset": "self",
          "as": "profile"
        },
        {
          "pattern": "rent-reminder",
          "preset": "upcoming",
          "as": "rent-reminder"
        },
        {
          "pattern": "lease-manager",
          "preset": "summary",
          "as": "lease"
        },
        {
          "pattern": "maintenance-ticket",
          "preset": "recent",
          "as": "maintenance"
        }
      ],
      "default_layout": [
        "rent-reminder",
        "profile",
        "lease",
        "maintenance"
      ],
      "shell": "top-nav-main"
    },
    {
      "id": "maintenance",
      "patterns": [
        {
          "pattern": "maintenance-ticket",
          "preset": "create",
          "as": "form"
        }
      ],
      "default_layout": [
        "form"
      ],
      "shell": "top-nav-main"
    },
    {
      "id": "documents",
      "patterns": [
        {
          "pattern": "document-vault",
          "preset": "tenant",
          "as": "documents"
        }
      ],
      "default_layout": [
        "documents"
      ],
      "shell": "top-nav-main"
    }
  ],
  "features": [
    "self-service",
    "file-upload",
    "notifications"
  ],
  "shells": {
    "top-nav-main": "Simple top navigation for tenant self-service"
  },
  "dependencies": {
    "patterns": {
      "tenant-card": "^1.0.0",
      "rent-reminder": "^1.0.0",
      "lease-manager": "^1.0.0",
      "maintenance-ticket": "^1.0.0",
      "document-vault": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "estate"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
