{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "about-hybrid",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "About Hybrid",
  "description": "About page combining hero, company story, team grid, values, and call-to-action sections.",
  "tags": [
    "about",
    "company",
    "team",
    "values",
    "story"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "about us",
        "about page",
        "company info",
        "team page"
      ],
      "secondary": [
        "our story",
        "our team",
        "our values",
        "mission"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "recommended"
  },
  "pages": [
    {
      "id": "about",
      "patterns": [
        {
          "pattern": "hero",
          "preset": "split",
          "as": "hero"
        },
        {
          "pattern": "prose-section",
          "preset": "story",
          "as": "story"
        },
        {
          "pattern": "card-grid",
          "preset": "team",
          "as": "team"
        },
        {
          "pattern": "card-grid",
          "preset": "values",
          "as": "values"
        },
        {
          "pattern": "cta-section",
          "preset": "standard",
          "as": "cta"
        }
      ],
      "default_layout": [
        "hero",
        "story",
        "team",
        "values",
        "cta"
      ],
      "shell": "top-nav-footer"
    }
  ],
  "features": [
    "team-grid",
    "values-display"
  ],
  "shells": {
    "top-nav-footer": "Standard marketing page layout with nav and footer"
  },
  "dependencies": {
    "patterns": {
      "hero": "^1.0.0",
      "prose-section": "^1.0.0",
      "card-grid": "^1.0.0",
      "cta-section": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "carbon"
    ],
    "modes": [
      "dark",
      "light"
    ]
  }
}
