{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "property-manager",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Property Manager",
  "description": "Property CRUD and management screens including property list, detail view, create/edit forms, and unit management.",
  "tags": [
    "property-management",
    "crud",
    "real-estate",
    "properties",
    "units"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "property management",
        "property list",
        "property details",
        "unit management"
      ],
      "secondary": [
        "add property",
        "edit property",
        "property crud"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "list",
      "patterns": [
        {
          "pattern": "property-grid",
          "preset": "cards",
          "as": "grid"
        }
      ],
      "default_layout": [
        "grid"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "detail",
      "patterns": [
        {
          "pattern": "property-detail",
          "preset": "view",
          "as": "detail"
        }
      ],
      "default_layout": [
        "detail"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "create",
      "patterns": [
        {
          "pattern": "property-detail",
          "preset": "create",
          "as": "form"
        }
      ],
      "default_layout": [
        "form"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "units",
      "patterns": [
        {
          "pattern": "unit-list",
          "preset": "grid",
          "as": "units"
        }
      ],
      "default_layout": [
        "units"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "unit-detail",
      "patterns": [
        {
          "pattern": "unit-detail",
          "preset": "view",
          "as": "unit"
        }
      ],
      "default_layout": [
        "unit"
      ],
      "shell": "sidebar-main"
    }
  ],
  "features": [
    "crud",
    "file-upload",
    "search",
    "filters"
  ],
  "shells": {
    "sidebar-main": "Sidebar navigation for property management"
  },
  "dependencies": {
    "patterns": {
      "property-grid": "^1.0.0",
      "property-detail": "^1.0.0",
      "property-card": "^1.0.0",
      "unit-list": "^1.0.0",
      "unit-detail": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "estate"
    ],
    "modes": [
      "light",
      "dark"
    ]
  }
}
