{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "dashboard-core",
  "version": "1.0.0",
  "decantr_compat": ">=0.10.0",
  "name": "Dashboard Core",
  "description": "Overview and analytics pages with KPIs, charts, and data tables",
  "tags": [
    "dashboard",
    "overview",
    "analytics",
    "kpi",
    "metrics",
    "charts"
  ],
  "classification": {
    "triggers": {
      "primary": [
        "dashboard",
        "overview",
        "analytics",
        "KPI",
        "metrics"
      ],
      "secondary": [
        "charts",
        "reports",
        "data visualization",
        "monitoring"
      ],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "overview",
      "default_layout": [
        "kpi-grid",
        "chart-grid",
        "activity-feed"
      ],
      "shell": "sidebar-main"
    },
    {
      "id": "analytics",
      "default_layout": [
        "filter-bar",
        "data-table"
      ],
      "shell": "sidebar-main"
    }
  ],
  "features": [
    "analytics-state"
  ],
  "shells": {
    "sidebar-main": "Sidebar navigation with main content area"
  },
  "dependencies": {
    "patterns": {
      "kpi-grid": "^1.0.0",
      "chart-grid": "^1.0.0",
      "data-table": "^1.0.0",
      "filter-bar": "^1.0.0",
      "activity-feed": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_theme": {
    "styles": [
      "auradecantism",
      "clean"
    ],
    "modes": [
      "dark",
      "auto"
    ]
  }
}
