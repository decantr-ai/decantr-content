{
  "$schema": "decantr-vignette-v1.0",
  "id": "registry-platform",
  "version": "1.0.0",
  "decantr_compat": ">=0.10.0",
  "name": "Registry Platform",
  "description": "Content registry with browsing, publishing, user management, team collaboration, and admin moderation. Dogfooded UI for the Decantr design intelligence platform.",
  "tags": [
    "registry",
    "platform",
    "dashboard",
    "content-management",
    "moderation",
    "billing"
  ],
  "compose": [
    "registry-browser",
    "user-dashboard",
    "content-editor",
    "admin-moderation",
    "team-management",
    "billing-portal"
  ],
  "theme": {
    "mode": "dark",
    "shape": "pill",
    "id": "luminarum"
  },
  "personality": "Technical, developer-oriented registry platform with a dark premium aesthetic. Content cards display pattern/theme previews with metadata (version, downloads, compatibility). Search is instant with faceted filters. Publishing workflow is clear and step-by-step. Admin moderation views are dense and action-oriented. Billing portal is clean and transparent. The Decantr dogfood app — built with its own system, showcasing what the platform produces. Think npm registry meets Figma Community.",
  "voice": {
    "tone": "Technical and developer-friendly. Uses correct design-system terminology. Precise about versions and compatibility.",
    "cta_verbs": [
      "Publish",
      "Install",
      "Browse",
      "Search",
      "Preview",
      "Fork"
    ],
    "avoid": [
      "Submit",
      "Click here",
      "Please enter",
      "Buy now",
      "Amazing"
    ],
    "empty_states": "Developer-friendly and constructive. An empty published items list should link to the publishing guide. Search with no results should suggest broadening filters.",
    "errors": "Precise and technical. Include error codes and affected resource identifiers. Validation errors should quote the failing field and expected format.",
    "loading": "Content card skeletons with code-block placeholders. Search results show filter sidebar while results stream in. Registry stats use counter animations."
  },
  "overrides": {},
  "dependencies": {
    "archetypes": {
      "registry-browser": "^1.0.0",
      "user-dashboard": "^1.0.0",
      "content-editor": "^1.0.0",
      "admin-moderation": "^1.0.0",
      "team-management": "^1.0.0",
      "billing-portal": "^1.0.0"
    }
  },
  "seo_hints": {
    "schema_org": [
      "WebApplication",
      "SoftwareApplication"
    ],
    "meta_priorities": [
      "description",
      "og:image",
      "twitter:card"
    ]
  },
  "features": [
    "search",
    "pagination",
    "auth",
    "api-keys",
    "validation",
    "admin",
    "team",
    "billing"
  ],
  "routes": {
    "/registry": {
      "shell": "topbar-main",
      "archetype": "registry-browser",
      "page": "registry"
    },
    "/registry/:type": {
      "shell": "topbar-main",
      "archetype": "registry-browser",
      "page": "registry-type"
    },
    "/registry/:type/:namespace/:slug": {
      "shell": "topbar-main",
      "archetype": "registry-browser",
      "page": "registry-detail"
    },
    "/dashboard": {
      "shell": "sidebar-main",
      "archetype": "user-dashboard",
      "page": "dashboard"
    },
    "/dashboard/content": {
      "shell": "sidebar-main",
      "archetype": "user-dashboard",
      "page": "dashboard-content"
    },
    "/dashboard/content/new": {
      "shell": "sidebar-main",
      "archetype": "content-editor",
      "page": "content-new"
    },
    "/dashboard/content/:id/edit": {
      "shell": "sidebar-main",
      "archetype": "content-editor",
      "page": "content-edit"
    },
    "/dashboard/api-keys": {
      "shell": "sidebar-main",
      "archetype": "user-dashboard",
      "page": "dashboard-api-keys"
    },
    "/dashboard/settings": {
      "shell": "sidebar-main",
      "archetype": "user-dashboard",
      "page": "dashboard-settings"
    },
    "/dashboard/team": {
      "shell": "sidebar-main",
      "archetype": "team-management",
      "page": "team-overview"
    },
    "/dashboard/team/members": {
      "shell": "sidebar-main",
      "archetype": "team-management",
      "page": "team-members"
    },
    "/dashboard/team/content": {
      "shell": "sidebar-main",
      "archetype": "team-management",
      "page": "team-content"
    },
    "/admin/moderation": {
      "shell": "sidebar-main",
      "archetype": "admin-moderation",
      "page": "moderation-queue"
    },
    "/admin/moderation/:id": {
      "shell": "sidebar-main",
      "archetype": "admin-moderation",
      "page": "moderation-detail"
    },
    "/dashboard/billing": {
      "shell": "sidebar-main",
      "archetype": "billing-portal",
      "page": "billing"
    }
  },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      {
        "key": "g r",
        "route": "/registry",
        "label": "Go to Registry"
      },
      {
        "key": "g d",
        "route": "/dashboard",
        "label": "Go to Dashboard"
      },
      {
        "key": "g c",
        "route": "/dashboard/content",
        "label": "Go to Content"
      },
      {
        "key": "g t",
        "route": "/dashboard/team",
        "label": "Go to Team"
      }
    ]
  }
}
