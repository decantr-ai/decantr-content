{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "multi-tenant-platform",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Multi-Tenant Platform",
  "description": "Enterprise-grade multi-tenant platform console with organization switching, API management, usage billing, webhooks, and audit logging. Built for trust and scale.",
  "tags": [
    "platform",
    "multi-tenant",
    "saas",
    "api",
    "billing",
    "enterprise",
    "2026"
  ],
  "compose": [
    "tenant-switcher-dashboard",
    "api-console",
    "usage-billing",
    "webhook-manager",
    "audit-center",
    "marketing-platform",
    "auth-flow-enterprise",
    "settings-full"
  ],
  "theme": {
    "mode": "dark",
    "shape": "rounded",
    "id": "launchpad"
  },
  "personality": "Enterprise-grade platform console built for trust and scale. Navy-to-violet gradient accents on clean white/dark surfaces. Organization switcher prominent in the top-left. Dense data tables with inline actions. API console feels like Stripe's — polished, developer-friendly. Billing shows clear usage breakdowns. Audit logs are prominent. Lucide icons. System sans with monospace for IDs, keys, and code.",
  "voice": {
    "tone": "Professional, developer-friendly. Assumes technical audience.",
    "cta_verbs": [
      "Create",
      "Configure",
      "Deploy",
      "Monitor",
      "Manage",
      "Explore"
    ],
    "avoid": [
      "Submit",
      "Click here",
      "Please enter",
      "Buy now",
      "Exciting"
    ],
    "empty_states": "Professional onboarding. Empty states guide users to create their first resource with clear documentation links. No whimsy.",
    "errors": "Precise and actionable. Include request IDs, error codes, and remediation steps. Link to API docs when relevant.",
    "loading": "Skeleton tables and card placeholders. Monospace fields show blinking cursors. Progress indicators for long operations."
  },
  "features": [
    "multi-tenancy",
    "api-management",
    "billing",
    "webhooks",
    "audit-logs",
    "auth",
    "sso",
    "marketing",
    "seo",
    "org-switching"
  ],
  "routes": {
    "/": {
      "page": "home",
      "shell": "top-nav-footer",
      "archetype": "marketing-platform"
    },
    "/docs": {
      "page": "docs",
      "shell": "top-nav-footer",
      "archetype": "marketing-platform"
    },
    "/login": {
      "page": "login",
      "shell": "centered",
      "archetype": "auth-flow-enterprise"
    },
    "/register": {
      "page": "register",
      "shell": "centered",
      "archetype": "auth-flow-enterprise"
    },
    "/sso": {
      "page": "sso",
      "shell": "centered",
      "archetype": "auth-flow-enterprise"
    },
    "/invite": {
      "page": "invite-accept",
      "shell": "centered",
      "archetype": "auth-flow-enterprise"
    },
    "/overview": {
      "page": "overview",
      "shell": "sidebar-main",
      "archetype": "tenant-switcher-dashboard"
    },
    "/members": {
      "page": "members",
      "shell": "sidebar-main",
      "archetype": "tenant-switcher-dashboard"
    },
    "/org-settings": {
      "page": "org-settings",
      "shell": "sidebar-main",
      "archetype": "tenant-switcher-dashboard"
    },
    "/api/docs": {
      "page": "api-docs",
      "shell": "sidebar-main",
      "archetype": "api-console"
    },
    "/api/keys": {
      "page": "api-keys",
      "shell": "sidebar-main",
      "archetype": "api-console"
    },
    "/api/webhooks": {
      "page": "webhooks",
      "shell": "sidebar-main",
      "archetype": "api-console"
    },
    "/usage": {
      "page": "usage",
      "shell": "sidebar-main",
      "archetype": "usage-billing"
    },
    "/billing": {
      "page": "billing",
      "shell": "sidebar-main",
      "archetype": "usage-billing"
    },
    "/invoices": {
      "page": "invoices",
      "shell": "sidebar-main",
      "archetype": "usage-billing"
    },
    "/webhooks": {
      "page": "endpoints",
      "shell": "sidebar-main",
      "archetype": "webhook-manager"
    },
    "/webhooks/:id": {
      "page": "endpoint-detail",
      "shell": "sidebar-main",
      "archetype": "webhook-manager"
    },
    "/audit": {
      "page": "audit-log",
      "shell": "sidebar-main",
      "archetype": "audit-center"
    },
    "/audit/settings": {
      "page": "audit-settings",
      "shell": "sidebar-main",
      "archetype": "audit-center"
    },
    "/settings/profile": {
      "page": "profile",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/security": {
      "page": "security",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/preferences": {
      "page": "preferences",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/danger": {
      "page": "danger",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    }
  },
  "overrides": {
    "features_add": [
      "theme-toggle",
      "command-palette"
    ],
    "features_remove": [],
    "pages": {},
    "pages_remove": []
  },
  "seo_hints": {
    "schema_org": [
      "Organization",
      "WebApplication",
      "SoftwareApplication"
    ],
    "meta_priorities": [
      "description",
      "og:image",
      "twitter:card"
    ]
  },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      {
        "key": "g o",
        "route": "/overview",
        "label": "Go to Overview"
      },
      {
        "key": "g a",
        "route": "/api/docs",
        "label": "Go to API Console"
      },
      {
        "key": "g b",
        "route": "/billing",
        "label": "Go to Billing"
      },
      {
        "key": "g u",
        "route": "/audit",
        "label": "Go to Audit Log"
      }
    ]
  },
  "dependencies": {
    "archetypes": {
      "tenant-switcher-dashboard": ">=1.0.0",
      "api-console": ">=1.0.0",
      "usage-billing": ">=1.0.0",
      "webhook-manager": ">=1.0.0",
      "audit-center": ">=1.0.0",
      "marketing-platform": ">=1.0.0",
      "auth-flow-enterprise": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": [
    "launchpad",
    "carbon",
    "government",
    "clean"
  ]
}
