{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "producer-studio",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Producer Studio",
  "description": "Electric music production workspace with multi-track DAW, stem library, collaboration hub, live session rooms, and full auth with marketing landing.",
  "tags": ["music", "production", "daw", "collaboration", "audio", "2026"],
  "compose": [
    "music-workspace",
    "track-library",
    "collaboration-hub",
    "session-rooms",
    "marketing-producer",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "dark",
    "shape": "rounded",
    "id": "studio-dark"
  },
  "personality": "Electric music production workspace with cyan waveforms pulsing across deep purple canvases. Multi-track DAW layout with stem-stack channel strips, meter bars glowing on transients, and automation lanes curving below. Split-royalty calculators with real-time percentage validation. Live session rooms with voice chat and collaborative scrubbing. Think Ableton meets Splice. Lucide icons. Electric.",
  "voice": {
    "tone": "Creative and technical. Speaks to producers and engineers.",
    "cta_verbs": ["Record", "Bounce", "Master", "Mix", "Collab", "Drop"],
    "avoid": ["Save", "Process"],
    "empty_states": "Empty session. Drop a stem or start from a preset.",
    "errors": "Bounce failed — clip {n} has no audio at {timestamp}",
    "loading": "Rendering stems... {percent}%"
  },
  "features": ["daw", "tracks", "collab", "sessions", "splits", "auth", "mfa", "oauth", "marketing", "seo"],
  "routes": {
    "/": { "page": "home", "shell": "top-nav-footer", "archetype": "marketing-producer" },
    "/login": { "page": "login", "shell": "centered", "archetype": "auth-full" },
    "/register": { "page": "register", "shell": "centered", "archetype": "auth-full" },
    "/forgot-password": { "page": "forgot-password", "shell": "centered", "archetype": "auth-full" },
    "/reset-password": { "page": "reset-password", "shell": "centered", "archetype": "auth-full" },
    "/verify-email": { "page": "verify-email", "shell": "centered", "archetype": "auth-full" },
    "/mfa-setup": { "page": "mfa-setup", "shell": "centered", "archetype": "auth-full" },
    "/mfa-verify": { "page": "mfa-verify", "shell": "centered", "archetype": "auth-full" },
    "/phone-verify": { "page": "phone-verify", "shell": "centered", "archetype": "auth-full" },
    "/session": { "page": "session", "shell": "sidebar-aside", "archetype": "music-workspace" },
    "/session/:id": { "page": "session-detail", "shell": "sidebar-aside", "archetype": "music-workspace" },
    "/tracks": { "page": "tracks", "shell": "sidebar-main", "archetype": "track-library" },
    "/tracks/:id": { "page": "track-detail", "shell": "sidebar-main", "archetype": "track-library" },
    "/collab": { "page": "collaborators", "shell": "sidebar-main", "archetype": "collaboration-hub" },
    "/collab/splits": { "page": "splits", "shell": "sidebar-main", "archetype": "collaboration-hub" },
    "/rooms": { "page": "rooms", "shell": "sidebar-main", "archetype": "session-rooms" },
    "/rooms/:id": { "page": "room-detail", "shell": "sidebar-main", "archetype": "session-rooms" },
    "/settings/profile": { "page": "profile", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/security": { "page": "security", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/preferences": { "page": "preferences", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/danger": { "page": "danger", "shell": "sidebar-aside", "archetype": "settings-full" }
  },
  "overrides": { "features_add": [], "features_remove": [], "pages": {}, "pages_remove": [] },
  "seo_hints": { "schema_org": ["Organization", "WebApplication"], "meta_priorities": ["description", "og:image"] },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      { "key": "g s", "route": "/session", "label": "Go to Session" },
      { "key": "g t", "route": "/tracks", "label": "Go to Tracks" },
      { "key": "g r", "route": "/rooms", "label": "Go to Rooms" }
    ]
  },
  "dependencies": {
    "archetypes": {
      "music-workspace": ">=1.0.0",
      "track-library": ">=1.0.0",
      "collaboration-hub": ">=1.0.0",
      "session-rooms": ">=1.0.0",
      "marketing-producer": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": ["studio-dark", "carbon-neon", "neon-cyber", "terminal"]
}
