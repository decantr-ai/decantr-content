{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "product-landing",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Product Landing Page",
  "description": "Complete product marketing landing page composition. Dark premium aesthetic with vibrant geometric accents, split hero, problem visualization, feature pipeline showcase, and conversion-optimized CTA flow. Derived from the Decantr brand homepage.",
  "compose": [
    "marketing-landing"
  ],
  "suggested_theme": {
    "style": "luminarum",
    "mode": "dark",
    "recipe": "luminarum",
    "shape": "pill"
  },
  "personality": [
    "bold",
    "technical",
    "premium",
    "vibrant"
  ],
  "overrides": {
    "patterns": {
      "hero-split": { "preset": "standard" },
      "before-after": { "preset": "browser-frames" },
      "pipeline-cards": { "preset": "outlined" },
      "tool-list": { "preset": "standard" },
      "quick-start": { "preset": "cards" },
      "cta-banner": { "preset": "gradient" },
      "tech-pills": { "preset": "colored" }
    }
  }
}
