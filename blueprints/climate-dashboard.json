{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "climate-dashboard",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Climate Dashboard",
  "description": "Carbon accounting and emissions dashboard with Scope 1/2/3 tracking, supply chain mapping, offset marketplace, regulatory reporting, and full auth with marketing landing.",
  "tags": ["climate", "esg", "sustainability", "carbon", "csrd", "2026"],
  "compose": [
    "emissions-dashboard",
    "supply-chain",
    "offset-marketplace",
    "reporting-center",
    "marketing-climate",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "light",
    "shape": "rounded",
    "id": "earth"
  },
  "personality": "Carbon accounting and emissions dashboard with organic earth-tone palette. Sankey diagrams show emissions flowing from sources through Scope 1/2/3 categories. Supply chain maps pin suppliers with tier rings showing Scope 3 complexity. Target progress rings track reduction commitments against science-based targets. Regulatory reporting for CSRD, SEC climate rules, Scope 3 disclosure. Lucide icons. Grounded.",
  "voice": {
    "tone": "Factual and urgent. Speaks to sustainability officers and compliance teams.",
    "cta_verbs": ["Measure", "Report", "Reduce", "Offset", "Disclose", "Verify"],
    "avoid": ["Manage", "Track"],
    "empty_states": "No emissions data yet. Connect your first supplier to begin.",
    "errors": "CSRD disclosure incomplete — missing Scope 3 category {n}.",
    "loading": "Calculating emissions... {percent}%"
  },
  "features": ["emissions", "supply-chain", "offsets", "reporting", "auth", "mfa", "oauth", "marketing", "seo"],
  "routes": {
    "/": { "page": "home", "shell": "top-nav-footer", "archetype": "marketing-climate" },
    "/login": { "page": "login", "shell": "centered", "archetype": "auth-full" },
    "/register": { "page": "register", "shell": "centered", "archetype": "auth-full" },
    "/forgot-password": { "page": "forgot-password", "shell": "centered", "archetype": "auth-full" },
    "/reset-password": { "page": "reset-password", "shell": "centered", "archetype": "auth-full" },
    "/verify-email": { "page": "verify-email", "shell": "centered", "archetype": "auth-full" },
    "/mfa-setup": { "page": "mfa-setup", "shell": "centered", "archetype": "auth-full" },
    "/mfa-verify": { "page": "mfa-verify", "shell": "centered", "archetype": "auth-full" },
    "/phone-verify": { "page": "phone-verify", "shell": "centered", "archetype": "auth-full" },
    "/emissions": { "page": "overview", "shell": "sidebar-main", "archetype": "emissions-dashboard" },
    "/emissions/scope/:id": { "page": "scope-detail", "shell": "sidebar-main", "archetype": "emissions-dashboard" },
    "/emissions/targets": { "page": "targets", "shell": "sidebar-main", "archetype": "emissions-dashboard" },
    "/suppliers": { "page": "suppliers", "shell": "sidebar-main", "archetype": "supply-chain" },
    "/suppliers/:id": { "page": "supplier-detail", "shell": "sidebar-main", "archetype": "supply-chain" },
    "/offsets": { "page": "marketplace", "shell": "sidebar-main", "archetype": "offset-marketplace" },
    "/offsets/:id": { "page": "project-detail", "shell": "sidebar-main", "archetype": "offset-marketplace" },
    "/offsets/checkout": { "page": "checkout", "shell": "sidebar-main", "archetype": "offset-marketplace" },
    "/reports": { "page": "reports", "shell": "sidebar-main", "archetype": "reporting-center" },
    "/reports/builder": { "page": "report-builder", "shell": "sidebar-main", "archetype": "reporting-center" },
    "/settings/profile": { "page": "profile", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/security": { "page": "security", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/preferences": { "page": "preferences", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/danger": { "page": "danger", "shell": "sidebar-aside", "archetype": "settings-full" }
  },
  "overrides": { "features_add": [], "features_remove": [], "pages": {}, "pages_remove": [] },
  "seo_hints": { "schema_org": ["Organization", "WebApplication"], "meta_priorities": ["description", "og:image"] },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      { "key": "g e", "route": "/emissions", "label": "Go to Emissions" },
      { "key": "g s", "route": "/suppliers", "label": "Go to Suppliers" },
      { "key": "g r", "route": "/reports", "label": "Go to Reports" }
    ]
  },
  "dependencies": {
    "archetypes": {
      "emissions-dashboard": ">=1.0.0",
      "supply-chain": ">=1.0.0",
      "offset-marketplace": ">=1.0.0",
      "reporting-center": ">=1.0.0",
      "marketing-climate": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": ["earth", "clean", "healthcare", "government"]
}
