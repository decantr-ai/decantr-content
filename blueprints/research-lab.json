{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "research-lab",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Research Lab",
  "description": "Scientific research workspace with lab notebooks, experiment tracking, sample inventory, instrument booking, dataset repository, and full auth with marketing landing.",
  "tags": ["research", "lab", "science", "notebook", "experiments", "2026"],
  "compose": [
    "lab-notebook",
    "experiment-tracker",
    "sample-inventory",
    "instrument-booking",
    "data-repository",
    "marketing-research",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "light",
    "shape": "sharp",
    "id": "lab"
  },
  "personality": "Scientific research workspace with pristine white panels and technical cyan accents. Lab notebook entries with LaTeX formula blocks and image embeds. Protocol steps numbered with reagent lists, equipment chips, and safety badges. Sample trackers with barcode displays and expiry countdowns. Instrument scheduling grids show bookings across lab equipment. Dataset cards with schema trees and quality indicators. Think Benchling meets Jupyter. Lucide icons. Precise.",
  "voice": {
    "tone": "Scientific and methodical. Speaks to researchers, PIs, grad students.",
    "cta_verbs": ["Log", "Analyze", "Publish", "Cite", "Reserve", "Replicate"],
    "avoid": ["Save", "Process"],
    "empty_states": "No experiments logged yet. Start your first notebook entry.",
    "errors": "Protocol step {n} validation failed — missing reagent {name}.",
    "loading": "Processing dataset... {rows}/{total}"
  },
  "features": ["notebook", "experiments", "samples", "instruments", "datasets", "auth", "mfa", "oauth", "marketing", "seo"],
  "routes": {
    "/": { "page": "home", "shell": "top-nav-footer", "archetype": "marketing-research" },
    "/login": { "page": "login", "shell": "centered", "archetype": "auth-full" },
    "/register": { "page": "register", "shell": "centered", "archetype": "auth-full" },
    "/forgot-password": { "page": "forgot-password", "shell": "centered", "archetype": "auth-full" },
    "/reset-password": { "page": "reset-password", "shell": "centered", "archetype": "auth-full" },
    "/verify-email": { "page": "verify-email", "shell": "centered", "archetype": "auth-full" },
    "/mfa-setup": { "page": "mfa-setup", "shell": "centered", "archetype": "auth-full" },
    "/mfa-verify": { "page": "mfa-verify", "shell": "centered", "archetype": "auth-full" },
    "/phone-verify": { "page": "phone-verify", "shell": "centered", "archetype": "auth-full" },
    "/notebook": { "page": "notebook", "shell": "sidebar-aside", "archetype": "lab-notebook" },
    "/notebook/:id": { "page": "entry-detail", "shell": "sidebar-aside", "archetype": "lab-notebook" },
    "/experiments": { "page": "experiments", "shell": "sidebar-main", "archetype": "experiment-tracker" },
    "/experiments/:id": { "page": "experiment-detail", "shell": "sidebar-main", "archetype": "experiment-tracker" },
    "/samples": { "page": "samples", "shell": "sidebar-main", "archetype": "sample-inventory" },
    "/samples/:id": { "page": "sample-detail", "shell": "sidebar-main", "archetype": "sample-inventory" },
    "/instruments": { "page": "instruments", "shell": "sidebar-main", "archetype": "instrument-booking" },
    "/instruments/:id": { "page": "instrument-detail", "shell": "sidebar-main", "archetype": "instrument-booking" },
    "/datasets": { "page": "datasets", "shell": "sidebar-main", "archetype": "data-repository" },
    "/datasets/:id": { "page": "dataset-detail", "shell": "sidebar-main", "archetype": "data-repository" },
    "/settings/profile": { "page": "profile", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/security": { "page": "security", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/preferences": { "page": "preferences", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/danger": { "page": "danger", "shell": "sidebar-aside", "archetype": "settings-full" }
  },
  "overrides": { "features_add": [], "features_remove": [], "pages": {}, "pages_remove": [] },
  "seo_hints": { "schema_org": ["Organization", "ResearchProject"], "meta_priorities": ["description", "og:image"] },
  "navigation": { "command_palette": true, "hotkeys": [] },
  "dependencies": {
    "archetypes": {
      "lab-notebook": ">=1.0.0",
      "experiment-tracker": ">=1.0.0",
      "sample-inventory": ">=1.0.0",
      "instrument-booking": ">=1.0.0",
      "data-repository": ">=1.0.0",
      "marketing-research": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": ["lab", "clean", "healthcare", "paper"]
}
