{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "civic-platform",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Civic Platform",
  "description": "Accessible civic engagement platform with petitions, budget transparency, council meeting archives, service requests, and full auth with marketing landing.",
  "tags": ["civic", "government", "community", "voting", "transparency", "2026"],
  "compose": [
    "engagement-hub",
    "budget-transparency",
    "meeting-archive",
    "service-requests",
    "marketing-civic",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "light",
    "shape": "sharp",
    "id": "government"
  },
  "personality": "Accessible civic engagement platform built for trust and clarity. High-contrast government-standard typography with generous spacing. Budget Sankey flows show taxpayer dollars from source to category to line item. Petition cards display signature progress prominently. Council meeting archives have full video with synchronized transcripts. WCAG AAA compliance throughout. Lucide icons. Accessible.",
  "voice": {
    "tone": "Clear and inclusive. Speaks to all citizens regardless of technical literacy.",
    "cta_verbs": ["Vote", "Sign", "Comment", "Attend", "Request", "Track"],
    "avoid": ["Submit", "Process", "User"],
    "empty_states": "No active petitions in your district. Be the first to start one.",
    "errors": "Your session expired. Sign in again to continue.",
    "loading": "Loading your ballot..."
  },
  "features": ["petitions", "budget", "meetings", "requests", "accessibility", "auth", "mfa", "marketing", "seo"],
  "routes": {
    "/": { "page": "home", "shell": "top-nav-footer", "archetype": "marketing-civic" },
    "/about": { "page": "about", "shell": "top-nav-footer", "archetype": "marketing-civic" },
    "/login": { "page": "login", "shell": "centered", "archetype": "auth-full" },
    "/register": { "page": "register", "shell": "centered", "archetype": "auth-full" },
    "/forgot-password": { "page": "forgot-password", "shell": "centered", "archetype": "auth-full" },
    "/reset-password": { "page": "reset-password", "shell": "centered", "archetype": "auth-full" },
    "/verify-email": { "page": "verify-email", "shell": "centered", "archetype": "auth-full" },
    "/mfa-setup": { "page": "mfa-setup", "shell": "centered", "archetype": "auth-full" },
    "/mfa-verify": { "page": "mfa-verify", "shell": "centered", "archetype": "auth-full" },
    "/phone-verify": { "page": "phone-verify", "shell": "centered", "archetype": "auth-full" },
    "/engage": { "page": "home", "shell": "top-nav-main", "archetype": "engagement-hub" },
    "/engage/petitions": { "page": "petitions", "shell": "top-nav-main", "archetype": "engagement-hub" },
    "/engage/petitions/:id": { "page": "petition-detail", "shell": "top-nav-main", "archetype": "engagement-hub" },
    "/budget": { "page": "budget", "shell": "sidebar-main", "archetype": "budget-transparency" },
    "/budget/:category": { "page": "budget-category", "shell": "sidebar-main", "archetype": "budget-transparency" },
    "/meetings": { "page": "meetings", "shell": "sidebar-main", "archetype": "meeting-archive" },
    "/meetings/:id": { "page": "meeting-detail", "shell": "sidebar-main", "archetype": "meeting-archive" },
    "/requests": { "page": "requests", "shell": "sidebar-main", "archetype": "service-requests" },
    "/requests/new": { "page": "new-request", "shell": "sidebar-main", "archetype": "service-requests" },
    "/requests/:id": { "page": "request-detail", "shell": "sidebar-main", "archetype": "service-requests" },
    "/settings/profile": { "page": "profile", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/security": { "page": "security", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/preferences": { "page": "preferences", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/danger": { "page": "danger", "shell": "sidebar-aside", "archetype": "settings-full" }
  },
  "overrides": { "features_add": [], "features_remove": [], "pages": {}, "pages_remove": [] },
  "seo_hints": { "schema_org": ["GovernmentOrganization", "WebSite"], "meta_priorities": ["description", "og:image"] },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      { "key": "g e", "route": "/engage", "label": "Go to Engage" },
      { "key": "g b", "route": "/budget", "label": "Go to Budget" },
      { "key": "g r", "route": "/requests", "label": "Go to Requests" }
    ]
  },
  "dependencies": {
    "archetypes": {
      "engagement-hub": ">=1.0.0",
      "budget-transparency": ">=1.0.0",
      "meeting-archive": ">=1.0.0",
      "service-requests": ">=1.0.0",
      "marketing-civic": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": ["government", "healthcare", "clean", "paper", "earth"]
}
