{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "restaurant-ops",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Restaurant Ops",
  "description": "Warm restaurant operations hub with floor maps, kitchen display system, menu engineering, inventory, server stations, customer loyalty, daily operations, and full auth with marketing landing.",
  "tags": ["restaurant", "hospitality", "pos", "kds", "operations", "2026"],
  "compose": [
    "restaurant-floor",
    "kitchen-display",
    "menu-management",
    "inventory-supplies",
    "server-station",
    "customer-loyalty",
    "daily-operations",
    "marketing-restaurant",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "light",
    "shape": "rounded",
    "id": "bistro"
  },
  "personality": "Warm restaurant operations hub with terracotta accents and handwritten chalkboard headers. Floor map shows live table status as colored shapes with party sizes. Kitchen display system rail shows order tickets flowing through stations with prep timers. Menu engineering grid highlights profitability per dish. Inventory depletion bars warn on low stock. Tip pool calculators split fairly. Think Toast meets Resy. Lucide icons. Hospitable.",
  "voice": {
    "tone": "Warm and operational. Speaks to owners, managers, servers, line cooks.",
    "cta_verbs": ["Seat", "Fire", "Bump", "Comp", "86", "Close"],
    "avoid": ["Submit", "Process"],
    "empty_states": "No reservations tonight. Perfect time for walk-ins.",
    "errors": "Order #{n} sent to wrong station. Recall and reroute?",
    "loading": "Printing to KDS..."
  },
  "features": ["floor", "kds", "menu", "inventory", "servers", "loyalty", "operations", "auth", "mfa", "oauth", "marketing", "seo"],
  "routes": {
    "/": { "page": "home", "shell": "top-nav-footer", "archetype": "marketing-restaurant" },
    "/login": { "page": "login", "shell": "centered", "archetype": "auth-full" },
    "/register": { "page": "register", "shell": "centered", "archetype": "auth-full" },
    "/forgot-password": { "page": "forgot-password", "shell": "centered", "archetype": "auth-full" },
    "/reset-password": { "page": "reset-password", "shell": "centered", "archetype": "auth-full" },
    "/verify-email": { "page": "verify-email", "shell": "centered", "archetype": "auth-full" },
    "/mfa-setup": { "page": "mfa-setup", "shell": "centered", "archetype": "auth-full" },
    "/mfa-verify": { "page": "mfa-verify", "shell": "centered", "archetype": "auth-full" },
    "/phone-verify": { "page": "phone-verify", "shell": "centered", "archetype": "auth-full" },
    "/floor": { "page": "floor", "shell": "sidebar-main", "archetype": "restaurant-floor" },
    "/floor/reservations": { "page": "reservations", "shell": "sidebar-main", "archetype": "restaurant-floor" },
    "/floor/reservations/new": { "page": "new-reservation", "shell": "sidebar-main", "archetype": "restaurant-floor" },
    "/kitchen": { "page": "kitchen", "shell": "sidebar-main", "archetype": "kitchen-display" },
    "/kitchen/stations": { "page": "stations", "shell": "sidebar-main", "archetype": "kitchen-display" },
    "/menus": { "page": "menus", "shell": "sidebar-main", "archetype": "menu-management" },
    "/menus/:id": { "page": "menu-detail", "shell": "sidebar-main", "archetype": "menu-management" },
    "/menus/engineering": { "page": "menu-engineering", "shell": "sidebar-main", "archetype": "menu-management" },
    "/inventory": { "page": "inventory", "shell": "sidebar-main", "archetype": "inventory-supplies" },
    "/inventory/:id": { "page": "ingredient-detail", "shell": "sidebar-main", "archetype": "inventory-supplies" },
    "/inventory/orders": { "page": "orders", "shell": "sidebar-main", "archetype": "inventory-supplies" },
    "/shift": { "page": "shift", "shell": "sidebar-main", "archetype": "server-station" },
    "/shift/tips": { "page": "tips", "shell": "sidebar-main", "archetype": "server-station" },
    "/customers": { "page": "customers", "shell": "sidebar-main", "archetype": "customer-loyalty" },
    "/customers/:id": { "page": "customer-detail", "shell": "sidebar-main", "archetype": "customer-loyalty" },
    "/customers/loyalty": { "page": "loyalty-program", "shell": "sidebar-main", "archetype": "customer-loyalty" },
    "/ops": { "page": "dashboard", "shell": "sidebar-main", "archetype": "daily-operations" },
    "/ops/reports": { "page": "reports", "shell": "sidebar-main", "archetype": "daily-operations" },
    "/settings/profile": { "page": "profile", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/security": { "page": "security", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/preferences": { "page": "preferences", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/danger": { "page": "danger", "shell": "sidebar-aside", "archetype": "settings-full" }
  },
  "overrides": { "features_add": [], "features_remove": [], "pages": {}, "pages_remove": [] },
  "seo_hints": { "schema_org": ["Restaurant", "Organization"], "meta_priorities": ["description", "og:image"] },
  "navigation": { "command_palette": true, "hotkeys": [] },
  "dependencies": {
    "archetypes": {
      "restaurant-floor": ">=1.0.0",
      "kitchen-display": ">=1.0.0",
      "menu-management": ">=1.0.0",
      "inventory-supplies": ">=1.0.0",
      "server-station": ">=1.0.0",
      "customer-loyalty": ">=1.0.0",
      "daily-operations": ">=1.0.0",
      "marketing-restaurant": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": ["bistro", "earth", "studio", "clean"]
}
