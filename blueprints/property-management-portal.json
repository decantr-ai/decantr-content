{
  "$schema": "decantr-vignette-v1.0",
  "id": "property-management-portal",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Property Management Portal",
  "description": "Complete property management platform for real estate investors and property owners. Includes portfolio dashboard, property/unit management, tenant management, financial tracking (P&L, rent roll, expenses), maintenance ticketing, and a self-service tenant portal.",
  "tags": [
    "property-management",
    "real-estate",
    "landlord",
    "rental",
    "saas",
    "professional"
  ],
  "compose": [
    "owner-dashboard",
    "property-manager",
    "tenant-manager",
    "pm-financials",
    "maintenance-center",
    "tenant-portal",
    "tenant-payments",
    "marketing-realestate",
    "auth-full",
    "settings-full",
    "about-hybrid",
    "contact",
    "legal"
  ],
  "theme": {
    "style": "estate",
    "mode": "light",
    "recipe": "estate",
    "shape": "rounded"
  },
  "personality": [
    "professional",
    "trustworthy",
    "warm",
    "efficient"
  ],
  "overrides": {
    "pages": {},
    "pages_remove": [],
    "features_add": [
      "theme-toggle"
    ],
    "features_remove": []
  },
  "dependencies": {
    "archetypes": {
      "owner-dashboard": "^1.0.0",
      "property-manager": "^1.0.0",
      "tenant-manager": "^1.0.0",
      "pm-financials": "^1.0.0",
      "maintenance-center": "^1.0.0",
      "tenant-portal": "^1.0.0",
      "tenant-payments": "^1.0.0",
      "marketing-realestate": "^1.0.0",
      "auth-full": "^1.0.0",
      "settings-full": "^1.0.0",
      "about-hybrid": "^1.0.0",
      "contact": "^1.0.0",
      "legal": "^1.0.0"
    },
    "recipes": {
      "estate": "^1.0.0"
    },
    "styles": {
      "estate": "^1.0.0"
    }
  },
  "features": [
    "auth",
    "mfa",
    "payments",
    "file-upload",
    "notifications",
    "search",
    "export",
    "theme-toggle",
    "kanban"
  ],
  "routes": {
    "/": {
      "shell": "top-nav-footer",
      "archetype": "marketing-realestate",
      "page": "home"
    },
    "/about": {
      "shell": "top-nav-footer",
      "archetype": "about-hybrid",
      "page": "about"
    },
    "/contact": {
      "shell": "top-nav-footer",
      "archetype": "contact",
      "page": "contact"
    },
    "/pricing": {
      "shell": "top-nav-footer",
      "archetype": "marketing-realestate",
      "page": "home"
    },
    "/privacy": {
      "shell": "top-nav-footer",
      "archetype": "legal",
      "page": "privacy"
    },
    "/terms": {
      "shell": "top-nav-footer",
      "archetype": "legal",
      "page": "terms"
    },
    "/login": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "login"
    },
    "/register": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "register"
    },
    "/forgot-password": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "forgot-password"
    },
    "/reset-password": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "reset-password"
    },
    "/verify-email": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "verify-email"
    },
    "/mfa-setup": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "mfa-setup"
    },
    "/mfa-verify": {
      "shell": "centered",
      "archetype": "auth-full",
      "page": "mfa-verify"
    },
    "/dashboard": {
      "shell": "sidebar-main",
      "archetype": "owner-dashboard",
      "page": "dashboard"
    },
    "/properties": {
      "shell": "sidebar-main",
      "archetype": "property-manager",
      "page": "list"
    },
    "/properties/new": {
      "shell": "sidebar-main",
      "archetype": "property-manager",
      "page": "create"
    },
    "/properties/:id": {
      "shell": "sidebar-main",
      "archetype": "property-manager",
      "page": "detail"
    },
    "/properties/:id/units": {
      "shell": "sidebar-main",
      "archetype": "property-manager",
      "page": "units"
    },
    "/properties/:id/units/:unitId": {
      "shell": "sidebar-main",
      "archetype": "property-manager",
      "page": "unit-detail"
    },
    "/tenants": {
      "shell": "sidebar-main",
      "archetype": "tenant-manager",
      "page": "list"
    },
    "/tenants/:id": {
      "shell": "sidebar-main",
      "archetype": "tenant-manager",
      "page": "detail"
    },
    "/financials": {
      "shell": "sidebar-main",
      "archetype": "pm-financials",
      "page": "overview"
    },
    "/financials/rent-roll": {
      "shell": "sidebar-main",
      "archetype": "pm-financials",
      "page": "rent-roll"
    },
    "/financials/expenses": {
      "shell": "sidebar-main",
      "archetype": "pm-financials",
      "page": "expenses"
    },
    "/maintenance": {
      "shell": "sidebar-main",
      "archetype": "maintenance-center",
      "page": "board"
    },
    "/maintenance/:id": {
      "shell": "sidebar-main",
      "archetype": "maintenance-center",
      "page": "ticket"
    },
    "/documents": {
      "shell": "sidebar-main",
      "archetype": "document-vault",
      "page": "list"
    },
    "/tenant-portal": {
      "shell": "top-nav-main",
      "archetype": "tenant-portal",
      "page": "home"
    },
    "/tenant-portal/payments": {
      "shell": "top-nav-main",
      "archetype": "tenant-payments",
      "page": "overview"
    },
    "/tenant-portal/maintenance": {
      "shell": "top-nav-main",
      "archetype": "tenant-portal",
      "page": "maintenance"
    },
    "/tenant-portal/documents": {
      "shell": "top-nav-main",
      "archetype": "tenant-portal",
      "page": "documents"
    },
    "/settings/profile": {
      "shell": "sidebar-main",
      "archetype": "settings-full",
      "page": "profile"
    },
    "/settings/security": {
      "shell": "sidebar-main",
      "archetype": "settings-full",
      "page": "security"
    },
    "/settings/preferences": {
      "shell": "sidebar-main",
      "archetype": "settings-full",
      "page": "preferences"
    },
    "/settings/account": {
      "shell": "sidebar-main",
      "archetype": "settings-full",
      "page": "danger"
    }
  },
  "seo_hints": {
    "schema_org": ["Organization", "WebApplication", "RealEstateAgent"],
    "meta_priorities": ["description", "og:image", "twitter:card"]
  }
}
