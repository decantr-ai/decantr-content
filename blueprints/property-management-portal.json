  "navigation": {
    "command_palette": true,
    "hotkeys": [
      {
        "key": "g h",
        "route": "/",
        "label": "Go to Home"
      },
      {
        "key": "g d",
        "route": "/dashboard",
        "label": "Go to Dashboard"
      },
      {
        "key": "g p",
        "route": "/properties",
        "label": "Go to Properties"
      },
      {
        "key": "g f",
        "route": "/financials",
        "label": "Go to Financials"
      }
    ]
  }
}
