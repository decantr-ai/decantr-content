{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "property-management-portal",
  "version": "1.0.0",
  "decantr_compat": ">=1.0.0",
  "name": "Property Management Portal",
  "description": "Complete property management platform for real estate investors and property owners. Includes portfolio dashboard, property/unit management, tenant management, financial tracking (P&L, rent roll, expenses), maintenance ticketing, and a self-service tenant portal.",
  "tags": [
    "property-management",
    "real-estate",
    "landlord",
    "rental",
    "saas",
    "professional"
  ],
  "compose": [
    "owner-dashboard",
    "property-manager",
    "tenant-manager",
    "pm-financials",
    "maintenance-center",
    "tenant-portal",
    "tenant-payments",
    "marketing-realestate",
    "auth-full",
    "settings-full",
    "about-hybrid",
    "contact",
    "legal"
  ],
  "theme": {
    "mode": "light",
    "shape": "rounded",
    "id": "estate"
  },
  "personality": "Professional, trust-building property management portal with a warm light theme. Clean card-based layouts for properties and units with status badges (occupied, vacant, maintenance). Financial views use conservative chart styles — bar charts for rent roll, line charts for P&L trends. Tenant directory emphasizes contact info and lease status. Maintenance board uses a kanban layout with priority coloring. The tenant portal feels welcoming and self-service. Think Buildium meets a modern banking app — serious about money, friendly about people.",
  "voice": {
    "tone": "Professional and reassuring. Speaks to property owners with authority and to tenants with warmth and clarity.",
    "cta_verbs": [
      "Add property",
      "View details",
      "Submit request",
      "Pay rent",
      "Export",
      "Schedule"
    ],
    "avoid": [
      "Submit",
      "Click here",
      "Please enter",
      "Buy",
      "Deploy"
    ],
    "empty_states": "Helpful and onboarding-oriented. An empty property list should guide through adding the first property with clear steps. Tenant portal empty states should reassure that everything is in order.",
    "errors": "Professional and specific. Payment processing errors include next steps. Maintenance submission failures offer alternative contact methods.",
    "loading": "Property card skeletons with address line placeholders. Financial tables show column headers while data loads. Tenant portal uses gentle fade-in transitions."
  },
  "overrides": {
    "pages": {},
    "pages_remove": [],
    "features_add": [
      "theme-toggle"
    ],
    "features_remove": []
  },
  "dependencies": {
    "archetypes": {
      "owner-dashboard": "^1.0.0",
      "property-manager": "^1.0.0",
      "tenant-manager": "^1.0.0",
      "pm-financials": "^1.0.0",
      "maintenance-center": "^1.0.0",
      "tenant-portal": "^1.0.0",
      "tenant-payments": "^1.0.0",
      "marketing-realestate": "^1.0.0",
      "auth-full": "^1.0.0",
      "settings-full": "^1.0.0",
      "about-hybrid": "^1.0.0",
      "contact": "^1.0.0",
      "legal": "^1.0.0"
    }
  },
  "features": [
    "dashboard",
    "analytics",
    "notifications",
    "crud",
    "file-upload",
    "search",
    "filters",
    "communication",
    "export",
    "charts",
    "date-range",
    "kanban",
    "drag-drop",
    "self-service",
    "payments",
    "autopay",
    "receipts",
    "marketing",
    "seo",
    "responsive",
    "auth",
    "mfa",
    "oauth",
    "email-verification",
    "password-reset",
    "profile-edit",
    "password-change",
    "mfa-management",
    "session-management",
    "theme-toggle",
    "account-deletion",
    "team-grid",
    "values-display",
    "form-validation",
    "spam-protection",
    "file-attachment",
    "toc-navigation",
    "print-friendly",
    "smooth-scroll"
  ],
  "routes": {
    "/": {
      "shell": "top-nav-footer",
      "archetype": "marketing-realestate",
      "page": "home"
    },
    "/about": {
      "shell": "top-nav-footer",
      "archetype": "about-hybrid",
