{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "health-wellness-portal",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Health & Wellness Portal",
  "description": "Calming, trust-building health portal with patient dashboard, appointment booking, telehealth, health records, and accessible design. WCAG AAA compliance throughout.",
  "tags": [
    "health",
    "wellness",
    "telehealth",
    "appointments",
    "medical",
    "patient-portal",
    "2026"
  ],
  "compose": [
    "patient-dashboard",
    "appointment-center",
    "telehealth-room",
    "health-records",
    "marketing-health",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "light",
    "shape": "rounded",
    "id": "healthcare"
  },
  "personality": "Calming, trust-building health portal with emphasis on clarity and accessibility. Soft blues and teals on warm white backgrounds. Large, readable typography — nothing small or dense. Vitals use color-coded status indicators always supplemented with text labels. Appointment booking is straightforward. Telehealth rooms are calm and functional. Document vault feels secure. Every interaction prioritizes patient confidence. Lucide icons. WCAG AAA compliance throughout.",
  "voice": {
    "tone": "Caring, clear, and professional. Speaks to patients.",
    "cta_verbs": [
      "Book",
      "View",
      "Download",
      "Upload",
      "Connect",
      "Schedule"
    ],
    "avoid": [
      "Submit",
      "Click here",
      "Please enter",
      "Buy now",
      "Urgent"
    ],
    "empty_states": "Reassuring and clear. No appointments? Show a friendly prompt to schedule one. No records? Explain the intake process warmly.",
    "errors": "Gentle and supportive. Never alarming. Always offer a way to contact support. Never use medical jargon in errors.",
    "loading": "Calm skeleton placeholders with soft rounded shapes. Vitals cards show gentle pulse animations. Progressive content reveal."
  },
  "features": [
    "patient-portal",
    "appointments",
    "telehealth",
    "health-records",
    "vitals",
    "medications",
    "auth",
    "mfa",
    "oauth",
    "marketing",
    "seo",
    "accessibility",
    "wcag-aaa"
  ],
  "routes": {
    "/": {
      "page": "home",
      "shell": "top-nav-footer",
      "archetype": "marketing-health"
    },
    "/login": {
      "page": "login",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/register": {
      "page": "register",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/forgot-password": {
      "page": "forgot-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/reset-password": {
      "page": "reset-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/verify-email": {
      "page": "verify-email",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-setup": {
      "page": "mfa-setup",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-verify": {
      "page": "mfa-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/phone-verify": {
      "page": "phone-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/dashboard": {
      "page": "overview",
      "shell": "sidebar-main",
      "archetype": "patient-dashboard"
    },
    "/vitals": {
      "page": "vitals",
      "shell": "sidebar-main",
      "archetype": "patient-dashboard"
    },
    "/medications": {
      "page": "medications",
      "shell": "sidebar-main",
      "archetype": "patient-dashboard"
    },
    "/appointments": {
      "page": "appointments",
      "shell": "sidebar-main",
      "archetype": "appointment-center"
    },
    "/appointments/book": {
      "page": "book",
      "shell": "sidebar-main",
      "archetype": "appointment-center"
    },
    "/appointments/:id": {
      "page": "appointment-detail",
      "shell": "sidebar-main",
      "archetype": "appointment-center"
    },
    "/telehealth": {
      "page": "session",
      "shell": "minimal-header",
      "archetype": "telehealth-room"
    },
    "/records": {
      "page": "records",
      "shell": "sidebar-main",
      "archetype": "health-records"
    },
    "/records/:id": {
      "page": "record-detail",
      "shell": "sidebar-main",
      "archetype": "health-records"
    },
    "/intake": {
      "page": "intake",
      "shell": "sidebar-main",
      "archetype": "health-records"
    },
    "/settings/profile": {
      "page": "profile",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/security": {
      "page": "security",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/preferences": {
      "page": "preferences",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/danger": {
      "page": "danger",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    }
  },
  "overrides": {
    "features_add": [
      "theme-toggle"
    ],
    "features_remove": [],
    "pages": {},
    "pages_remove": []
  },
  "seo_hints": {
    "schema_org": [
      "Organization",
      "MedicalOrganization",
      "WebApplication"
    ],
    "meta_priorities": [
      "description",
      "og:image",
      "twitter:card"
    ]
  },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      {
        "key": "g d",
        "route": "/dashboard",
        "label": "Go to Dashboard"
      },
      {
        "key": "g a",
        "route": "/appointments",
        "label": "Go to Appointments"
      },
      {
        "key": "g r",
        "route": "/records",
        "label": "Go to Records"
      }
    ]
  },
  "dependencies": {
    "archetypes": {
      "patient-dashboard": ">=1.0.0",
      "appointment-center": ">=1.0.0",
      "telehealth-room": ">=1.0.0",
      "health-records": ">=1.0.0",
      "marketing-health": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": [
    "healthcare",
    "clean",
    "government",
    "paper"
  ]
}
