{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "esports-hq",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Esports HQ",
  "description": "Professional esports team operations with roster tracking, scrim scheduling, VOD review, sponsor dashboards, and full auth with marketing landing.",
  "tags": ["esports", "gaming", "team-ops", "competitive", "2026"],
  "compose": [
    "team-operations",
    "scrim-scheduler",
    "vod-review",
    "sponsor-dashboard",
    "marketing-esports",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "dark",
    "shape": "rounded",
    "id": "gaming-guild"
  },
  "personality": "Professional esports team operations hub with vibrant neon-accented rosters and live scoreboards. Player form trackers show sparklines of K/D ratios, win rates, and self-reported mood indicators. Scrim calendars map team availability to opponent windows. VOD review interface with frame-by-frame annotations and drawing tools. Sponsor dashboards track activation metrics. Think Overwatch League backstage. Lucide icons. Competitive.",
  "voice": {
    "tone": "Competitive and operational. Speaks to coaches, analysts, players, managers.",
    "cta_verbs": ["Scrim", "Review", "Draft", "Bench", "Rotate", "Analyze"],
    "avoid": ["Manage", "Handle"],
    "empty_states": "No scrims scheduled. Reach out to the {region} captains.",
    "errors": "VOD upload failed — file size exceeds 4GB limit.",
    "loading": "Loading match replay..."
  },
  "features": ["roster", "scrims", "vods", "sponsors", "auth", "mfa", "oauth", "marketing", "seo"],
  "routes": {
    "/": { "page": "home", "shell": "top-nav-footer", "archetype": "marketing-esports" },
    "/login": { "page": "login", "shell": "centered", "archetype": "auth-full" },
    "/register": { "page": "register", "shell": "centered", "archetype": "auth-full" },
    "/forgot-password": { "page": "forgot-password", "shell": "centered", "archetype": "auth-full" },
    "/reset-password": { "page": "reset-password", "shell": "centered", "archetype": "auth-full" },
    "/verify-email": { "page": "verify-email", "shell": "centered", "archetype": "auth-full" },
    "/mfa-setup": { "page": "mfa-setup", "shell": "centered", "archetype": "auth-full" },
    "/mfa-verify": { "page": "mfa-verify", "shell": "centered", "archetype": "auth-full" },
    "/phone-verify": { "page": "phone-verify", "shell": "centered", "archetype": "auth-full" },
    "/team": { "page": "overview", "shell": "sidebar-main", "archetype": "team-operations" },
    "/team/roster": { "page": "roster", "shell": "sidebar-main", "archetype": "team-operations" },
    "/team/players/:id": { "page": "player-detail", "shell": "sidebar-main", "archetype": "team-operations" },
    "/scrims": { "page": "scrims", "shell": "sidebar-main", "archetype": "scrim-scheduler" },
    "/scrims/:id": { "page": "match-detail", "shell": "sidebar-main", "archetype": "scrim-scheduler" },
    "/vods": { "page": "vods", "shell": "sidebar-main", "archetype": "vod-review" },
    "/vods/:id": { "page": "vod-detail", "shell": "sidebar-main", "archetype": "vod-review" },
    "/sponsors": { "page": "sponsors", "shell": "sidebar-main", "archetype": "sponsor-dashboard" },
    "/sponsors/:id": { "page": "sponsor-detail", "shell": "sidebar-main", "archetype": "sponsor-dashboard" },
    "/settings/profile": { "page": "profile", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/security": { "page": "security", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/preferences": { "page": "preferences", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/danger": { "page": "danger", "shell": "sidebar-aside", "archetype": "settings-full" }
  },
  "overrides": { "features_add": [], "features_remove": [], "pages": {}, "pages_remove": [] },
  "seo_hints": { "schema_org": ["Organization", "SportsTeam"], "meta_priorities": ["description", "og:image"] },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      { "key": "g t", "route": "/team", "label": "Go to Team" },
      { "key": "g s", "route": "/scrims", "label": "Go to Scrims" },
      { "key": "g v", "route": "/vods", "label": "Go to VODs" }
    ]
  },
  "dependencies": {
    "archetypes": {
      "team-operations": ">=1.0.0",
      "scrim-scheduler": ">=1.0.0",
      "vod-review": ">=1.0.0",
      "sponsor-dashboard": ">=1.0.0",
      "marketing-esports": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": ["gaming-guild", "neo-tokyo", "neon-cyber", "carbon-neon", "dopamine"]
}
