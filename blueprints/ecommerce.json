{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "ecommerce",
  "version": "2.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "E-Commerce",
  "description": "Full-featured online retail experience with product browsing, checkout, order tracking, marketing landing, and complete auth and settings.",
  "tags": [
    "ecommerce",
    "store",
    "retail",
    "shopping",
    "checkout",
    "orders",
    "2026"
  ],
  "compose": [
    "storefront-browse",
    "ecommerce-checkout",
    "order-management",
    "marketing-ecommerce",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "id": "auradecantism",
    "mode": "light",
    "shape": "rounded"
  },
  "personality": "Warm, inviting storefront where product imagery takes center stage. Clean white backgrounds with accent pops on CTAs. Typography hierarchy guides the eye from product name to price to action. Cart feels lightweight and frictionless. Checkout is a calm, focused 3-step flow. Order history is clean and scannable. Product cards use generous image space with subtle hover zoom. Comparison tools help shoppers decide. Lucide icons. Mobile-first, touch-friendly.",
  "voice": {
    "tone": "Friendly and confident. Product-focused, not pushy.",
    "cta_verbs": [
      "Shop",
      "Add",
      "Compare",
      "Checkout",
      "Track",
      "Browse"
    ],
    "avoid": [
      "Submit",
      "Click here",
      "Please enter",
      "Purchase immediately"
    ],
    "empty_states": "Warm and inviting. Suggest popular items or categories when a search returns no results. Keep the shopper browsing.",
    "errors": "Reassuring and solution-focused. If a payment fails, suggest alternatives. Never alarm the customer.",
    "loading": "Show product card skeletons with image placeholders. Subtle shimmer animation to signal progress."
  },
  "features": [
    "auth",
    "mfa",
    "oauth",
    "payments",
    "search",
    "analytics",
    "marketing",
    "seo"
  ],
  "routes": {
    "/": {
      "page": "home",
      "shell": "top-nav-footer",
      "archetype": "marketing-ecommerce"
    },
    "/shop": {
      "page": "browse",
      "shell": "top-nav-main",
      "archetype": "storefront-browse"
    },
    "/shop/:id": {
      "page": "product-detail",
      "shell": "top-nav-main",
      "archetype": "storefront-browse"
    },
    "/cart": {
      "page": "cart",
      "shell": "top-nav-main",
      "archetype": "storefront-browse"
    },
    "/checkout": {
      "page": "checkout",
      "shell": "minimal-header",
      "archetype": "ecommerce-checkout"
    },
    "/orders": {
      "page": "orders",
      "shell": "sidebar-main",
      "archetype": "order-management"
    },
    "/orders/:id": {
      "page": "order-detail",
      "shell": "sidebar-main",
      "archetype": "order-management"
    },
    "/login": {
      "page": "login",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/register": {
      "page": "register",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/forgot-password": {
      "page": "forgot-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/reset-password": {
      "page": "reset-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/verify-email": {
      "page": "verify-email",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-setup": {
      "page": "mfa-setup",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-verify": {
      "page": "mfa-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/phone-verify": {
      "page": "phone-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/settings/profile": {
      "page": "profile",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/security": {
      "page": "security",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/preferences": {
      "page": "preferences",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/danger": {
      "page": "danger",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    }
  },
  "overrides": {
    "features_add": [
      "theme-toggle",
      "command-palette"
    ],
    "features_remove": [],
    "pages": {},
    "pages_remove": []
  },
  "navigation": {
    "command_palette": true,
    "hotkey_semantics": {
      "chord_window_ms": 900,
      "input_guard": true,
      "modifier_suppression": true,
      "match_case": false
    },
    "hotkeys": [
      {
        "key": "g h",
        "route": "/",
        "label": "Go to Home"
      },
      {
        "key": "g s",
        "route": "/shop",
        "label": "Go to Shop"
      },
      {
        "key": "g c",
        "route": "/cart",
        "label": "Go to Cart"
      },
      {
        "key": "g o",
        "route": "/orders",
        "label": "Go to Orders"
      },
      {
        "key": "?",
        "action": "openShortcutsHelp",
        "label": "Show keyboard shortcuts"
      }
    ]
  },
  "seo_hints": {
    "schema_org": [
      "WebApplication",
      "Store",
      "Product"
    ],
    "meta_priorities": [
      "description",
      "og:title",
      "og:description",
      "og:image"
    ]
  },
  "dependencies": {
    "archetypes": {
      "storefront-browse": ">=1.0.0",
      "ecommerce-checkout": ">=1.0.0",
      "order-management": ">=1.0.0",
      "marketing-ecommerce": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": [
    "auradecantism",
    "clean",
    "studio",
    "dopamine"
  ]
}
