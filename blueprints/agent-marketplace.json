{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "agent-marketplace",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Agent Marketplace",
  "description": "Full agent marketplace platform for discovering, deploying, and monitoring autonomous agent swarms. Combines orchestration dashboard, auth, marketing landing, and AI transparency views.",
  "tags": [
    "agents",
    "marketplace",
    "orchestration",
    "ai",
    "monitoring",
    "saas",
    "2026"
  ],
  "compose": [
    "agent-orchestrator",
    "auth-full",
    "marketing-saas",
    "ai-transparency"
  ],
  "theme": {
    "mode": "dark",
    "shape": "rounded",
    "id": "carbon-neon"
  },
  "personality": "Confident cyber-minimal agent marketplace. Neon accent glows on dark void backgrounds. Monospace data typography. Agent status shown through color-coded rings and pulse animations. Think Linear meets a mission control center. Lucide icons. No decorative elements — every pixel serves the operator.",
  "voice": {
    "tone": "Operational and precise. Speaks to agent operators and platform engineers. Data-first, minimal prose.",
    "cta_verbs": [
      "Deploy",
      "Monitor",
      "Configure",
      "Browse",
      "Inspect",
      "Activate"
    ],
    "avoid": [
      "Submit",
      "Click here",
      "Please enter",
      "Buy now",
      "Exciting"
    ],
    "empty_states": "Mission-control style. An empty agent fleet should prompt deployment of the first agent with a clear setup flow. No whimsy.",
    "errors": "Diagnostic and actionable. Include agent IDs, error codes, and timestamps. Suggest remediation steps or link to runbooks.",
    "loading": "Status ring skeletons with pulse animation. Agent cards show placeholder rings while data streams in. Monospace data fields use blinking cursor placeholders."
  },
  "features": [
    "agents",
    "monitoring",
    "orchestration",
    "real-time",
    "websockets",
    "auth",
    "mfa",
    "oauth",
    "analytics",
    "observability",
    "marketing",
    "seo"
  ],
  "routes": {
    "/": {
      "page": "home",
      "shell": "top-nav-footer",
      "archetype": "marketing-saas"
    },
    "/login": {
      "page": "login",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/register": {
      "page": "register",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/forgot-password": {
      "page": "forgot-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/reset-password": {
      "page": "reset-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/verify-email": {
      "page": "verify-email",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/agents": {
      "page": "agent-overview",
      "shell": "sidebar-main",
      "archetype": "agent-orchestrator"
    },
    "/agents/:id": {
      "page": "agent-detail",
      "shell": "sidebar-main",
      "archetype": "agent-orchestrator"
    },
    "/agents/config": {
      "page": "agent-config",
      "shell": "sidebar-main",
      "archetype": "agent-orchestrator"
    },
    "/marketplace": {
      "page": "agent-marketplace",
      "shell": "sidebar-main",
      "archetype": "agent-orchestrator"
    },
    "/transparency": {
      "page": "model-overview",
      "shell": "sidebar-main",
      "archetype": "ai-transparency"
    },
    "/transparency/inference": {
      "page": "inference-log",
      "shell": "sidebar-main",
      "archetype": "ai-transparency"
    },
    "/transparency/confidence": {
      "page": "confidence-explorer",
      "shell": "sidebar-main",
      "archetype": "ai-transparency"
    },
    "/mfa-setup": {
      "page": "mfa-setup",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-verify": {
      "page": "mfa-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/phone-verify": {
      "page": "phone-verify",
      "shell": "centered",
      "archetype": "auth-full"
    }
  },
  "overrides": {
    "features_add": [
      "theme-toggle",
      "command-palette"
    ],
    "features_remove": [],
    "pages": {},
    "pages_remove": []
  },
  "seo_hints": {
    "schema_org": [
      "Organization",
      "WebApplication",
      "SoftwareApplication"
    ],
    "meta_priorities": [
      "description",
      "og:image",
      "twitter:card"
    ]
  },
  "navigation": {
    "command_palette": {
      "trigger": "Cmd+K",
      "placeholder": "Type a command or search...",
      "width": "640px",
      "styling": "modal",
      "commands": [
        { "id": "nav.agents", "label": "Go to Agents", "section": "Navigation", "hotkey": "g a", "route": "/agents" },
        { "id": "nav.marketplace", "label": "Go to Marketplace", "section": "Navigation", "hotkey": "g m", "route": "/marketplace" },
        { "id": "nav.transparency", "label": "Go to Transparency", "section": "Navigation", "hotkey": "g t", "route": "/transparency" },
        { "id": "agent.new", "label": "Deploy new agent", "section": "Agents", "action": "openNewAgentDialog" },
        { "id": "agent.config", "label": "Open agent config", "section": "Agents", "route": "/agents/config" },
        { "id": "marketplace.search", "label": "Search marketplace...", "section": "Marketplace", "action": "focusMarketplaceSearch" },
        { "id": "transparency.inference", "label": "Open inference log", "section": "Transparency", "route": "/transparency/inference" },
        { "id": "transparency.confidence", "label": "Open confidence explorer", "section": "Transparency", "route": "/transparency/confidence" },
        { "id": "theme.toggle", "label": "Toggle theme mode", "section": "Settings", "action": "toggleThemeMode" },
        { "id": "auth.signout", "label": "Sign out", "section": "Account", "action": "signOut" }
      ]
    },
    "hotkey_semantics": {
      "chord_window_ms": 900,
      "input_guard": true,
      "modifier_suppression": true,
      "match_case": false
    },
    "hotkeys": [
      {
        "key": "g a",
        "route": "/agents",
        "label": "Go to Agents"
      },
      {
        "key": "g m",
        "route": "/marketplace",
        "label": "Go to Marketplace"
      },
      {
        "key": "g t",
        "route": "/transparency",
        "label": "Go to Transparency"
      },
      {
        "key": "?",
        "action": "openShortcutsHelp",
        "label": "Show keyboard shortcuts",
        "semantics": {
          "input_guard": true,
          "modifier_suppression": false
        }
      }
    ]
  },
  "dependencies": {
    "archetypes": {
      "agent-orchestrator": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "marketing-saas": ">=1.0.0",
      "ai-transparency": ">=1.0.0"
    }
  },
  "suggested_themes": [
    "carbon-neon",
    "carbon",
    "terminal",
    "neon-cyber"
  ]
}
