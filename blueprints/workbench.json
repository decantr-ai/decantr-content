{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "workbench",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Workbench",
  "description": "Technical design-system workbench with multi-panel IDE workspace, component catalog browser, property inspector with live preview, and full auth and settings. Multi-archetype composition for design system power users.",
  "tags": ["workbench", "ide", "design-system", "components", "developer", "2026"],
  "compose": [
    "workbench-core",
    "workbench-catalog",
    "workbench-inspector",
    "auth-flow",
    "settings"
  ],
  "theme": {
    "mode": "dark",
    "shape": "rounded",
    "id": "auradecantism"
  },
  "personality": "Technical design-system workbench for power users. Dense, IDE-like layout with multi-panel navigation. Monospace typography for code and data, system fonts for UI labels. The workspace splits into resizable panes — component tree on the left, live preview center, property inspector right. Catalog is a browsable grid with instant search. Everything responds to keyboard shortcuts. Command palette for quick navigation. Think VS Code crossed with Storybook. Lucide icons. No wasted space.",
  "voice": {
    "tone": "Technical and efficient. Speaks to design system engineers.",
    "cta_verbs": ["Inspect", "Browse", "Preview", "Configure", "Export", "Search"],
    "avoid": ["Submit", "Click here", "Please enter", "Buy", "Subscribe"],
    "empty_states": "Technical and helpful. An empty component list should explain how to register components or link to documentation.",
    "errors": "Developer-friendly. Show error codes, stack traces for component render failures, and link to relevant docs.",
    "loading": "Code skeleton blocks with line-height placeholders. Component preview areas show a subtle grid pattern while loading."
  },
  "features": [
    "auth",
    "keyboard-shortcuts",
    "search",
    "split-pane",
    "command-palette",
    "live-preview"
  ],
  "routes": {
    "/workspace": {
      "page": "workspace",
      "shell": "sidebar-aside",
      "archetype": "workbench-core"
    },
    "/workspace/:id": {
      "page": "component-detail",
      "shell": "sidebar-aside",
      "archetype": "workbench-core"
    },
    "/catalog": {
      "page": "catalog",
      "shell": "sidebar-main",
      "archetype": "workbench-catalog"
    },
    "/catalog/:id": {
      "page": "catalog-detail",
      "shell": "sidebar-main",
      "archetype": "workbench-catalog"
    },
    "/inspector": {
      "page": "inspector",
      "shell": "sidebar-aside",
      "archetype": "workbench-inspector"
    },
    "/preview": {
      "page": "preview",
      "shell": "sidebar-aside",
      "archetype": "workbench-inspector"
    },
    "/login": {
      "page": "login",
      "shell": "centered",
      "archetype": "auth-flow"
    },
    "/register": {
      "page": "register",
      "shell": "centered",
      "archetype": "auth-flow"
    },
    "/forgot-password": {
      "page": "forgot-password",
      "shell": "centered",
      "archetype": "auth-flow"
    },
    "/settings": {
      "page": "settings",
      "shell": "sidebar-main",
      "archetype": "settings"
    }
  },
  "overrides": {
    "features_add": ["theme-toggle"],
    "features_remove": [],
    "pages": {},
    "pages_remove": []
  },
  "seo_hints": {
    "schema_org": ["WebApplication", "SoftwareApplication"],
    "meta_priorities": ["description", "og:title", "og:description"]
  },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      { "key": "g w", "route": "/workspace", "label": "Go to Workspace" },
      { "key": "g c", "route": "/catalog", "label": "Go to Catalog" },
      { "key": "g i", "route": "/inspector", "label": "Go to Inspector" },
      { "key": "g p", "route": "/preview", "label": "Go to Preview" },
      { "key": "g s", "route": "/settings", "label": "Go to Settings" }
    ]
  },
  "dependencies": {
    "archetypes": {
      "workbench-core": ">=1.0.0",
      "workbench-catalog": ">=1.0.0",
      "workbench-inspector": ">=1.0.0",
      "auth-flow": ">=1.0.0",
      "settings": ">=1.0.0"
    }
  }
}