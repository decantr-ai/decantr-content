{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "data-pipeline-studio",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Data Pipeline Studio",
  "description": "Technical data engineering workspace with visual pipeline builder, source catalog, transformation editor, job monitoring, and terminal-inspired aesthetics. Built for data engineers.",
  "tags": [
    "data",
    "etl",
    "pipeline",
    "integration",
    "transformation",
    "engineering",
    "2026"
  ],
  "compose": [
    "pipeline-builder",
    "source-catalog",
    "transformation-editor",
    "job-monitor",
    "marketing-pipeline",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "dark",
    "shape": "sharp",
    "id": "terminal"
  },
  "personality": "Technical data engineering workspace with terminal-inspired aesthetics. Phosphor green/amber on black for pipeline canvas and log viewers. ASCII box borders on panels. Monospace everywhere. Visual pipeline builder uses nodes and edges with animated data flow particles. Source connectors show recognizable database/API icons. Transformation nodes show SQL/code previews. Think dbt Cloud meets Prefect meets a retro terminal. Lucide icons mixed with data-type icons.",
  "voice": {
    "tone": "Technical and direct. Speaks to data engineers.",
    "cta_verbs": [
      "Run",
      "Deploy",
      "Connect",
      "Transform",
      "Preview",
      "Monitor"
    ],
    "avoid": [
      "Submit",
      "Click here",
      "Please enter",
      "Buy now",
      "Easy"
    ],
    "empty_states": "Terminal-style. An empty pipeline workspace shows a blinking cursor prompt inviting the user to create their first pipeline. No decoration.",
    "errors": "Diagnostic and log-formatted. Include job IDs, timestamps, and stack traces. Suggest fixes or link to docs.",
    "loading": "Terminal-style progress bars with percentage. Pipeline nodes show blinking status indicators. Log lines stream in real-time."
  },
  "features": [
    "pipelines",
    "data-sources",
    "transformations",
    "job-monitoring",
    "visual-builder",
    "sql-editor",
    "auth",
    "mfa",
    "oauth",
    "marketing",
    "seo",
    "real-time",
    "node-graph"
  ],
  "routes": {
    "/": {
      "page": "home",
      "shell": "top-nav-footer",
      "archetype": "marketing-pipeline"
    },
    "/login": {
      "page": "login",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/register": {
      "page": "register",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/forgot-password": {
      "page": "forgot-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/reset-password": {
      "page": "reset-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/verify-email": {
      "page": "verify-email",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-setup": {
      "page": "mfa-setup",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-verify": {
      "page": "mfa-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/phone-verify": {
      "page": "phone-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/pipelines": {
      "page": "pipelines",
      "shell": "terminal-split",
      "archetype": "pipeline-builder"
    },
    "/pipelines/:id": {
      "page": "pipeline-editor",
      "shell": "terminal-split",
      "archetype": "pipeline-builder"
    },
    "/pipelines/:id/config": {
      "page": "pipeline-config",
      "shell": "terminal-split",
      "archetype": "pipeline-builder"
    },
    "/sources": {
      "page": "sources",
      "shell": "sidebar-main",
      "archetype": "source-catalog"
    },
    "/sources/:id": {
      "page": "source-detail",
      "shell": "sidebar-main",
      "archetype": "source-catalog"
    },
    "/connections": {
      "page": "connections",
      "shell": "sidebar-main",
      "archetype": "source-catalog"
    },
    "/transforms": {
      "page": "transforms",
      "shell": "sidebar-aside",
      "archetype": "transformation-editor"
    },
    "/transforms/:id": {
      "page": "transform-editor",
      "shell": "sidebar-aside",
      "archetype": "transformation-editor"
    },
    "/transforms/preview": {
      "page": "data-preview",
      "shell": "sidebar-aside",
      "archetype": "transformation-editor"
    },
    "/jobs": {
      "page": "jobs",
      "shell": "sidebar-main",
      "archetype": "job-monitor"
    },
    "/jobs/:id": {
      "page": "job-detail",
      "shell": "sidebar-main",
      "archetype": "job-monitor"
    },
    "/settings/profile": {
      "page": "profile",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/security": {
      "page": "security",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/preferences": {
      "page": "preferences",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/danger": {
      "page": "danger",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    }
  },
  "overrides": {
    "features_add": [
      "theme-toggle",
      "command-palette"
    ],
    "features_remove": [],
    "pages": {},
    "pages_remove": []
  },
  "seo_hints": {
    "schema_org": [
      "Organization",
      "WebApplication",
      "SoftwareApplication"
    ],
    "meta_priorities": [
      "description",
      "og:image",
      "twitter:card"
    ]
  },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      {
        "key": "g p",
        "route": "/pipelines",
        "label": "Go to Pipelines"
      },
      {
        "key": "g s",
        "route": "/sources",
        "label": "Go to Sources"
      },
      {
        "key": "g t",
        "route": "/transforms",
        "label": "Go to Transforms"
      },
      {
        "key": "g j",
        "route": "/jobs",
        "label": "Go to Jobs"
      }
    ]
  },
  "dependencies": {
    "archetypes": {
      "pipeline-builder": ">=1.0.0",
      "source-catalog": ">=1.0.0",
      "transformation-editor": ">=1.0.0",
      "job-monitor": ">=1.0.0",
      "marketing-pipeline": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": [
    "terminal",
    "carbon-neon",
    "fintech",
    "carbon"
  ]
}
