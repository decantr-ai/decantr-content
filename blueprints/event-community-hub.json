{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "event-community-hub",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Event & Community Hub",
  "description": "High-energy community hub with event discovery, social feed, ticket checkout, organizer tools, and vibrant marketing landing. Built for connection and celebration.",
  "tags": [
    "events",
    "community",
    "social",
    "ticketing",
    "livestream",
    "2026"
  ],
  "compose": [
    "event-discovery",
    "community-feed",
    "ticket-checkout",
    "organizer-dashboard",
    "marketing-events",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "dark",
    "shape": "rounded",
    "id": "dopamine"
  },
  "personality": "High-energy community hub with bold, vibrant visuals. Y2K-inspired maximalism with saturated event imagery. Event cards are punchy — bold titles, gradient accents, clear date badges. Community feed is social and lively with reactions and comments. Ticket selection is fun, not transactional. Live streams feel immersive with floating chat. Organizer dashboard balances energy with clarity. Lucide icons. Every interaction feels like joining a party.",
  "voice": {
    "tone": "Enthusiastic and inclusive. Celebratory.",
    "cta_verbs": [
      "Join",
      "RSVP",
      "Share",
      "Watch",
      "Connect",
      "Discover"
    ],
    "avoid": [
      "Submit",
      "Click here",
      "Please enter",
      "Buy now",
      "Corporate"
    ],
    "empty_states": "Inviting and energetic. No events yet? Show trending communities and upcoming highlights. Always feel alive.",
    "errors": "Friendly and reassuring. Never kill the vibe. Offer quick recovery and keep the energy up.",
    "loading": "Vibrant gradient skeleton cards. Event images load progressively. Feed items animate in with subtle bounce."
  },
  "features": [
    "events",
    "community",
    "social-feed",
    "ticketing",
    "livestream",
    "organizer-tools",
    "auth",
    "mfa",
    "oauth",
    "marketing",
    "seo",
    "reactions"
  ],
  "routes": {
    "/": {
      "page": "home",
      "shell": "top-nav-footer",
      "archetype": "marketing-events"
    },
    "/login": {
      "page": "login",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/register": {
      "page": "register",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/forgot-password": {
      "page": "forgot-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/reset-password": {
      "page": "reset-password",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/verify-email": {
      "page": "verify-email",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-setup": {
      "page": "mfa-setup",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/mfa-verify": {
      "page": "mfa-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/phone-verify": {
      "page": "phone-verify",
      "shell": "centered",
      "archetype": "auth-full"
    },
    "/events": {
      "page": "events",
      "shell": "top-nav-main",
      "archetype": "event-discovery"
    },
    "/events/:id": {
      "page": "event-detail",
      "shell": "top-nav-main",
      "archetype": "event-discovery"
    },
    "/feed": {
      "page": "feed",
      "shell": "top-nav-main",
      "archetype": "community-feed"
    },
    "/feed/:id": {
      "page": "post-detail",
      "shell": "top-nav-main",
      "archetype": "community-feed"
    },
    "/members": {
      "page": "members",
      "shell": "top-nav-main",
      "archetype": "community-feed"
    },
    "/tickets": {
      "page": "tickets",
      "shell": "minimal-header",
      "archetype": "ticket-checkout"
    },
    "/organizer": {
      "page": "org-overview",
      "shell": "sidebar-main",
      "archetype": "organizer-dashboard"
    },
    "/organizer/events/:id/edit": {
      "page": "org-event-edit",
      "shell": "sidebar-main",
      "archetype": "organizer-dashboard"
    },
    "/organizer/attendees": {
      "page": "org-attendees",
      "shell": "sidebar-main",
      "archetype": "organizer-dashboard"
    },
    "/organizer/analytics": {
      "page": "org-analytics",
      "shell": "sidebar-main",
      "archetype": "organizer-dashboard"
    },
    "/settings/profile": {
      "page": "profile",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/security": {
      "page": "security",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/preferences": {
      "page": "preferences",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    },
    "/settings/danger": {
      "page": "danger",
      "shell": "sidebar-main",
      "archetype": "settings-full"
    }
  },
  "overrides": {
    "features_add": [
      "theme-toggle",
      "command-palette"
    ],
    "features_remove": [],
    "pages": {},
    "pages_remove": []
  },
  "seo_hints": {
    "schema_org": [
      "Organization",
      "Event",
      "WebApplication"
    ],
    "meta_priorities": [
      "description",
      "og:image",
      "twitter:card"
    ]
  },
  "navigation": {
    "command_palette": true,
    "hotkeys": [
      {
        "key": "g e",
        "route": "/events",
        "label": "Go to Events"
      },
      {
        "key": "g f",
        "route": "/feed",
        "label": "Go to Feed"
      },
      {
        "key": "g o",
        "route": "/organizer",
        "label": "Go to Organizer"
      }
    ]
  },
  "dependencies": {
    "archetypes": {
      "event-discovery": ">=1.0.0",
      "community-feed": ">=1.0.0",
      "ticket-checkout": ">=1.0.0",
      "organizer-dashboard": ">=1.0.0",
      "marketing-events": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": [
    "dopamine",
    "neo-tokyo",
    "studio",
    "auradecantism"
  ]
}
