{
  "$schema": "https://decantr.ai/schemas/blueprint.v1.json",
  "id": "legal-research",
  "version": "1.0.0",
  "decantr_compat": ">=1.5.0",
  "name": "Legal Research",
  "description": "Authoritative legal research workspace with case law search, contract diffs, matter management, citation tools, and full auth with marketing landing.",
  "tags": ["legal", "law", "research", "contracts", "matters", "2026"],
  "compose": [
    "research-workspace",
    "contract-center",
    "matter-management",
    "citation-tools",
    "marketing-legal",
    "auth-full",
    "settings-full"
  ],
  "theme": {
    "mode": "light",
    "shape": "rounded",
    "id": "counsel"
  },
  "personality": "Authoritative legal research workspace with warm cream backgrounds and deep navy accents. Serif body typography with monospace case citations. Citation graphs visualize case law networks showing which decisions cite which. Contract diffs reveal redlining with author attribution in margins. Matter cards track billable hours and deadlines with urgency indicators. Lucide icons. Scholarly.",
  "voice": {
    "tone": "Formal and precise. Speaks to attorneys, paralegals, researchers.",
    "cta_verbs": ["Research", "Cite", "Shepardize", "Draft", "Redline", "File"],
    "avoid": ["Click", "Browse"],
    "empty_states": "No matters assigned to you. Ask the partner to add you to a case.",
    "errors": "Citation check failed — {citation} could not be resolved.",
    "loading": "Searching case law..."
  },
  "features": ["research", "contracts", "matters", "citations", "auth", "mfa", "oauth", "marketing", "seo"],
  "routes": {
    "/": { "page": "home", "shell": "top-nav-footer", "archetype": "marketing-legal" },
    "/login": { "page": "login", "shell": "centered", "archetype": "auth-full" },
    "/register": { "page": "register", "shell": "centered", "archetype": "auth-full" },
    "/forgot-password": { "page": "forgot-password", "shell": "centered", "archetype": "auth-full" },
    "/reset-password": { "page": "reset-password", "shell": "centered", "archetype": "auth-full" },
    "/verify-email": { "page": "verify-email", "shell": "centered", "archetype": "auth-full" },
    "/mfa-setup": { "page": "mfa-setup", "shell": "centered", "archetype": "auth-full" },
    "/mfa-verify": { "page": "mfa-verify", "shell": "centered", "archetype": "auth-full" },
    "/phone-verify": { "page": "phone-verify", "shell": "centered", "archetype": "auth-full" },
    "/research": { "page": "search", "shell": "sidebar-aside", "archetype": "research-workspace" },
    "/research/cases/:id": { "page": "case-detail", "shell": "sidebar-aside", "archetype": "research-workspace" },
    "/research/memo": { "page": "research-memo", "shell": "sidebar-aside", "archetype": "research-workspace" },
    "/contracts": { "page": "contracts", "shell": "sidebar-main", "archetype": "contract-center" },
    "/contracts/:id": { "page": "contract-detail", "shell": "sidebar-main", "archetype": "contract-center" },
    "/contracts/compare": { "page": "contract-compare", "shell": "sidebar-main", "archetype": "contract-center" },
    "/matters": { "page": "matters", "shell": "sidebar-main", "archetype": "matter-management" },
    "/matters/:id": { "page": "matter-detail", "shell": "sidebar-main", "archetype": "matter-management" },
    "/citations": { "page": "citations", "shell": "sidebar-main", "archetype": "citation-tools" },
    "/citations/check": { "page": "citation-check", "shell": "sidebar-main", "archetype": "citation-tools" },
    "/settings/profile": { "page": "profile", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/security": { "page": "security", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/preferences": { "page": "preferences", "shell": "sidebar-aside", "archetype": "settings-full" },
    "/settings/danger": { "page": "danger", "shell": "sidebar-aside", "archetype": "settings-full" }
  },
  "overrides": { "features_add": [], "features_remove": [], "pages": {}, "pages_remove": [] },
  "seo_hints": { "schema_org": ["Organization", "WebApplication"], "meta_priorities": ["description", "og:image"] },
  "navigation": { "command_palette": true, "hotkeys": [] },
  "dependencies": {
    "archetypes": {
      "research-workspace": ">=1.0.0",
      "contract-center": ">=1.0.0",
      "matter-management": ">=1.0.0",
      "citation-tools": ">=1.0.0",
      "marketing-legal": ">=1.0.0",
      "auth-full": ">=1.0.0",
      "settings-full": ">=1.0.0"
    }
  },
  "suggested_themes": ["counsel", "bespoke", "paper", "editorial"]
}
