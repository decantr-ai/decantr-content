{
  "id": "sidebar-right",
  "name": "Right Sidebar",
  "description": "Main content with a right-side navigation panel. Useful for settings, documentation sidebars, or inspector layouts.",
  "layout": "grid",
  "atoms": "_grid _h[100vh]",
  "config": {
    "regions": [
      "header",
      "nav",
      "body"
    ],
    "grid": {
      "areas": [
        [
          "header",
          "nav"
        ],
        [
          "body",
          "nav"
        ]
      ]
    },
    "nav": {
      "position": "right",
      "width": "240px",
      "collapseTo": "64px",
      "collapseBelow": "md"
    },
    "header": {
      "height": "52px",
      "sticky": true
    },
    "body": {
      "scroll": true
    }
  },
  "configurable": {
    "nav": {
      "positions": [
        "left",
        "right",
        "top"
      ],
      "modes": [
        "full",
        "rail",
        "hidden"
      ]
    },
    "header": {
      "toggleable": true
    },
    "footer": {
      "toggleable": true
    },
    "sizing": {
      "sidebarWidth": {
        "min": 48,
        "max": 400,
        "default": 240
      },
      "headerHeight": {
        "min": 36,
        "max": 80,
        "default": 52
      }
    }
  },
  "internal_layout": {
    "root": {
      "display": "grid",
      "height": "100vh",
      "grid_template": "columns: 1fr sidebar; rows: 52px 1fr",
      "atoms": "_grid _h[100vh]"
    },
    "header": {
      "height": "52px",
      "display": "flex",
      "align": "center",
      "justify": "space-between",
      "padding": "0 1.5rem",
      "border": "bottom",
      "left_content": "Brand / page title",
      "right_content": "Actions / search",
      "button_sizing": "Buttons in the header use compact sizing: py-1.5 px-3 text-sm (~32px tall). The header is a tight 52px bar \u2014 default d-interactive padding is too large here."
    },
    "body": {
      "flex": "1",
      "overflow_y": "auto",
      "padding": "1.5rem",
      "note": "Main scroll container. Content area is on the left side."
    },
    "sidebar": {
      "width": "240px",
      "collapsed_width": "64px",
      "collapse_breakpoint": "md",
      "position": "right",
      "direction": "column",
      "border": "left",
      "background": "var(--d-surface)",
      "grid_span": "row 1/3",
      "atoms": "_flex _col _borderL",
      "nav": {
        "flex": "1",
        "overflow_y": "auto",
        "padding": "0.5rem",
        "item_treatment": "d-interactive[ghost]",
        "item_padding": "0.375rem 0.75rem",
        "item_gap": "2px",
        "item_content": "icon + label text. Collapsed: icon only."
      },
      "note": "Right-positioned navigation panel. Useful for settings nav, docs sidebar, or inspector."
    }
  },
  "guidance": {
    "section_label_treatment": "d-label[data-anchor]",
    "section_density": "compact"
  },
  "code": {
    "imports": "import { Shell } from 'decantr/components';",
    "example": "Shell({ config: 'sidebar-right' },\n  Shell.Header({}, headerContent),\n  Shell.Nav({}, navContent),\n  Shell.Body({}, mainContent)\n)"
  },
  "$schema": "https://decantr.ai/schemas/shell.v1.json"
}