{
  "id": "top-nav-sidebar",
  "name": "Top Nav + Sidebar",
  "description": "Full-width header spanning both columns, with left sidebar navigation below. Combines top branding with sidebar navigation depth.",
  "layout": "grid",
  "atoms": "_grid _h[100vh]",
  "config": {
    "regions": [
      "header",
      "nav",
      "body"
    ],
    "grid": {
      "areas": [
        [
          "header",
          "header"
        ],
        [
          "nav",
          "body"
        ]
      ]
    },
    "nav": {
      "position": "left",
      "width": "240px",
      "collapseTo": "64px",
      "collapseBelow": "md"
    },
    "header": {
      "height": "52px",
      "sticky": true
    },
    "body": {
      "scroll": true
    }
  },
  "configurable": {
    "nav": {
      "positions": [
        "left",
        "right"
      ],
      "modes": [
        "full",
        "rail",
        "hidden"
      ]
    },
    "header": {
      "toggleable": true
    },
    "footer": {
      "toggleable": true
    },
    "sizing": {
      "sidebarWidth": {
        "min": 48,
        "max": 400,
        "default": 240
      },
      "headerHeight": {
        "min": 36,
        "max": 80,
        "default": 52
      }
    }
  },
  "internal_layout": {
    "root": {
      "display": "grid",
      "height": "100vh",
      "grid_template": "columns: sidebar 1fr; rows: 52px 1fr",
      "atoms": "_grid _h[100vh]"
    },
    "header": {
      "height": "52px",
      "display": "flex",
      "align": "center",
      "justify": "space-between",
      "padding": "0 1.5rem",
      "border": "bottom",
      "background": "var(--d-bg)",
      "sticky": true,
      "grid_span": "column 1/3",
      "left_content": "Brand/logo",
      "right_content": "Search + user actions",
      "note": "Full-width header spanning both sidebar and body columns.",
      "button_sizing": "Buttons in the header use compact sizing: py-1.5 px-3 text-sm (~32px tall). The header is a tight 52px bar \u2014 default d-interactive padding is too large here."
    },
    "sidebar": {
      "width": "240px",
      "collapsed_width": "64px",
      "collapse_breakpoint": "md",
      "position": "left",
      "direction": "column",
      "border": "right",
      "background": "var(--d-surface)",
      "atoms": "_flex _col _borderR",
      "nav": {
        "flex": "1",
        "overflow_y": "auto",
        "padding": "0.5rem",
        "item_treatment": "d-interactive[ghost]",
        "item_padding": "0.375rem 0.75rem",
        "item_gap": "2px",
        "item_content": "icon + label text"
      },
      "note": "Sidebar sits below the full-width header. Contains navigation depth."
    },
    "body": {
      "flex": "1",
      "overflow_y": "auto",
      "padding": "1.5rem",
      "note": "Main scroll container for primary content."
    }
  },
  "code": {
    "imports": "import { Shell } from 'decantr/components';",
    "example": "Shell({ config: 'top-nav-sidebar' },\n  Shell.Header({}, headerContent),\n  Shell.Nav({}, sidebarContent),\n  Shell.Body({}, mainContent)\n)"
  },
  "$schema": "https://decantr.ai/schemas/shell.v1.json"
}