{
  "id": "sidebar-aside",
  "name": "Sidebar + Aside",
  "description": "Three-column layout with left navigation and right inspector/detail panel. Used for admin dashboards, email clients, IDE-style apps.",
  "layout": "grid",
  "atoms": "_grid _h[100vh]",
  "config": {
    "regions": [
      "header",
      "nav",
      "body",
      "aside"
    ],
    "grid": {
      "areas": [
        [
          "nav",
          "header",
          "aside"
        ],
        [
          "nav",
          "body",
          "aside"
        ]
      ]
    },
    "nav": {
      "position": "left",
      "width": "240px",
      "collapseTo": "64px",
      "collapseBelow": "md"
    },
    "header": {
      "height": "52px",
      "sticky": true
    },
    "body": {
      "scroll": true
    },
    "aside": {
      "width": "280px",
      "collapsible": true
    }
  },
  "configurable": {
    "nav": {
      "positions": [
        "left",
        "right"
      ],
      "modes": [
        "full",
        "rail",
        "hidden"
      ]
    },
    "header": {
      "toggleable": true
    },
    "aside": {
      "toggleable": true
    },
    "sizing": {
      "sidebarWidth": {
        "min": 48,
        "max": 400,
        "default": 240
      },
      "headerHeight": {
        "min": 36,
        "max": 80,
        "default": 52
      },
      "asideWidth": {
        "min": 200,
        "max": 480,
        "default": 280
      }
    }
  },
  "internal_layout": {
    "root": {
      "display": "grid",
      "height": "100vh",
      "grid_template": "columns: sidebar 1fr aside; rows: 52px 1fr",
      "atoms": "_grid _h[100vh]"
    },
    "sidebar": {
      "width": "240px",
      "collapsed_width": "64px",
      "collapse_breakpoint": "md",
      "position": "left",
      "direction": "column",
      "border": "right",
      "background": "var(--d-surface)",
      "grid_span": "row 1/3",
      "atoms": "_flex _col _borderR",
      "brand": {
        "height": "52px",
        "display": "flex",
        "align": "center",
        "padding": "0 1rem",
        "border": "bottom",
        "content": "Logo/brand + collapse toggle"
      },
      "nav": {
        "flex": "1",
        "overflow_y": "auto",
        "padding": "0.5rem",
        "item_treatment": "d-interactive[ghost]",
        "item_padding": "0.375rem 0.75rem",
        "item_gap": "2px",
        "item_content": "icon + label text"
      },
      "footer": {
        "border": "top",
        "padding": "0.5rem",
        "position_within": "bottom (mt-auto)",
        "content": "User avatar + settings"
      }
    },
    "header": {
      "height": "52px",
      "display": "flex",
      "align": "center",
      "justify": "space-between",
      "padding": "0 1.5rem",
      "border": "bottom",
      "left_content": "Breadcrumb / page title",
      "right_content": "Actions / search",
      "button_sizing": "Buttons in the header use compact sizing: py-1.5 px-3 text-sm (~32px tall). The header is a tight 52px bar \u2014 default d-interactive padding is too large here."
    },
    "body": {
      "flex": "1",
      "overflow_y": "auto",
      "padding": "1.5rem",
      "note": "Main scroll container for primary content."
    },
    "aside": {
      "width": "280px",
      "collapsible": true,
      "direction": "column",
      "border": "left",
      "background": "var(--d-bg)",
      "grid_span": "row 1/3",
      "atoms": "_flex _col _borderL",
      "note": "Right inspector/detail panel. Toggleable. Shows contextual details, properties, or preview."
    }
  },
  "guidance": {
    "section_label_treatment": "d-label[data-anchor]",
    "section_density": "compact"
  },
  "code": {
    "imports": "import { Shell } from 'decantr/components';",
    "example": "Shell({ config: 'sidebar-aside' },\n  Shell.Header({}, headerContent),\n  Shell.Nav({}, navContent),\n  Shell.Body({}, mainContent),\n  Shell.Aside({}, asideContent)\n)"
  },
  "$schema": "https://decantr.ai/schemas/shell.v1.json"
}