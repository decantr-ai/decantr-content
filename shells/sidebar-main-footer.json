{
  "id": "sidebar-main-footer",
  "name": "Sidebar + Main + Footer",
  "description": "Sidebar layout with a persistent footer bar. Used for apps needing status bars or action footers.",
  "layout": "grid",
  "atoms": "_grid _h[100vh]",
  "config": {
    "regions": [
      "header",
      "nav",
      "body",
      "footer"
    ],
    "grid": {
      "areas": [
        [
          "nav",
          "header"
        ],
        [
          "nav",
          "body"
        ],
        [
          "nav",
          "footer"
        ]
      ]
    },
    "nav": {
      "position": "left",
      "width": "240px",
      "collapseTo": "64px",
      "collapseBelow": "md"
    },
    "header": {
      "height": "52px",
      "sticky": true
    },
    "body": {
      "scroll": true
    },
    "footer": {
      "height": "auto",
      "sticky": false
    }
  },
  "configurable": {
    "nav": {
      "positions": [
        "left",
        "right",
        "top"
      ],
      "modes": [
        "full",
        "rail",
        "hidden"
      ]
    },
    "header": {
      "toggleable": true
    },
    "footer": {
      "toggleable": true
    },
    "sizing": {
      "sidebarWidth": {
        "min": 48,
        "max": 400,
        "default": 240
      },
      "headerHeight": {
        "min": 36,
        "max": 80,
        "default": 52
      }
    }
  },
  "internal_layout": {
    "root": {
      "display": "grid",
      "height": "100vh",
      "grid_template": "columns: sidebar 1fr; rows: 52px 1fr auto",
      "atoms": "_grid _h[100vh]"
    },
    "sidebar": {
      "width": "240px",
      "collapsed_width": "64px",
      "collapse_breakpoint": "md",
      "position": "left",
      "direction": "column",
      "border": "right",
      "background": "var(--d-surface)",
      "grid_span": "row 1/3",
      "atoms": "_flex _col _borderR",
      "brand": {
        "height": "52px",
        "display": "flex",
        "align": "center",
        "padding": "0 1rem",
        "border": "bottom",
        "content": "Logo/brand + collapse toggle"
      },
      "nav": {
        "flex": "1",
        "overflow_y": "auto",
        "padding": "0.5rem",
        "item_treatment": "d-interactive[ghost]",
        "item_padding": "0.375rem 0.75rem",
        "item_gap": "2px",
        "item_content": "icon + label text"
      },
      "footer": {
        "border": "top",
        "padding": "0.5rem",
        "position_within": "bottom (mt-auto)",
        "content": "User avatar + settings"
      }
    },
    "header": {
      "height": "52px",
      "display": "flex",
      "align": "center",
      "justify": "space-between",
      "padding": "0 1.5rem",
      "border": "bottom",
      "left_content": "Breadcrumb / page title",
      "right_content": "Actions / search",
      "button_sizing": "Buttons in the header use compact sizing: py-1.5 px-3 text-sm (~32px tall). The header is a tight 52px bar \u2014 default d-interactive padding is too large here."
    },
    "body": {
      "flex": "1",
      "overflow_y": "auto",
      "padding": "1.5rem",
      "note": "Main scroll container for primary content."
    },
    "footer": {
      "height": "auto",
      "display": "flex",
      "align": "center",
      "padding": "0.75rem 1.5rem",
      "border": "top",
      "note": "Persistent footer bar for status indicators or action buttons. Spans main content column only, not sidebar."
    }
  },
  "guidance": {
    "section_label_treatment": "d-label[data-anchor]",
    "section_density": "compact"
  },
  "code": {
    "imports": "import { Shell } from 'decantr/components';",
    "example": "Shell({ config: 'sidebar-main-footer' },\n  Shell.Header({}, headerContent),\n  Shell.Nav({}, navContent),\n  Shell.Body({}, mainContent),\n  Shell.Footer({}, footerContent)\n)"
  },
  "$schema": "https://decantr.ai/schemas/shell.v1.json"
}